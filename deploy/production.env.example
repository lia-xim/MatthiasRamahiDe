NODE_ENV=production

# Shared
ASTRO_PUBLIC_SITE_URL=https://matthiasramahi.de
PREVIEW_SECRET=change-me-long-random-preview-secret

# Payload
PAYLOAD_SECRET=change-me-long-random-payload-secret
PAYLOAD_PUBLIC_SERVER_URL=https://cms.matthiasramahi.de
PAYLOAD_PORT=3300
PAYLOAD_DB_PUSH=false
POSTGRES_PASSWORD=change-me-long-random-postgres-password
DATABASE_URI=
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=
PAYLOAD_ADMIN_NAME=Matthias Ramahi
ASTRO_PREVIEW_URL=https://matthiasramahi.de
ASTRO_REBUILD_WEBHOOK_URL=http://astro-rebuild:8787/rebuild
ASTRO_REBUILD_WEBHOOK_SECRET=change-me-long-random-rebuild-secret

# Astro draft reads
PAYLOAD_PREVIEW_API_KEY=users-api-key-from-payload-admin

# Contact form / Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
PAYLOAD_EMAIL_FROM_ADDRESS=anfrage@matthiasramahi.de
PAYLOAD_EMAIL_FROM_NAME=Matthias Ramahi CMS
CONTACT_FROM_EMAIL=Matthias Ramahi <anfrage@matthiasramahi.de>
CONTACT_TO_EMAIL=info@matthiasramahi.de
CONTACT_ALERT_EMAIL=info@matthiasramahi.de
# Vercel: /tmp/matthias-contact-queue. Self-hosted Astro: persistent volume path.
CONTACT_QUEUE_DIR=/tmp/matthias-contact-queue
CONTACT_RETRY_SECRET=change-me-long-random-contact-retry-secret
CONTACT_IP_HASH_SALT=change-me-long-random-ip-hash-salt

# Optional S3/R2/Hetzner Object Storage
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
