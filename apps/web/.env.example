# Public site URL used for canonical URLs and social previews
ASTRO_PUBLIC_SITE_URL=https://matthiasramahi.de

# Payload API endpoint used during Astro build/dev and preview rendering
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Must match apps/cms PREVIEW_SECRET
PREVIEW_SECRET=change-me-preview-secret

# Create an API key on the Payload admin user and paste only the key value here.
PAYLOAD_PREVIEW_API_KEY=

# Migration controls
# Adopted core .html URLs are routed through Astro/Payload by default.
ASTRO_ENABLE_ADOPTED_ROUTES=true
# Local SEO pages are approved for private staging and can route through Astro/Payload.
# Set false only if you temporarily want the static legacy fallback for city pages.
ASTRO_ENABLE_LOCAL_SEO_ADOPTED_ROUTES=true
# Allows new Payload pages without a legacy .html file to render from structured CMS fields.
ASTRO_ENABLE_CMS_DYNAMIC_ROUTES=true
ASTRO_ENABLE_CMS_JOURNAL_ROUTES=true
# Keep blog.html visually locked to the approved curated index unless this is intentionally enabled.
ASTRO_ENABLE_CMS_JOURNAL_INDEX_CARDS=false
ASTRO_ENABLE_CMS_SERVICE_ROUTES=true
PAYLOAD_FETCH_TIMEOUT_MS=3500
PAYLOAD_FETCH_CACHE_MS=300000
# Live CMS pages can bypass static-build fetch disabling and use shorter caches.
ASTRO_LIVE_CMS_CACHE_MS=30000
ASTRO_LIVE_PAGE_CACHE_SECONDS=60
ASTRO_LIVE_PAGE_STALE_SECONDS=300

# Contact form delivery via Resend. Set in Vercel project settings, not in Git.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Matthias Ramahi <anfrage@matthiasramahi.de>
CONTACT_TO_EMAIL=info@matthiasramahi.de
CONTACT_ALERT_EMAIL=info@matthiasramahi.de
# Vercel: /tmp/matthias-contact-queue. Local dev: .contact-queue.
CONTACT_QUEUE_DIR=/tmp/matthias-contact-queue
CONTACT_RETRY_SECRET=change-me-contact-retry-secret
CONTACT_IP_HASH_SALT=change-me-ip-hash-salt
