---
import CmsRoutedPage from '../components/cms/CmsRoutedPage.astro'
import LegacyPageShell from '../components/legacy/LegacyPageShell.astro'
import { envFlagNotFalse } from '../lib/envFlags'
import { getLegacyFileForPath } from '../lib/legacy'
import { getBySlug, type PayloadDoc } from '../lib/payload'

export const prerender = false

const slug = Astro.params.slug || ''
const legacyFile = Astro.props.legacyFile || getLegacyFileForPath(Astro.url.pathname)
const enableCmsDynamicRoutes = envFlagNotFalse('ASTRO_ENABLE_CMS_DYNAMIC_ROUTES')
let cmsDoc: PayloadDoc | null = null
let cmsCollection = ''

if (!legacyFile && enableCmsDynamicRoutes && slug) {
  for (const collection of ['site-pages', 'service-pages', 'local-seo-pages'] as const) {
    const doc = await getBySlug(collection, slug, { depth: 2 })
    if (doc) {
      cmsDoc = doc
      cmsCollection = collection
      break
    }
  }
}

if (!legacyFile && !cmsDoc) {
  return new Response('Not found', { status: 404 })
}

Astro.response.headers.set('cache-control', 'public, max-age=300, stale-while-revalidate=86400')
if (cmsDoc) Astro.response.headers.set('x-migration-render', 'cms-dynamic-structured')
---
{legacyFile ? <LegacyPageShell legacyFile={legacyFile} /> : <CmsRoutedPage collection={cmsCollection} doc={cmsDoc as PayloadDoc} />}
