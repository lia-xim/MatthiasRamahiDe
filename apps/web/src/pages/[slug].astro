---
import CmsRoutedPage from '../components/cms/CmsRoutedPage.astro'
import NativeLocalSeoFamilyPage from '../components/cms/NativeLocalSeoFamilyPage.astro'
import Native404Page from '../components/native/Native404Page.astro'
import { getNativeHtmlFileForPath } from '../lib/adoptedRoutes'
import { envFlagNotFalse } from '../lib/envFlags'
import { getBySlug, type PayloadDoc } from '../lib/payload'

export const prerender = false

const slug = Astro.params.slug || ''
const legacyFile = Astro.props.legacyFile || getNativeHtmlFileForPath(Astro.url.pathname)
const enableCmsDynamicRoutes = envFlagNotFalse('ASTRO_ENABLE_CMS_DYNAMIC_ROUTES')
let cmsDoc: PayloadDoc | null = null
let cmsCollection = ''

if (legacyFile) {
  return Astro.redirect(`/${legacyFile}`, 308)
}

if (enableCmsDynamicRoutes && slug) {
  for (const collection of ['site-pages', 'service-pages', 'local-seo-pages'] as const) {
    const doc = await getBySlug(collection, slug, { depth: 2 })
    if (doc) {
      cmsDoc = doc
      cmsCollection = collection
      break
    }
  }
}

if (!cmsDoc) {
  Astro.response.status = 404
  Astro.response.headers.set('cache-control', 'no-store')
} else {
  Astro.response.headers.set('cache-control', 'public, max-age=300, stale-while-revalidate=86400')
  Astro.response.headers.set('x-migration-render', 'cms-dynamic-structured')
}
---
{
  !cmsDoc ? (
    <Native404Page />
  ) : cmsCollection === 'local-seo-pages' ? (
    <NativeLocalSeoFamilyPage doc={cmsDoc as PayloadDoc} />
  ) : (
    <CmsRoutedPage collection={cmsCollection} doc={cmsDoc as PayloadDoc} />
  )
}
