---
import ContentBlocks from '../../components/ContentBlocks.astro'
import ContactCta from '../../components/ContactCta.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import {
  getBySlug,
  imageDisplayUrl,
  internalSitePath,
  linkAttributes,
  routeForDoc,
  toAbsoluteSiteUrl,
} from '../../lib/payload'
import { breadcrumbJsonLd, faqJsonLd, serviceJsonLd, type JsonLd } from '../../lib/seo'

export const prerender = false

const cmsServiceRoutesEnabled = import.meta.env.ASTRO_ENABLE_CMS_SERVICE_ROUTES === 'true'

const { slug } = Astro.params

if (!cmsServiceRoutesEnabled) {
  return Astro.redirect(slug ? `/${slug}.html` : '/leistungen.html', 308)
}

const doc = Astro.props.doc ?? (slug ? await getBySlug('service-pages', slug) : null)

if (!doc) {
  return Astro.redirect('/services')
}

const hero = imageDisplayUrl(doc.heroImage, 'wide')
const proofPoints = (doc.proofPoints ?? []) as Array<{ label?: string; text?: string }>
const audience = (doc.audience ?? []) as Array<{ item?: string }>
const faq = (doc.faq ?? []) as Array<{ question?: string; answer?: string }>
const relatedPages = (doc.relatedPages ?? []) as Array<{ label?: string; href?: string }>
const canonicalUrl = toAbsoluteSiteUrl(doc.seo?.canonicalUrl || routeForDoc('service-pages', doc))
const canonicalPath = internalSitePath(canonicalUrl)
const routePath = internalSitePath(routeForDoc('service-pages', doc))

if (canonicalPath && routePath && canonicalPath.replace(/\/$/, '') !== routePath.replace(/\/$/, '')) {
  return Astro.redirect(canonicalPath, 308)
}

const faqSchema = faqJsonLd(faq)
const jsonLdItems: JsonLd[] = [
  serviceJsonLd(doc, canonicalUrl),
  breadcrumbJsonLd([
    { name: 'Startseite', url: '/' },
    { name: 'Leistungen', url: '/leistungen' },
    { name: doc.title || 'Leistung', url: canonicalUrl },
  ]),
]
if (faqSchema) jsonLdItems.push(faqSchema)
---
<BaseLayout
  title={doc.seo?.title || `${doc.title} | Matthias Ramahi`}
  description={doc.seo?.description || doc.intro || ''}
  canonicalUrl={canonicalUrl}
  noIndex={doc.seo?.noIndex}
  ogImage={doc.seo?.ogImage || doc.heroImage}
  jsonLd={jsonLdItems}
>
  <section class="hero-stage" style={hero ? `background: linear-gradient(180deg, rgba(2,3,6,.32), rgba(2,3,6,.9)), url('${hero}') center / cover;` : ''}>
    <div class="hero-stage__grid container">
      <div>
        <p class="eyebrow">Leistung</p>
        <h1 class="display">{doc.title}</h1>
      </div>
      <p class="copy">{doc.intro}</p>
    </div>
  </section>

  {proofPoints.length > 0 && (
    <section class="container section-pad">
      <p class="eyebrow">Warum diese Leistung</p>
      <div class="card-grid" style="margin-top: 24px;">
        {proofPoints.map((point) => (
          <article class="card">
            <h3>{point.label}</h3>
            <p class="copy">{point.text}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {audience.length > 0 && (
    <section class="container section-pad is-compact">
      <p class="eyebrow">Geeignet fuer</p>
      <div class="filter-row">
        {audience.map((entry) => entry.item && <span>{entry.item}</span>)}
      </div>
    </section>
  )}

  <ContentBlocks blocks={doc.blocks} />

  {faq.length > 0 && (
    <section class="container section-pad">
      <p class="eyebrow">FAQ</p>
      <div class="stack-list">
        {faq.map((item) => (
          <article class="stack-item">
            <h3>{item.question}</h3>
            <p class="copy">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {relatedPages.length > 0 && (
    <section class="container section-pad is-compact">
      <p class="eyebrow">Verwandte Seiten</p>
      <div class="filter-row">
        {relatedPages.map((link) => link.href && <a {...linkAttributes(link)}>{link.label}</a>)}
      </div>
    </section>
  )}

  <ContactCta cta={doc.cta} />
</BaseLayout>
