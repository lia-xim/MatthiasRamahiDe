---
import ContentBlocks from '../../components/ContentBlocks.astro'
import ContactCta from '../../components/ContactCta.astro'
import LoadMoreGallery from '../../components/LoadMoreGallery.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBySlug, imageDisplayUrl, listDocuments, routeForDoc, toAbsoluteSiteUrl } from '../../lib/payload'
import { breadcrumbJsonLd, imageGalleryJsonLd, type JsonLd } from '../../lib/seo'

export const prerender = true

export async function getStaticPaths() {
  const docs = await listDocuments('portfolio-projects', { limit: 300, sort: 'sortOrder,-updatedAt' })
  return docs.map((doc) => ({ params: { slug: doc.slug }, props: { doc } }))
}

const { slug } = Astro.params
const doc = Astro.props.doc ?? (slug ? await getBySlug('portfolio-projects', slug) : null)

if (!doc) {
  return Astro.redirect('/portfolio')
}

const hero = imageDisplayUrl(doc.coverImage, 'wide')
const gallery = doc.gallery ?? []
const portfolioFocus = doc.category || doc.presentationMode || doc.title || 'Portfolio-Serie'
const rawDescription = doc.seo?.description || doc.excerpt || ''
const description =
  rawDescription.length >= 70
    ? rawDescription
    : `${doc.title || 'Portfolio-Serie'}: kuratierte Bildstrecke von Matthias Ramahi mit ausgewählten Motiven, Details und visueller Produktion aus Düsseldorf / NRW.`
const seoCanonicalUrl = doc.seo?.canonicalUrl ? toAbsoluteSiteUrl(doc.seo.canonicalUrl) : ''
const canonicalUrl =
  seoCanonicalUrl && new URL(seoCanonicalUrl).pathname !== '/portfolio.html'
    ? seoCanonicalUrl
    : toAbsoluteSiteUrl(routeForDoc('portfolio-projects', doc))
const gallerySchema = imageGalleryJsonLd(gallery, { name: doc.title || 'Portfolio', url: canonicalUrl })
const jsonLdItems: JsonLd[] = [
  breadcrumbJsonLd([
    { name: 'Startseite', url: '/' },
    { name: 'Portfolio', url: '/portfolio' },
    { name: doc.title || 'Projekt', url: canonicalUrl },
  ]),
]
if (gallerySchema) jsonLdItems.push(gallerySchema)
---
<BaseLayout
  title={doc.seo?.title || `${doc.title} | Matthias Ramahi`}
  description={description}
  canonicalUrl={canonicalUrl}
  noIndex={doc.seo?.noIndex}
  ogImage={doc.seo?.ogImage || doc.coverImage}
  jsonLd={jsonLdItems}
>
  <section class="hero-stage" style={hero ? `background: linear-gradient(180deg, rgba(2,3,6,.35), rgba(2,3,6,.88)), url('${hero}') center / cover;` : ''}>
    <div class="hero-stage__grid container">
      <div>
        <p class="eyebrow">Portfolio / {doc.presentationMode || 'Serie'}</p>
        <h1 class="display">{doc.title}</h1>
      </div>
      <p class="copy">{doc.excerpt}</p>
    </div>
  </section>

  <LoadMoreGallery items={gallery} eyebrow="Bildstrecke" fallback="Portfolio-Bild" />

  <section class="container section-pad">
    <p class="eyebrow">Einordnung</p>
    <div class="stack-list">
      <article class="stack-item">
        <h2>Serie, Einsatz und Bildsprache</h2>
        <p class="copy">
          Diese Auswahl ist als kuratierter Einstieg in {portfolioFocus} gedacht: nicht als endlose Galerie,
          sondern als verdichtete Serie mit Hauptmotiv, Varianten, Details und ruhigen Uebergaengen. Fuer SEO
          und Nutzerfuehrung bleibt die Seite bewusst eigenstaendig, waehrend sie auf die passenden Leistungs-
          und Standortseiten im Fotografie-Cluster verweist.
        </p>
        <p class="copy">
          Entscheidend ist die Lesbarkeit der Bildstrecke. Farbe, Abstand, Perspektive und Reihenfolge sollen
          schnell zeigen, ob eine aehnliche Produktion fuer Marke, Verkauf, Portfolio, Print oder digitale
          Praesentation funktioniert. So bekommt jedes Portfolio-Motiv einen klaren Kontext statt nur einen
          isolierten Galerieplatz.
        </p>
      </article>
    </div>
  </section>

  <ContentBlocks blocks={doc.blocks} />
  <ContactCta cta={doc.cta} />
</BaseLayout>
