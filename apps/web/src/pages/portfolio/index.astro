---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ContactCta from '../../components/ContactCta.astro'
import ResponsiveImage from '../../components/ResponsiveImage.astro'
import { listDocuments, routeForDoc } from '../../lib/payload'

const [projects, categories] = await Promise.all([
  listDocuments('portfolio-projects', { limit: 60, sort: 'sortOrder,-updatedAt' }),
  listDocuments('portfolio-categories', { limit: 30, sort: 'sortOrder,title' }),
])
---
<BaseLayout title="Portfolio — Matthias Ramahi Fotografie" description="Kuratierte Fotografie-Projekte und Bildserien von Matthias Ramahi.">
  <section class="hero-stage">
    <div class="hero-stage__grid container">
      <div>
        <p class="eyebrow">Portfolio</p>
        <h1 class="display">Bildserien, nicht Galerieraster.</h1>
      </div>
      <p class="copy">Ausgewählte Arbeiten aus Automotive, Portrait, Landschaft, Motorrad und visueller Produktion. Jede Serie wird als eigener Bildraum gepflegt: Cover, Sequenz, Kontext, SEO und Anfrageweg.</p>
    </div>
  </section>

  {categories.length > 0 && (
    <section class="container section-pad is-compact">
      <p class="eyebrow">Kapitel</p>
      <div class="filter-row">
        {categories.map((category) => <span>{category.title}</span>)}
      </div>
    </section>
  )}

  <section class="container section-pad">
    {projects.length > 0 ? (
      <div class="card-grid">
        {projects.map((project) => (
          <a class="card" href={routeForDoc('portfolio-projects', project)}>
            <ResponsiveImage media={project.coverImage} size="card" fallback="Portfolio-Bild" />
            <div style="margin-top: 22px;">
              <h3>{project.title}</h3>
              <p class="copy">{project.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p class="eyebrow">Noch keine veröffentlichten Projekte</p>
        <p class="copy">Portfolio-Projekte erscheinen hier, sobald sie in Payload veröffentlicht sind.</p>
      </div>
    )}
  </section>

  <ContactCta />
</BaseLayout>
