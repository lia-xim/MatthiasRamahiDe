---
import NativeJournalPostPage from '../../components/cms/NativeJournalPostPage.astro'
import { envFlag } from '../../lib/envFlags'
import { getBySlug } from '../../lib/payload'

export const prerender = false

const { slug } = Astro.params
const journalRoutesEnabled = envFlag('ASTRO_ENABLE_CMS_JOURNAL_ROUTES') || envFlag('ASTRO_ENABLE_JOURNAL_ROUTES')

if (!journalRoutesEnabled) {
  return Astro.redirect('/blog.html', 308)
}

const doc = Astro.props.doc ?? (slug ? await getBySlug('journal-posts', slug) : null)

if (!doc) {
  return Astro.redirect('/journal')
}
---
<NativeJournalPostPage doc={doc} />
