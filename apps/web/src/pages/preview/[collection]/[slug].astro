---
import CmsRoutedPage from '../../../components/cms/CmsRoutedPage.astro'
import NativeJournalPostPage from '../../../components/cms/NativeJournalPostPage.astro'
import NativeLocalSeoFamilyPage from '../../../components/cms/NativeLocalSeoFamilyPage.astro'
import { getBySlug, routeForDoc } from '../../../lib/payload'

export const prerender = false

const allowedCollections = ['portfolio-projects', 'service-pages', 'local-seo-pages', 'journal-posts', 'site-pages']
const { collection = '', slug = '' } = Astro.params
const secret = Astro.url.searchParams.get('secret')
const expectedSecret = import.meta.env.PREVIEW_SECRET
const isAllowed = allowedCollections.includes(collection)

if (!isAllowed || !expectedSecret || secret !== expectedSecret) {
  return Astro.redirect('/')
}

const doc = await getBySlug(collection, slug, { draft: true, depth: 2 })

if (!doc) {
  return Astro.redirect('/')
}

const publishedHref = routeForDoc(collection, doc)
---
{collection === 'local-seo-pages' ? (
  <NativeLocalSeoFamilyPage doc={doc} preview={{ collection, slug, status: doc._status, publishedHref }} />
) : (
  collection === 'journal-posts' ? (
    <NativeJournalPostPage doc={doc} preview={{ collection, slug, status: doc._status, publishedHref }} />
  ) : (
    <CmsRoutedPage collection={collection} doc={doc} preview={{ collection, slug, status: doc._status, publishedHref }} />
  )
)}
