---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactCta from '../components/ContactCta.astro'
import ContentBlocks from '../components/ContentBlocks.astro'
import ResponsiveImage from '../components/ResponsiveImage.astro'
import { getSitePageByType, imageUrl, listDocuments, routeForDoc, type PayloadDoc } from '../lib/payload'

const [homePage, portfolioProjects, servicePages, journalPosts] = await Promise.all([
  getSitePageByType('home'),
  listDocuments('portfolio-projects', { limit: 6, sort: 'sortOrder,-updatedAt' }),
  listDocuments('service-pages', { limit: 8, sort: 'sortOrder,title' }),
  listDocuments('journal-posts', { limit: 3, sort: '-publishedAt' }),
])

const heroImage = homePage?.heroImage || homePage?.teaserImage
const hero = imageUrl(heroImage, 'wide')
const title = homePage?.seo?.title || 'Matthias Ramahi — Fotografie Düsseldorf & NRW'
const description =
  homePage?.seo?.description ||
  homePage?.intro ||
  'Kuratierte Fotografie aus Düsseldorf: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft.'
const serviceFallback: PayloadDoc[] = [
  { id: 'automobil-fotografie-duesseldorf', title: 'Automobilfotografie', slug: 'automobil-fotografie-duesseldorf', intro: 'Fahrzeuge, Reflexe, Linien und Details als präzise Bildserie.' },
  { id: 'sportwagen-fotografie-duesseldorf', title: 'Sportwagenfotografie', slug: 'sportwagen-fotografie-duesseldorf', intro: 'Performance, Material und Präsenz für private und kommerzielle Serien.' },
  { id: 'oldtimer-fotografie-duesseldorf', title: 'Oldtimer-Fotografie', slug: 'oldtimer-fotografie-duesseldorf', intro: 'Klassiker als Exponat: ruhig, sammlerhaft und wertig.' },
  { id: 'motorrad-fotografie-duesseldorf', title: 'Motorrad-Fotografie', slug: 'motorrad-fotografie-duesseldorf', intro: 'Maschinen, Mechanik und Haltung als kraftvolle Sequenz.' },
  { id: 'portraitfotografie-duesseldorf', title: 'Portraitfotografie', slug: 'portraitfotografie-duesseldorf', intro: 'Portraits mit Nähe, Licht und klarer Nutzungslogik.' },
  { id: 'landschaftsfotografie-duesseldorf', title: 'Landschaftsfotografie', slug: 'landschaftsfotografie-duesseldorf', intro: 'Ruhige Motive für Raum, Print, Web und Sammlung.' },
]
const serviceCards = servicePages.length ? servicePages : serviceFallback
---
<BaseLayout title={title} description={description} noIndex={homePage?.seo?.noIndex} ogImage={homePage?.seo?.ogImage || heroImage}>
  <section class="hero-stage" style={hero ? `background: linear-gradient(180deg, rgba(2,3,6,.24), rgba(2,3,6,.9)), url('${hero}') center / cover;` : ''}>
    <div class="hero-stage__grid container">
      <div>
        <p class="eyebrow">Düsseldorf / NRW</p>
        <h1 class="display">{homePage?.title || 'Fotografie, die Räume öffnet.'}</h1>
      </div>
      <div>
        <p class="copy">{homePage?.intro || 'Automotive, Portrait, Landschaft und visuelle Produktion - ruhig kuratiert, technisch sauber und bereit für Web, Print und Kampagne.'}</p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px;">
          <a class="button is-accent" href="/portfolio">Portfolio ansehen</a>
          <a class="button" href="mailto:info@matthiasramahi.de?subject=Projektanfrage">Anfrage senden</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container section-pad">
    <p class="eyebrow">Fotografie</p>
    <div class="card-grid" style="margin-top: 24px;">
      {serviceCards.map((service) => (
        <a class="card" href={service.slug ? routeForDoc('service-pages', service) : '/services'}>
          <ResponsiveImage media={service.teaserImage || service.heroImage} size="card" fallback="Leistungsbild" />
          <div style="margin-top: 22px;">
            <h3>{service.title}</h3>
            <p class="copy">{service.intro || service.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {portfolioProjects.length > 0 && (
    <section class="container section-pad">
      <p class="eyebrow">Ausgewählte Arbeiten</p>
      <div class="card-grid" style="margin-top: 24px;">
        {portfolioProjects.map((project) => (
          <a class="card" href={routeForDoc('portfolio-projects', project)}>
            <ResponsiveImage media={project.coverImage} size="card" fallback="Portfolio-Bild" />
            <div style="margin-top: 22px;">
              <h3>{project.title}</h3>
              <p class="copy">{project.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {homePage?.blocks && <ContentBlocks blocks={homePage.blocks} />}

  {journalPosts.length > 0 && (
    <section class="container section-pad">
      <p class="eyebrow">Journal</p>
      <div class="card-grid" style="margin-top: 24px;">
        {journalPosts.map((post) => (
          <a class="card" href={routeForDoc('journal-posts', post)}>
            <ResponsiveImage media={post.coverImage} size="card" fallback="Journal-Bild" />
            <h3 style="margin-top: 22px;">{post.title}</h3>
            <p class="copy">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <ContactCta cta={homePage?.contactOverride || homePage?.cta} />
</BaseLayout>
