---
import NativeAdoptedPage from '../../components/native/NativeAdoptedPage.astro'
import {
  getLegacyRedirectTarget,
  getNativeHtmlFileForPath,
  isCmsAdoptedLegacyFile,
} from '../../lib/adoptedRoutes'

export const prerender = false

const slug = Astro.params.slug || ''
const legacyFile = getNativeHtmlFileForPath(`/${slug}.html`) || getNativeHtmlFileForPath(`/${slug}`)

if (!legacyFile || !isCmsAdoptedLegacyFile(legacyFile, { includeLocalSeo: true })) {
  return Astro.redirect('/')
}

const redirectTarget = getLegacyRedirectTarget(legacyFile)

if (redirectTarget) {
  return Astro.redirect(`/${redirectTarget}`, 308)
}

Astro.response.headers.set(
  'cache-control',
  import.meta.env.DEV ? 'no-store' : 'public, max-age=300, stale-while-revalidate=86400',
)
Astro.response.headers.set('x-migration-render', 'adopted-astro-payload')
---
<NativeAdoptedPage legacyFile={legacyFile} />
