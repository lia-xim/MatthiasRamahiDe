---
import NativeAdoptedPage from '../components/native/NativeAdoptedPage.astro'
import {
  getLegacyRedirectTarget,
  isCmsAdoptedLegacyFile,
  listNativeHtmlRouteFiles,
} from '../lib/adoptedRoutes'

export const prerender = true

type Props = {
  legacyFile?: string
}

export function getStaticPaths() {
  return listNativeHtmlRouteFiles()
    .filter((file) => file !== 'index.html')
    .map((file) => ({
      params: { slug: file.replace(/\.html$/i, '') },
      props: { legacyFile: file },
    }))
}

const { legacyFile } = Astro.props as Props

if (!legacyFile) {
  return new Response('Not found', { status: 404 })
}

const redirectTarget = getLegacyRedirectTarget(legacyFile)

if (redirectTarget) {
  return Astro.redirect(`/${redirectTarget}`, 308)
}

const shouldRenderFromCms = isCmsAdoptedLegacyFile(legacyFile, { includeLocalSeo: true })

if (!shouldRenderFromCms) {
  return new Response('Not found', { status: 404 })
}

Astro.response.headers.set('x-migration-render', 'adopted-astro-payload')
---
<NativeAdoptedPage legacyFile={legacyFile} />
