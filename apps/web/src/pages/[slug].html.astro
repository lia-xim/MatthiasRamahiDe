---
import LegacyPageShell from '../components/legacy/LegacyPageShell.astro'
import { isCmsAdoptedLegacyFile } from '../lib/adoptedRoutes'
import { envFlag, envFlagNotFalse } from '../lib/envFlags'
import { listLegacyHtmlFiles, readLegacyPage } from '../lib/legacy'

export const prerender = true

type Props = {
  legacyFile?: string
}

const enableAdoptedRouteRewrite = envFlagNotFalse('ASTRO_ENABLE_ADOPTED_ROUTES')
const enableLocalSeoAdoptedRouteRewrite = envFlag('ASTRO_ENABLE_LOCAL_SEO_ADOPTED_ROUTES')

export async function getStaticPaths() {
  const files = await listLegacyHtmlFiles()
  return files
    .filter((file) => file !== 'index.html')
    .map((file) => ({
      params: { slug: file.replace(/\.html$/i, '') },
      props: { legacyFile: file },
    }))
}

const { legacyFile } = Astro.props as Props

if (!legacyFile) {
  return new Response('Not found', { status: 404 })
}

const shouldRenderFromCms =
  enableAdoptedRouteRewrite &&
  isCmsAdoptedLegacyFile(legacyFile, { includeLocalSeo: enableLocalSeoAdoptedRouteRewrite })

const legacyHtml = shouldRenderFromCms ? '' : await readLegacyPage(legacyFile)

if (shouldRenderFromCms) Astro.response.headers.set('x-migration-render', 'adopted-astro-payload')
---
{shouldRenderFromCms ? <LegacyPageShell legacyFile={legacyFile} /> : <Fragment set:html={legacyHtml} />}
