---
import { getNavigation, linkAttributes } from '../lib/payload'

const navigation = await getNavigation()
const links = navigation?.primary?.length
  ? navigation.primary
  : [
      { label: 'Home', href: '/' },
      { label: 'Fotografie', href: '/fotografie-duesseldorf' },
      { label: 'Portfolio', href: '/portfolio.html' },
      { label: 'Über mich', href: '/ueber-mich' },
      { label: 'Journal', href: '/journal' },
      { label: 'Kontakt', href: '/kontakt' },
    ]
const cta = navigation?.cta?.href
  ? navigation.cta
  : { label: 'Projekt anfragen', href: '/contact.html#anfrage' }
---
<header class="site-header">
  <div class="site-header__inner container">
    <a class="brand-mark" href="/" aria-label="Matthias Ramahi Startseite">Matthias<br />Ramahi</a>
    <nav class="nav" aria-label="Hauptnavigation">
      {links.map((link) => link.href && <a {...linkAttributes(link)}>{link.label}</a>)}
    </nav>
    <a class="button is-accent" {...linkAttributes(cta)}>{cta.label || 'Projekt anfragen'}</a>
  </div>
</header>
