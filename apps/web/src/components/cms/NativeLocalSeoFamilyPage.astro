---
import PreviewToolbar from '../PreviewToolbar.astro'
import NativeLegacyLayout from '../../layouts/NativeLegacyLayout.astro'
import { getLegacyFileForPath } from '../../lib/legacy'
import { getComponentizedLegacyParts } from '../../lib/legacyParts'
import { localSeoLayoutFamilyForDoc, localSeoLayoutFamilyForSlug, localSeoParentLegacyFiles } from '../../lib/localSeoLayoutFamilies'
import { routeForDoc, type PayloadDoc } from '../../lib/payload'

type PreviewState = {
  collection: string
  publishedHref: string
  slug: string
  status?: string
}

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string | null
  preview?: PreviewState
}

const { doc, legacyFile: providedLegacyFile, preview } = Astro.props as Props

function legacyCandidate(value?: string | null) {
  if (!value) return null
  const pathname = value.replace(/^https?:\/\/[^/]+/i, '')
  const clean = pathname.startsWith('/') ? pathname : `/${pathname}`
  return getLegacyFileForPath(clean)
}

const localLegacyFile =
  providedLegacyFile ||
  legacyCandidate(doc?.legacy?.sourceFile) ||
  legacyCandidate(doc?.seo?.legacyUrl) ||
  legacyCandidate(doc?.slug) ||
  legacyCandidate(doc?.slug ? `${doc.slug}.html` : null)

const family =
  localSeoLayoutFamilyForSlug(localLegacyFile) ||
  localSeoLayoutFamilyForDoc(doc)

const parentLegacyFile = family ? localSeoParentLegacyFiles[family] : null
const shouldRenderFamilyLayout = Boolean(localLegacyFile && family && parentLegacyFile)
const legacyParts = shouldRenderFamilyLayout ? await getComponentizedLegacyParts(localLegacyFile as string) : null
const fallbackDoc = !shouldRenderFamilyLayout && doc ? doc : null
const FallbackLocalSeoPage = fallbackDoc ? (await import('./NativeLocalSeoPage.astro')).default : null
const publishedHref = preview?.publishedHref || (doc ? routeForDoc('local-seo-pages', doc) : localLegacyFile ? `/${localLegacyFile}` : '/')

if (shouldRenderFamilyLayout) {
  Astro.response.headers.set('x-cms-render-source', 'local-seo-family-layout')
  Astro.response.headers.set('x-cms-layout-family', family as string)
  Astro.response.headers.set('x-cms-layout-parent', parentLegacyFile as string)
}
---
{shouldRenderFamilyLayout && legacyParts ? (
  <NativeLegacyLayout legacyFile={localLegacyFile as string} current="fotografie" doc={doc} noIndex={Boolean(preview)}>
    <Fragment set:html={`<!-- cms-local-seo-family:${family}; parent:${parentLegacyFile}; source:${localLegacyFile} -->`} />
    {preview && (
      <PreviewToolbar
        collection={preview.collection}
        slug={preview.slug}
        status={preview.status}
        publishedHref={publishedHref}
      />
    )}
    <Fragment set:html={legacyParts.pageContent} />
  </NativeLegacyLayout>
) : FallbackLocalSeoPage && fallbackDoc ? (
  <FallbackLocalSeoPage doc={fallbackDoc} preview={preview} />
) : null}
