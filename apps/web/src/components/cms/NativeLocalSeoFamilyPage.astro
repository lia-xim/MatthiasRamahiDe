---
import NativeLocalSeoFamilyStructuredPage from './NativeLocalSeoFamilyStructuredPage.astro'
import { getNativeHtmlFileForPath } from '../../lib/adoptedRoutes'
import { localSeoFamilyContent } from '../../lib/localSeoFamilyContent'
import { localSeoLayoutFamilyForDoc, localSeoLayoutFamilyForSlug } from '../../lib/localSeoLayoutFamilies'
import type { PayloadDoc } from '../../lib/payload'

type PreviewState = {
  collection: string
  publishedHref: string
  slug: string
  status?: string
}

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string | null
  preview?: PreviewState
}

const { doc, legacyFile: providedLegacyFile, preview } = Astro.props as Props

function legacyCandidate(value?: string | null) {
  if (!value) return null
  const pathname = value.replace(/^https?:\/\/[^/]+/i, '')
  const clean = pathname.startsWith('/') ? pathname : `/${pathname}`
  return getNativeHtmlFileForPath(clean)
}

const localLegacyFile =
  providedLegacyFile ||
  legacyCandidate(doc?.legacy?.sourceFile) ||
  legacyCandidate(doc?.seo?.legacyUrl) ||
  legacyCandidate(doc?.slug) ||
  legacyCandidate(doc?.slug ? `${doc.slug}.html` : null)

const family =
  localSeoLayoutFamilyForSlug(localLegacyFile) ||
  localSeoLayoutFamilyForDoc(doc)

const familyContent = family ? localSeoFamilyContent[family] : null
const shouldRenderFamilyLayout = Boolean(localLegacyFile && familyContent)
const fallbackDoc = !shouldRenderFamilyLayout && doc ? doc : null
const FallbackLocalSeoPage = fallbackDoc ? (await import('./NativeLocalSeoPage.astro')).default : null

if (shouldRenderFamilyLayout) {
  Astro.response.headers.set('x-cms-render-source', 'structured-local-seo-family')
  Astro.response.headers.set('x-cms-layout-family', familyContent!.family)
  Astro.response.headers.set('x-cms-layout-parent', familyContent!.parentLegacyFile)
}
---
{shouldRenderFamilyLayout && familyContent ? (
  <NativeLocalSeoFamilyStructuredPage
    doc={doc}
    familyContent={familyContent}
    legacyFile={localLegacyFile as string}
    preview={preview}
  />
) : FallbackLocalSeoPage && fallbackDoc ? (
  <FallbackLocalSeoPage doc={fallbackDoc} preview={preview} />
) : null}
