---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import NativeFamilyClusterLinks from './NativeFamilyClusterLinks.astro'
import PreviewToolbar from '../PreviewToolbar.astro'
import {
  localScopePhrase,
  nativeFamilyPageContext,
  type NativeFamilyPreviewState,
} from '../../lib/nativeFamilyPageContext'
import { familyVisualSlots, getFamilyVisualSourceDoc } from '../../lib/localSeoFamilyVisuals'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string
  preview?: NativeFamilyPreviewState
  visualDoc?: PayloadDoc | null
}

const defaultLegacyFile = 'motorrad-fotografie.html'
const { doc: providedDoc = undefined, legacyFile: providedLegacyFile, preview, visualDoc: providedVisualDoc = undefined } = Astro.props as Props
const legacyFile = providedLegacyFile || defaultLegacyFile
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))
const visualDoc = providedVisualDoc ?? (await getFamilyVisualSourceDoc('motorrad', doc, legacyFile, defaultLegacyFile))
const pageContext = nativeFamilyPageContext({
  defaultLegacyFile,
  doc,
  family: 'motorrad',
  legacyFile,
  preview,
})
const { clusterHeading, clusterLinks, isKeywordPage, isParentPage, overviewHref, publishedHref, scope, serviceLabel } = pageContext
const heroSecondLine = isParentPage || isKeywordPage ? 'Fotografie.' : `Fotografie ${scope.label}`
const heroLabel = isParentPage || isKeywordPage ? 'Motorradfotografie' : `Motorradfotografie ${scope.label}`
const heroLead = isParentPage
  ? 'Motorradfotografie: Silhouette, Mechanik, Haltung, Detail und Fahrerbezug werden als kraftvolle Serie geplant — für Custom Bikes, Händler, Werkstätten und private Maschinen. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.'
  : isKeywordPage
    ? `${serviceLabel}: eigenständiger Einstieg in den Motorrad Fotografie-Cluster. Silhouette, Mechanik, Haltung, Detail und Fahrerbezug werden als kraftvolle Serie geplant - für Custom Bikes, Händler, Werkstätten und private Maschinen. Die Seite bleibt bewusst im Layout der übergeordneten Kategorie, setzt den Text aber auf diese konkrete Suchintention.`
    : `Motorradfotografie in ${scope.label}: Silhouette, Mechanik, Haltung, Detail und Fahrerbezug werden als kraftvolle Serie geplant - für Custom Bikes, Händler, Werkstätten und private Maschinen. ${localScopePhrase(scope)}`
const metaTitle = isParentPage
  ? 'Motorradfotografie - Matthias Ramahi'
  : isKeywordPage
    ? `${serviceLabel} | Matthias Ramahi`
    : `${serviceLabel} ${scope.label} | Matthias Ramahi`
const metaDescription = isParentPage
  ? 'Motorradfotografie: Bildserien für Custom Bikes, Werkstätten, Händler und private Maschinen - Silhouette, Mechanik, Haltung und Detail.'
  : isKeywordPage
    ? `${serviceLabel}: Bildserien für Custom Bikes, Werkstätten, Händler und private Maschinen.`
    : `${serviceLabel} ${scope.label}: Bildserien für Custom Bikes, Werkstätten, Händler und private Maschinen.`
const contactSubject = isParentPage ? 'Motorrad Fotografie Anfrage' : `${serviceLabel}${isKeywordPage ? '' : ` ${scope.label}`} Anfrage`
const contactHeadline = isParentPage
  ? 'Motorrad &lt;em&gt;anfragen.&lt;/em&gt;'
  : isKeywordPage
    ? `${serviceLabel} &lt;em&gt;anfragen.&lt;/em&gt;`
    : `Motorrad ${scope.label} &lt;em&gt;anfragen.&lt;/em&gt;`
const contactLead = isParentPage
  ? 'Schreibe kurz, welches Bike fotografiert werden soll — Modell, Standort, ob Fahrerbilder gewünscht sind und wofür die Bilder genutzt werden. Wir klären Licht, Location und Ablauf gemeinsam.'
  : isKeywordPage
    ? `Schreibe kurz, wofür ${serviceLabel} gebraucht wird, welches Motiv im Mittelpunkt steht und welche Nutzung geplant ist. Wir klären Stil, Ort, Umfang und Ausgabe gemeinsam.`
    : `Schreibe kurz, welches Bike in ${scope.label} fotografiert werden soll - Modell, Standort, ob Fahrerbilder gewünscht sind und wofür die Bilder genutzt werden. Wir klären Licht, Location und Ablauf gemeinsam.`

const visualSlots = familyVisualSlots(visualDoc, [
  { alt: 'Motorrad Stand und Silhouette', full: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp', mobile: 'assets/optimized/assets-photos-motorrad-ninja-road-720.webp', src: 'assets/optimized/assets-photos-motorrad-ninja-road-960.webp', width: 960, height: 1440 },
  { alt: 'Motorrad mit Fahrer', full: 'assets/optimized/assets-photos-motorrad-duke-1920.webp', mobile: 'assets/optimized/assets-photos-motorrad-duke-720.webp', src: 'assets/optimized/assets-photos-motorrad-duke-960.webp', width: 960, height: 1706 },
  { alt: 'Motorrad Strasse', full: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp', mobile: 'assets/optimized/assets-photos-motorrad-ninja-road-720.webp', src: 'assets/optimized/assets-photos-motorrad-ninja-road-960.webp', width: 960, height: 1440 },
  { alt: 'Motorrad Stand & Silhouette', full: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp', src: 'assets/optimized/assets-photos-motorrad-ninja-road-720.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Detail', full: 'assets/optimized/assets-portfolio-dsc3892-1920.webp', src: 'assets/portfolio/thumbs/_DSC3892.webp', width: 720, height: 480 },
  { alt: 'Motorrad mit Fahrer', full: 'assets/optimized/assets-photos-motorrad-duke-1920.webp', src: 'assets/optimized/assets-photos-motorrad-duke-720.webp', width: 720, height: 1280 },
  { alt: 'Motorrad Schraeglage und Kurve', full: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp', src: 'assets/optimized/assets-photos-motorrad-ninja-road-720.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Cinematic', full: 'assets/optimized/assets-portfolio-dsc2986-1920.webp', src: 'assets/portfolio/thumbs/_DSC2986.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Social & Vertical', full: 'assets/portfolio/_DSC9301-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9301-Enhanced-NR.webp', width: 720, height: 900 },
  { alt: 'Motorrad Hero-Motiv', full: 'assets/optimized/assets-photos-motorrad-1920.webp', src: 'assets/optimized/assets-photos-motorrad-720.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Detail', full: 'assets/optimized/assets-portfolio-dsc3892-1920.webp', src: 'assets/portfolio/thumbs/_DSC3892.webp', width: 720, height: 480 },
  { alt: 'Motorrad in Werkstatt', full: 'assets/optimized/assets-portfolio-dsc2986-1920.webp', src: 'assets/portfolio/thumbs/_DSC2986.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Vertical', full: 'assets/portfolio/_DSC9301-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9301-Enhanced-NR.webp', width: 720, height: 900 },
  { alt: 'Motorrad Profil', full: 'assets/portfolio/_DSC9321-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9321-Enhanced-NR.webp', width: 720, height: 1080 },
  { alt: 'Motorrad Cinematic', full: 'assets/optimized/assets-portfolio-dsc3878-1920.webp', src: 'assets/portfolio/thumbs/_DSC3878.webp', width: 720, height: 480 },
])

const cityLinks = [
  ['motorrad-fotografie.html', 'Düsseldorf'],
  ['motorrad-fotografie-koeln.html', 'Köln'],
  ['motorrad-fotografie-essen.html', 'Essen'],
  ['motorrad-fotografie-dortmund.html', 'Dortmund'],
  ['motorrad-fotografie-duisburg.html', 'Duisburg'],
  ['motorrad-fotografie-bochum.html', 'Bochum'],
  ['motorrad-fotografie-wuppertal.html', 'Wuppertal'],
  ['motorrad-fotografie-leverkusen.html', 'Leverkusen'],
  ['motorrad-fotografie-oberhausen.html', 'Oberhausen'],
  ['motorrad-fotografie-krefeld.html', 'Krefeld'],
  ['motorrad-fotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['motorrad-fotografie-moers.html', 'Moers'],
  ['motorrad-fotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['motorrad-fotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['motorrad-fotografie-solingen.html', 'Solingen'],
  ['motorrad-fotografie-remscheid.html', 'Remscheid'],
  ['motorrad-fotografie-mettmann.html', 'Mettmann'],
  ['motorrad-fotografie-hilden.html', 'Hilden'],
  ['motorrad-fotografie-dormagen.html', 'Dormagen'],
  ['motorrad-fotografie-neuss.html', 'Neuss'],
  ['motorrad-fotografie-nrw.html', 'NRW'],
  ['motorrad-fotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['motorrad-shooting-duesseldorf.html', 'Motorrad Shooting'],
  ['bike-fotografie.html', 'Bike Fotografie'],
  ['custom-bike-fotografie.html', 'Custom Bike Fotografie'],
  ['motorrad-verkaufsfotos-duesseldorf.html', 'Motorrad Verkaufsfotos'],
  ['biker-portrait-duesseldorf.html', 'Biker Portrait'],
] as const
---
<AdoptedPageLayout
  legacyFile={legacyFile}
  current="fotografie"
  doc={doc}
  noIndex={Boolean(preview)}
  title={metaTitle}
  description={metaDescription}
  ogImage={visualSlots[0].full}
>
  {preview && (
    <PreviewToolbar
      collection={preview.collection}
      slug={preview.slug}
      status={preview.status}
      publishedHref={publishedHref}
    />
  )}
  <main>
    <section class="hero-mr" id="top" data-header-theme="dark" aria-label={heroLabel}>
      <div class="hero-mr__stage" aria-hidden="true">
        <div class="hero-mr__slides">
          <div class="hero-mr__slide is-active" data-slide="0" style="--pos:50% 52%">
            <div class="hero-mr__zoom">
              <img class="hero-mr__image" src={visualSlots[0].src} srcset={visualSlots[0].srcset} sizes="100vw" alt="" fetchpriority="high" decoding="async" width={visualSlots[0].width} height={visualSlots[0].height} />
            </div>
          </div>
          <div class="hero-mr__slide" data-slide="1" style="--pos:50% 48%">
            <div class="hero-mr__zoom">
              <img class="hero-mr__image" src={visualSlots[1].src} srcset={visualSlots[1].srcset} sizes="100vw" alt="" decoding="async" loading="lazy" width={visualSlots[1].width} height={visualSlots[1].height} />
            </div>
          </div>
          <div class="hero-mr__slide" data-slide="2" style="--pos:50% 50%">
            <div class="hero-mr__zoom">
              <img class="hero-mr__image" src={visualSlots[2].src} srcset={visualSlots[2].srcset} sizes="100vw" alt="" decoding="async" loading="lazy" width={visualSlots[2].width} height={visualSlots[2].height} />
            </div>
          </div>
        </div>
        <span class="hero-mr__edge" id="heroMrEdge"></span>
        <span class="hero-mr__vignette"></span>
      </div>

      <div class="hero-mr__grid">
        <h1 class="hero-mr__title" id="heroMrTitle">
          <span class="line"><span class="word">Motorrad</span></span>
          <span class="line"><span class="word">{heroSecondLine}</span></span>
        </h1>
        <div class="hero-mr__lede-block">
          <p class="hero-mr__lede">{doc?.intro || heroLead}</p>
          <div class="hero-mr__actions">
            <a href="#anfrage">Shooting buchen →</a>
            <a class="ghost" href="portfolio.html">Portfolio</a>
          </div>
        </div>
      </div>

      <aside class="hero-mr__rail" aria-label="Bildauswahl">
        <nav class="hero-mr__rail-dots" id="heroMrDots" aria-label="Bildauswahl">
          <button type="button" data-slide="0" aria-current="true" aria-label="Bild 1"><span></span></button>
          <button type="button" data-slide="1" aria-label="Bild 2"><span></span></button>
          <button type="button" data-slide="2" aria-label="Bild 3"><span></span></button>
        </nav>
      </aside>
    </section>

    <section class="st" data-header-theme="light">
      <div class="section-inner">
        <div>
          <h2>Geschwindigkeit und Leidenschaft <em>auf Bildern.</em></h2>
        </div>
        <div class="st-body">
          <p>Ein Motorrad muss <strong>auch im Stand Spannung tragen</strong>. Ich arbeite mit gesetzten Winkeln, kontrolliertem Licht und einer ruhigen Bildsprache — Mechanik, Material und Haltung wirken sofort, ohne Effektpose.</p>
          <p>Einsatz: <strong>Social, Website, Verkauf, Werkstatt, Kampagne</strong>. Sie erhalten Dateien für Web und Druck — bereit für Reels, Story, Magazin und Print, im einheitlichen Bild-Look.</p>
          <a class="st-cta" href="#anfrage">Shooting anfragen →</a>
        </div>
      </div>
    </section>

    <section class="mk" data-header-theme="dark">
      <div class="section-inner">
        <div class="mk-head">
          <h2>Vom Detail <em>bis zur Kurve.</em></h2>
          <p>Sechs Bildtypen, die ich anbiete — vom ruhigen Standschuss bis zum Pan-Shot in der Schräglage. Jede Serie wird aus diesen Modulen zusammengestellt, je nach Bike, Anlass und Verwendung.</p>
        </div>
        <div class="mk-grid">
          <article class="mk-card">
            <figure class="mk-img"><img src={visualSlots[3].src} data-src={visualSlots[3].src} loading="lazy" alt={visualSlots[3].alt} width={visualSlots[3].width} height={visualSlots[3].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">01 · Stand & Silhouette</span>
              <h3>Die ruhige Bildbühne</h3>
              <p>Bike pur — Proportionen, Linienführung, Haltung. Gesetztes Licht, klare Winkel. Bereit für Header, Print und Werkstatt-Wand.</p>
            </div>
          </article>
          <article class="mk-card">
            <figure class="mk-img"><img loading="lazy" src={visualSlots[4].src} alt={visualSlots[4].alt} width={visualSlots[4].width} height={visualSlots[4].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">02 · Detail</span>
              <h3>Tank, Motor, Felge, Lenker</h3>
              <p>Nahaufnahmen, die Material, Verarbeitung und Charakter ehrlich zeigen — für Custom-Doku, Händlerseiten und redaktionelle Strecken.</p>
            </div>
          </article>
          <article class="mk-card">
            <figure class="mk-img"><img src={visualSlots[5].src} data-src={visualSlots[5].src} loading="lazy" alt={visualSlots[5].alt} width={visualSlots[5].width} height={visualSlots[5].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">03 · Mit Fahrer</span>
              <h3>Mensch + Maschine, Haltung</h3>
              <p>Fahrer und Bike zusammen — Haltung, Helm, Hände am Lenker. Porträt-Logik trifft Maschine, gerne vor Ort oder am Werkstatttor.</p>
            </div>
          </article>
          <article class="mk-card">
            <figure class="mk-img"><img src={visualSlots[6].src} data-src={visualSlots[6].src} loading="lazy" alt={visualSlots[6].alt} width={visualSlots[6].width} height={visualSlots[6].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">04 · Schräglage & Kurve</span>
              <h3>On-the-go, Pan-Shots</h3>
              <p>Mitziehaufnahmen aus der Kurve, sauber gezogene Pan-Shots — Geschwindigkeit als Bild, nicht als Behauptung. Strecke nach Absprache.</p>
            </div>
          </article>
          <article class="mk-card">
            <figure class="mk-img"><img loading="lazy" src={visualSlots[7].src} alt={visualSlots[7].alt} width={visualSlots[7].width} height={visualSlots[7].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">05 · Cinematic</span>
              <h3>Atmosphäre, Licht, Editorial</h3>
              <p>Bildserien mit Stimmung — Gegenlicht, Dämmerung, Werkhalle, Asphalt nach Regen. Editorial-Look für Magazin und Marken-Kampagne.</p>
            </div>
          </article>
          <article class="mk-card">
            <figure class="mk-img"><img loading="lazy" src={visualSlots[8].src} alt={visualSlots[8].alt} width={visualSlots[8].width} height={visualSlots[8].height} decoding="async" /></figure>
            <div class="mk-text">
              <span class="no">06 · Social & Vertical</span>
              <h3>Reels, Story, 9:16-Cuts</h3>
              <p>Hochformat wird von Anfang an mitgeplant — eine Aufnahme, zwei Formate. Reels-, Story- und 9:16-Cuts direkt aus dem Set.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="po" data-header-theme="dark" aria-label="Ausgewählte Motorrad-Arbeiten">
      <div class="po-grid" id="poGrid">
        <header class="po-head">
          <h2>Aktuelle <em>Arbeiten.</em></h2>
          <p>Sechs kuratierte Motorrad-Bilder aus jüngeren Serien. Klicken zum Vergrössern.</p>
        </header>
        <button type="button" class="po-tile t1" data-i="0" data-full={visualSlots[9].full} aria-label="Bild 1 vergrößern">
          <img loading="lazy" src={visualSlots[9].src} data-full={visualSlots[9].full} alt={visualSlots[9].alt} width={visualSlots[9].width} height={visualSlots[9].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
        <button type="button" class="po-tile t2" data-i="1" data-full={visualSlots[10].full} aria-label="Bild 2 vergrößern">
          <img src={visualSlots[10].src} data-full={visualSlots[10].full} loading="lazy" alt={visualSlots[10].alt} width={visualSlots[10].width} height={visualSlots[10].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
        <button type="button" class="po-tile t3" data-i="2" data-full={visualSlots[11].full} aria-label="Bild 3 vergrößern">
          <img src={visualSlots[11].src} data-full={visualSlots[11].full} loading="lazy" alt={visualSlots[11].alt} width={visualSlots[11].width} height={visualSlots[11].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
        <button type="button" class="po-tile t4" data-i="3" data-full={visualSlots[12].full} aria-label="Bild 4 vergrößern">
          <img src={visualSlots[12].src} data-full={visualSlots[12].full} loading="lazy" alt={visualSlots[12].alt} width={visualSlots[12].width} height={visualSlots[12].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
        <button type="button" class="po-tile t5" data-i="4" data-full={visualSlots[13].full} aria-label="Bild 5 vergrößern">
          <img loading="lazy" src={visualSlots[13].src} data-full={visualSlots[13].full} alt={visualSlots[13].alt} width={visualSlots[13].width} height={visualSlots[13].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
        <button type="button" class="po-tile t6" data-i="5" data-full={visualSlots[14].full} aria-label="Bild 6 vergrößern">
          <img loading="lazy" src={visualSlots[14].src} data-full={visualSlots[14].full} alt={visualSlots[14].alt} width={visualSlots[14].width} height={visualSlots[14].height} decoding="async" />
          <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        </button>
      </div>
    </section>

    <section class="fw" data-header-theme="light">
      <div class="section-inner">
        <div class="fw-head">
          <h2>Für <em>wen</em> ich arbeite.</h2>
          <p class="lead">Vom ersten eigenen Bike bis zur Kampagne — jede Serie wird auf Maschine, Marke und Nutzung zugeschnitten.</p>
        </div>
        <div class="fw-grid">
          <article class="fw-card"><span class="no">01</span><strong>Motorradfahrer mit eigener Maschine</strong></article>
          <article class="fw-card"><span class="no">02</span><strong>Custom Builder &amp; Manufakturen</strong></article>
          <article class="fw-card"><span class="no">03</span><strong>Werkstätten &amp; Händler</strong></article>
          <article class="fw-card"><span class="no">04</span><strong>Marken, Magazin &amp; Kampagne</strong></article>
        </div>
        <div class="fw-foot">
          <p>Du erkennst dein Setting wieder? <em>Lass uns sprechen.</em></p>
          <a href="#anfrage">Projekt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="rl" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Motorrad steht selten allein. Schau dir die anderen Disziplinen an — gleicher Anspruch, anderer Bildfokus. Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        </div>
        <div class="rl-grid">
          <a class="rl-card" href="automobil-fotografie.html">
            <img loading="lazy" src="assets/optimized/assets-photos-automobil-neon-960.webp" alt="Automobilfotografie" width="960" height="640" decoding="async" />
            <div class="overlay"></div>
            <div class="content"><div><span>01 / Verwandt</span><strong>Automobil</strong></div><span class="arrow">→</span></div>
          </a>
          <a class="rl-card" href="sportwagen-fotografie.html">
            <img loading="lazy" src="assets/portfolio/thumbs/_DSC3032_genErase (1).webp" alt="Sportwagenfotografie" width="720" height="480" decoding="async" />
            <div class="overlay"></div>
            <div class="content"><div><span>02 / Verwandt</span><strong>Sportwagen</strong></div><span class="arrow">→</span></div>
          </a>
          <a class="rl-card" href="videografie-duesseldorf.html">
            <img loading="lazy" src="assets/portfolio/thumbs/_DSC8032.webp" alt="Videografie" width="720" height="900" decoding="async" />
            <div class="overlay"></div>
            <div class="content"><div><span>03 / Service</span><strong>Videografie</strong></div><span class="arrow">→</span></div>
          </a>
          <a class="rl-card" href="portfolio.html">
            <img loading="lazy" src="assets/portfolio/thumbs/_DSC3879.webp" alt="Vollständiges Portfolio" width="720" height="480" decoding="async" />
            <div class="overlay"></div>
            <div class="content"><div><span>04 / Übersicht</span><strong>Portfolio</strong></div><span class="arrow">→</span></div>
          </a>
        </div>
      </div>
    </section>

    {!isParentPage && (
      <NativeFamilyClusterLinks
        clusterHeading={clusterHeading}
        clusterLinks={clusterLinks}
        overviewHref={overviewHref}
        scopeLabel={scope.label}
      />
    )}

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Motorrad Fotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Motorrad Fotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Motorrad Fotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Motorrad Fotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject={contactSubject}
      data-contact-headline={contactHeadline}
      data-contact-lead={contactLead}
    ></section>
  </main>
</AdoptedPageLayout>
