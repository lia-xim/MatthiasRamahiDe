---
import NativeLegacyLayout from '../../layouts/NativeLegacyLayout.astro'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

const legacyFile = 'motorrad-fotografie.html'
const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))

const heroSlides = [
  {
    image: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp',
    alt: 'Motorrad Fotografie Düsseldorf - Kawasaki auf Landstrasse',
    width: 1920,
    height: 2880,
  },
  {
    image: 'assets/optimized/assets-photos-motorrad-duke-1920.webp',
    alt: 'Motorrad Fotografie Düsseldorf - KTM Duke',
    width: 1920,
    height: 3413,
  },
  {
    image: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp',
    alt: 'Motorrad Fotografie Düsseldorf - Ninja Road',
    width: 1920,
    height: 2880,
  },
]

const modules = [
  {
    className: 'c1',
    image: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp',
    alt: 'Motorrad Stand & Silhouette',
    width: 1920,
    height: 2880,
    number: '01 · Stand & Silhouette',
    title: 'Die ruhige Bildbühne',
    text: 'Klare Silhouette, kontrollierte Umgebung, präzise Linien. Das Bike wird als Objekt gelesen — stark für Website, Verkauf, Social und Druck.',
  },
  {
    className: 'c2',
    image: 'assets/optimized/assets-portfolio-dsc3892-1920.webp',
    alt: 'Motorrad Detail',
    width: 1920,
    height: 1280,
    number: '02 · Detail',
    title: 'Tank, Motor, Felge, Lenker',
    text: 'Material, Textur und Mechanik bekommen eigene Motive. So entsteht eine Serie, die nicht nur ein Motorrad zeigt, sondern seine Sprache.',
  },
  {
    className: 'c3',
    image: 'assets/optimized/assets-photos-motorrad-duke-1920.webp',
    alt: 'Motorrad mit Fahrer',
    width: 1920,
    height: 3413,
    number: '03 · Mit Fahrer',
    title: 'Mensch + Maschine, Haltung',
    text: 'Portraits und Fahraufnahmen verbinden den Fahrer mit dem Bike. Für Personal Brand, Werkstatt, Händler und Magazine.',
  },
  {
    className: 'c4',
    image: 'assets/optimized/assets-photos-motorrad-ninja-road-1920.webp',
    alt: 'Motorrad Schräglage und Kurve',
    width: 1920,
    height: 2880,
    number: '04 · Schräglage & Kurve',
    title: 'On-the-go, Pan-Shots',
    text: 'Bewegung wird planbar: Route, Lichtfenster, Sicherheitsabstand und Wiederholbarkeit. Dynamisch, aber kontrolliert.',
  },
  {
    className: 'c5',
    image: 'assets/optimized/assets-portfolio-dsc2986-1920.webp',
    alt: 'Motorrad Cinematic',
    width: 1707,
    height: 2560,
    number: '05 · Cinematic',
    title: 'Atmosphäre, Licht, Editorial',
    text: 'Stimmige Bildstrecken für Kampagnen, Lookbooks oder Magazin-Storys. Licht und Umgebung tragen die Maschine.',
  },
  {
    className: 'c6',
    image: 'assets/portfolio/_DSC9301-Enhanced-NR.webp',
    alt: 'Motorrad Social & Vertical',
    width: 2048,
    height: 2560,
    number: '06 · Social & Vertical',
    title: 'Reels, Story, 9:16-Cuts',
    text: 'Motive werden direkt für Kanäle gedacht: Querformat, Hochformat, Teaser, Detail und Hero. Ohne späteren Qualitätsverlust.',
  },
]

const portfolioTiles = [
  ['t1', 'assets/optimized/assets-photos-motorrad-1920.webp', 'Motorrad Hero-Motiv', 1707, 2560],
  ['t2', 'assets/optimized/assets-portfolio-dsc3892-1920.webp', 'Motorrad Detail', 1920, 1280],
  ['t3', 'assets/optimized/assets-portfolio-dsc2986-1920.webp', 'Motorrad in Werkstatt', 1707, 2560],
  ['t4', 'assets/portfolio/_DSC9301-Enhanced-NR.webp', 'Motorrad Vertical', 2048, 2560],
  ['t5', 'assets/portfolio/_DSC9321-Enhanced-NR.webp', 'Motorrad Profil', 1707, 2560],
  ['t6', 'assets/optimized/assets-portfolio-dsc3878-1920.webp', 'Motorrad Cinematic', 1920, 1280],
] as const

const audiences = [
  ['01', 'Motorradfahrer', 'Eigenes Bike · Erinnerung'],
  ['02', 'Custom Builder', 'Umbau · Werkstatt · Manufaktur'],
  ['03', 'Händler', 'Verkauf · Website · Portale'],
  ['04', 'Marke & Magazin', 'Kampagne · Editorial · Social'],
] as const

const relatedAreas = [
  {
    href: 'automobil-fotografie.html',
    image: 'assets/optimized/assets-photos-automobil-neon-1920.webp',
    alt: 'Automobilfotografie',
    width: 1920,
    height: 1280,
    meta: '01 / Verwandt',
    title: 'Automobil',
  },
  {
    href: 'sportwagen-fotografie.html',
    image: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp',
    alt: 'Sportwagenfotografie',
    width: 1920,
    height: 1280,
    meta: '02 / Verwandt',
    title: 'Sportwagen',
  },
  {
    href: 'videografie-duesseldorf.html',
    image: 'assets/optimized/assets-portfolio-dsc2986-1920.webp',
    alt: 'Videografie Düsseldorf',
    width: 1707,
    height: 2560,
    meta: '03 / Bewegtbild',
    title: 'Videografie',
  },
  {
    href: 'portfolio.html',
    image: 'assets/optimized/assets-photos-motorrad-1920.webp',
    alt: 'Vollständiges Portfolio',
    width: 1707,
    height: 2560,
    meta: '04 / Übersicht',
    title: 'Portfolio',
  },
]

const cityLinks = [
  ['motorrad-fotografie.html', 'Düsseldorf'],
  ['motorrad-fotografie-koeln.html', 'Köln'],
  ['motorrad-fotografie-essen.html', 'Essen'],
  ['motorrad-fotografie-dortmund.html', 'Dortmund'],
  ['motorrad-fotografie-duisburg.html', 'Duisburg'],
  ['motorrad-fotografie-bochum.html', 'Bochum'],
  ['motorrad-fotografie-wuppertal.html', 'Wuppertal'],
  ['motorrad-fotografie-leverkusen.html', 'Leverkusen'],
  ['motorrad-fotografie-oberhausen.html', 'Oberhausen'],
  ['motorrad-fotografie-krefeld.html', 'Krefeld'],
  ['motorrad-fotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['motorrad-fotografie-moers.html', 'Moers'],
  ['motorrad-fotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['motorrad-fotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['motorrad-fotografie-solingen.html', 'Solingen'],
  ['motorrad-fotografie-remscheid.html', 'Remscheid'],
  ['motorrad-fotografie-mettmann.html', 'Mettmann'],
  ['motorrad-fotografie-hilden.html', 'Hilden'],
  ['motorrad-fotografie-dormagen.html', 'Dormagen'],
  ['motorrad-fotografie-neuss.html', 'Neuss'],
  ['motorrad-fotografie-nrw.html', 'NRW'],
  ['motorrad-fotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['motorrad-shooting-duesseldorf.html', 'Motorrad Shooting'],
  ['bike-fotografie.html', 'Bike Fotografie'],
  ['custom-bike-fotografie.html', 'Custom Bike Fotografie'],
  ['motorrad-verkaufsfotos-duesseldorf.html', 'Motorrad Verkaufsfotos'],
  ['biker-portrait-duesseldorf.html', 'Biker Portrait'],
] as const
---
<NativeLegacyLayout legacyFile={legacyFile} current="fotografie" doc={doc}>
  <main>
    <section class="hero-mr" id="top" data-header-theme="dark" aria-label="Motorradfotografie">
      <div class="hero-mr__slides" aria-hidden="true">
        {heroSlides.map((slide, index) => (
          <div class={`hero-mr__slide${index === 0 ? ' is-active' : ''}`} data-slide={index}>
            <img
              class="hero-mr__image"
              src={slide.image}
              alt={slide.alt}
              width={slide.width}
              height={slide.height}
              decoding="async"
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </div>
        ))}
      </div>
      <div class="hero-mr__edge" id="heroMrEdge" aria-hidden="true"></div>
      <div class="hero-mr__shade" aria-hidden="true"></div>

      <div class="hero-mr__copy">
        <p class="eyebrow">Motorradfotografie Düsseldorf</p>
        <h1 id="heroMrTitle"><span>Motorrad</span><em>Fotografie.</em></h1>
        <p class="hero-mr__lead">Motorradfotografie: Silhouette, Mechanik, Haltung, Detail und Fahrerbezug werden als kraftvolle Serie geplant — für Custom Bikes, Händler, Werkstätten und private Maschinen. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.</p>
        <div class="hero-mr__actions">
          <a href="#anfrage">Shooting buchen →</a>
          <a class="ghost" href="portfolio.html">Portfolio</a>
        </div>
      </div>

      <div class="hero-mr__dots" id="heroMrDots" aria-label="Hero Bilder wählen">
        {heroSlides.map((_, index) => (
          <button type="button" data-slide={index} aria-current={index === 0 ? 'true' : 'false'}>{String(index + 1).padStart(2, '0')}</button>
        ))}
      </div>
    </section>

    <section class="st" data-header-theme="light">
      <div class="section-inner">
        <div>
          <h2>Geschwindigkeit und Leidenschaft <em>auf Bildern.</em></h2>
        </div>
        <div class="st-body">
          <p>Motorräder leben von <strong>Linie, Haltung und Energie</strong>. Ich fotografiere Bikes nicht beliebig vor der nächsten Wand, sondern entwickle eine Serie aus Hero, Detail, Bewegung und Portrait.</p>
          <p>Der Look bleibt hochwertig und klar: genug Kraft, aber ohne visuelle Überladung. Für private Erinnerungen, Händler, Custom Builder, Social-Kampagnen und Print.</p>
          <a class="st-cta" href="#anfrage">Shooting anfragen →</a>
        </div>
      </div>
    </section>

    <section class="mk" data-header-theme="dark">
      <div class="section-inner">
        <div class="mk-head">
          <h2>Was eine Motorradserie <em>braucht.</em></h2>
          <p>Ein starkes Bike braucht nicht ein einzelnes Bild, sondern eine Dramaturgie. Diese Bausteine plane ich pro Produktion mit.</p>
        </div>

        <div class="mk-grid">
          {modules.map((item) => (
            <article class={`mk-card ${item.className}`}>
              <img data-src={item.image} src={item.image} loading="lazy" alt={item.alt} width={item.width} height={item.height} decoding="async" />
              <div class="mk-card__copy">
                <span>{item.number}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="po" data-header-theme="dark" aria-label="Ausgewählte Motorrad-Arbeiten">
      <div class="po-grid" id="poGrid">
        <header class="po-head">
          <h2>Aktuelle <em>Arbeiten.</em></h2>
          <p>Sechs kuratierte Motorrad-Bilder aus jüngeren Serien. Klicken zum Vergrössern.</p>
        </header>
        {portfolioTiles.map(([className, image, alt, width, height], index) => (
          <button type="button" class={`po-tile ${className}`} data-i={index} aria-label={`Bild ${index + 1} vergrößern`}>
            <img data-src={image} src={image} loading="lazy" alt={alt} width={width} height={height} decoding="async" />
            <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
          </button>
        ))}
      </div>
    </section>

    <section class="fw" data-header-theme="light">
      <div class="section-inner">
        <div class="fw-head">
          <h2>Für <em>wen</em> ich arbeite.</h2>
          <p class="lead">Vom ersten eigenen Bike bis zur Kampagne — jede Serie wird auf Maschine, Marke und Nutzung zugeschnitten.</p>
        </div>
        <div class="fw-grid">
          {audiences.map(([number, title, label]) => (
            <article class="fw-card"><span class="no">{number}</span><strong>{title}</strong><span class="lbl">{label}</span></article>
          ))}
        </div>
        <div class="fw-foot">
          <p>Du erkennst dein Setting wieder? <em>Lass uns sprechen.</em></p>
          <a href="#anfrage">Projekt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="rl" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Motorrad gehört zur grösseren Automotive-Welt, braucht aber eine eigene Haltung. Schau dir verwandte Disziplinen an — gleicher Anspruch, anderer Rhythmus. Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        </div>
        <div class="rl-grid">
          {relatedAreas.map((area) => (
            <a class="rl-card" href={area.href}>
              <img data-src={area.image} src={area.image} loading="lazy" alt={area.alt} width={area.width} height={area.height} decoding="async" />
              <div class="overlay"></div>
              <div class="content"><div><span>{area.meta}</span><strong>{area.title}</strong></div><span class="arrow">→</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Motorrad Fotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Motorrad Fotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Motorrad Fotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Motorrad Fotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject="Motorrad Fotografie Anfrage"
      data-contact-headline="Motorrad &lt;em&gt;anfragen.&lt;/em&gt;"
      data-contact-lead="Schreibe kurz, welches Bike fotografiert werden soll — Modell, Standort, ob Fahrerbilder gewünscht sind und wofür die Bilder genutzt werden. Wir klären Licht, Location und Ablauf gemeinsam."
    />
  </main>
</NativeLegacyLayout>
