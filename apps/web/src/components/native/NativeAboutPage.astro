---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

const legacyFile = 'ueber-mich.html'
const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))

const chapters = [
  {
    href: 'automobil-fotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-automobil-sunset-960.webp',
    alt: 'Automobilfotografie',
    width: 960,
    height: 640,
    title: 'Automobil',
    number: 'N° 01',
    meta: 'Location · Location · Detail',
  },
  {
    href: 'sportwagen-fotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-automobil-neon-960.webp',
    alt: 'Sportwagenfotografie',
    width: 960,
    height: 640,
    title: 'Sportwagen',
    number: 'N° 02',
    meta: 'Performance · Editorial',
  },
  {
    href: 'oldtimer-fotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-oldtimer-stage-960.webp',
    alt: 'Oldtimerfotografie',
    width: 960,
    height: 640,
    title: 'Oldtimer',
    number: 'N° 03',
    meta: 'Sammlung · Auktion',
  },
  {
    href: 'motorrad-fotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-motorrad-720.webp',
    alt: 'Motorradfotografie',
    width: 720,
    height: 1080,
    title: 'Motorrad',
    number: 'N° 04',
    meta: 'Maschine · Haltung',
  },
  {
    href: 'portraitfotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-portrait-blue-720.webp',
    alt: 'Portraitfotografie',
    width: 720,
    height: 900,
    title: 'Portrait',
    number: 'N° 05',
    meta: 'Branding · Editorial',
  },
  {
    href: 'landschaftsfotografie-duesseldorf.html',
    image: 'assets/optimized/assets-photos-landschaft-720.webp',
    alt: 'Landschaftsfotografie',
    width: 720,
    height: 1080,
    title: 'Landschaft',
    number: 'N° 06',
    meta: 'Fine Art · Print',
  },
]
---
<AdoptedPageLayout legacyFile={legacyFile} current="ueber-mich" doc={doc}>
  <main>
    <section class="ovh ovh--ueber" data-theme="dark" data-header-theme="dark" aria-label="Matthias Ramahi — Fotograf aus Düsseldorf">
      <img class="ovh__photo" src="mpissxxj-portfolio_webp_full_063-1.webp" alt="" width="1920" height="1280" fetchpriority="high" decoding="async" aria-hidden="true" />
      <div class="ovh__glow" aria-hidden="true"></div>
      <div class="ovh__aperture" aria-hidden="true"></div>
      <div class="ovh__grid">
        <div class="ovh__beam" aria-hidden="true"></div>
        <p class="ovh__kicker">Über mich · Düsseldorf · NRW</p>
        <h1 class="ovh__title">
          <span class="line"><span class="word">Hinter der</span></span>
          <span class="line"><span class="word">Kamera.</span></span>
        </h1>
        <p class="ovh__lead">Matthias Ramahi — Fotograf aus Düsseldorf. Editorial geführte Bildserien für Automobile, Oldtimer, Sportwagen, Motorräder, Portraits und Landschaften. Ausgebildet im Handwerk, denkend wie ein Editor.</p>
        <div class="ovh__actions">
          <a class="ovh__btn" href="portfolio.html">Portfolio ansehen →</a>
          <a class="ovh__btn ovh__btn--ghost" href="#anfrage">Projekt anfragen</a>
        </div>
      </div>
    </section>

    <section class="statement sec-light" data-theme="light" data-header-theme="light" aria-label="Haltung">
      <div class="section-inner">
        <div>
          <h2>Bild vor Filter,<br />Motiv vor <em>Effekt</em>.</h2>
        </div>
        <div class="body">
          <p class="lead">Was mich an Fotografie hält, ist nicht das eine spektakuläre Bild — es ist die ruhige Arbeit davor: das genaue Hinsehen, das Warten auf das richtige Licht, die kleine Verschiebung in der Komposition, die ein Motiv plötzlich tragen lässt.</p>
          <p>Mein Anspruch ist editorial: klare Linien, ehrliche Farben, keine Effektkette. Ob Portrait, Automobil oder Landschaft — am Ende geht es darum, dass das Bild den Charakter seines Motivs zeigt und nicht den meiner Software. Aus dieser Geduld entstehen Aufnahmen, die nach dem Shooting noch arbeiten — auf dem Inserat, im Pressekit, an der Wand.</p>
          <div class="actions">
            <a class="btn dark" href="portfolio.html">Portfolio ansehen</a>
            <a class="btn" href="#schwerpunkte" style="color:var(--ink);border-color:var(--ink)">Bereiche ansehen</a>
          </div>
        </div>
      </div>
    </section>

    <section class="chapters sec-dark" id="schwerpunkte" data-theme="dark" data-header-theme="dark" aria-label="Schwerpunkte">
      <div class="section-inner">
        <div class="chapters-head">
          <h2>Sechs Bereiche.<br />Eine <em>Hand</em>.</h2>
          <p class="lead">Ich arbeite nicht in Genre-Schubladen — aber jede Disziplin braucht ihr eigenes Vorgehen. Licht, Distanz, Material und Rhythmus passen sich an, die Bildsprache bleibt verwandt.</p>
        </div>
        <div class="chapter-grid">
          {chapters.map((chapter) => (
            <a class="chapter" href={chapter.href}>
              <div class="img"><img src={chapter.image} alt={chapter.alt} loading="lazy" width={chapter.width} height={chapter.height} decoding="async" /></div>
              <div class="head"><h3>{chapter.title}</h3><span class="num">{chapter.number}</span></div>
              <span class="meta"><span>{chapter.meta}</span><span class="arr">→</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="sister sec-light" data-theme="light" data-header-theme="light" aria-label="Sophia Ramahi — Videografin">
      <div class="section-inner sister-grid">
        <div class="sister-copy">
          <p class="kicker dark">Bewegte Bilder · Empfehlung</p>
          <h2>Wenn es <em>bewegt</em> sein soll.</h2>
          <p class="lead">Für bewegte Bilder empfehle ich meine Schwester Sophia Ramahi — Videografin aus dem Rheinland.</p>
          <p>Sophia produziert Musikvideos, Imagefilme und redaktionelles Bewegtbild. Aus einer Familie, aus einer Bildsprache — wir arbeiten regelmäßig parallel auf Set, damit Foto und Video aus einem Guss kommen.</p>
          <div class="actions">
            <a class="btn dark" href="contact.html#anfrage">Anfrage Foto + Video →</a>
          </div>
        </div>
        <aside class="sister-plate" aria-label="Visitentafel Sophia Ramahi">
          <p class="sister-plate__tag">Schwester · Location</p>
          <p class="sister-plate__name">Sophia<br /><em>Ramahi</em>.</p>
          <ul class="sister-plate__roles">
            <li>Videografin</li>
            <li>Musikvideos</li>
            <li>Imagefilm</li>
            <li>Editorial · Set</li>
          </ul>
          <p class="sister-plate__loc">Düsseldorf · NRW</p>
        </aside>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-theme="light"
      data-header-theme="light"
      data-contact-subject="Projektanfrage"
      data-contact-headline="Projekt <em>anfragen.</em>"
      data-contact-lead="Schreiben Sie kurz, welche Leistung Sie interessiert, wo das Projekt stattfindet und welchen Zeitraum Sie planen. Ich melde mich mit Rückfragen oder einem nächsten Schritt per E-Mail."
    />
  </main>

  <!-- Hero entrance: add .is-in so the OVH title/lead/actions animate in.
       site-chrome.js does not handle .ovh, so this mirrors the legacy inline
       script. Without it the copy stays at opacity:0 and the column reads blank. -->
  <script is:inline>
    (function () {
      var h = document.querySelector('.ovh')
      if (!h) return
      var t = h.querySelector('.ovh__title')
      function start() { h.classList.add('is-in'); if (t) t.classList.add('is-in') }
      if (matchMedia('(prefers-reduced-motion:reduce)').matches) { start(); return }
      requestAnimationFrame(function () { requestAnimationFrame(start) })
    })()
  </script>
</AdoptedPageLayout>
