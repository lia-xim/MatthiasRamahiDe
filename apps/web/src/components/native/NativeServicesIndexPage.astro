---
import NativeLegacyLayout from '../../layouts/NativeLegacyLayout.astro'
import { servicesIndexItems } from '../../lib/nativeContent'
import { getSitePageByType, type PayloadDoc } from '../../lib/payload'

const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getSitePageByType('services-index', { depth: 2 }))
---
<NativeLegacyLayout legacyFile="leistungen.html" current="leistungen" doc={doc}>
  <main>
    <section class="ld-hero" id="top" data-header-theme="dark" aria-label="Weitere Dienstleistungen">
      <div class="ld-hero__bg" aria-hidden="true">
        <img src="/assets/services/portfolio_webp_full_057-1.webp" alt="" loading="eager" decoding="async" fetchpriority="high" width="1280" height="1920" />
      </div>
      <div class="ld-hero__copy">
        <p class="kicker">Partnernetzwerk · Düsseldorf · NRW</p>
        <h1>Alles aus <em>einer Hand.</em></h1>
        <p class="ld-hero__lead">{doc?.intro || 'Für Projekte, die über die Fotografie hinausgehen: hochwertige Drucke, Großformat, Werbetechnik, Webdesign, Video und musikalische Begleitung — seriös koordiniert, visuell abgestimmt und über erfahrene Partner in Düsseldorf und NRW umgesetzt.'}</p>
        <div class="ld-hero__actions">
          <a class="ld-btn is-primary" href="#anfrage">Projekt anfragen</a>
          <a class="ld-btn" href="#overview">Leistungen ansehen</a>
        </div>
        <p class="ld-hero__lead" style="font-size:13px;max-width:560px;margin-top:14px">Unverbindliche Erstklaerung / Antwort meist innerhalb von 24 Stunden / ein Ansprechpartner fuer Ablauf und Partner.</p>
      </div>
    </section>

    <section class="overview" id="overview" data-header-theme="light" aria-label="Unsere Dienstleistungen im Überblick">
      <div class="overview-inner">
        <div class="overview-head">
          <h2>Dienstleistungen <em>im Überblick.</em></h2>
          <p>Vom einzelnen Fine-Art-Print bis zur kompletten Markenfläche, Website, Filmproduktion oder Eventbegleitung. Sechs ergänzende Bereiche, ein gemeinsamer visueller Anspruch.</p>
        </div>
        <div class="overview-grid">
          {servicesIndexItems.slice(0, 6).map((service) => (
            <a class="overview-tile" href={service.href}>
              <img src={service.images[0].src} alt={service.images[0].alt} loading="lazy" width={service.images[0].width} height={service.images[0].height} decoding="async" />
              <div class="label"><strong set:html={service.headline.replace(/\.$/, '')}></strong><span>{service.number.split('·')[1]?.trim() || 'Leistung'}</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="services" data-header-theme="light" aria-label="Leistungsdetails">
      <div class="services-list">
        {servicesIndexItems.map((service) => (
          <a class="service" id={service.id} href={service.href} data-header-theme={service.theme}>
            <div class="service-copy">
              <span class="service-num">{service.number}</span>
              <h3 set:html={service.headline}></h3>
              <p>{service.text}</p>
              <div class="tags">{service.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
              <span class="service-go">Mehr Infos</span>
            </div>
            <div class="image-set">
              {service.images.map((image) => (
                <figure class={`image-card ${image.className || ''}`.trim()}>
                  <img src={image.src} alt={image.alt} loading="lazy" width={image.width} height={image.height} decoding="async" />
                  <figcaption class="image-caption">{image.caption}</figcaption>
                </figure>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="why" data-header-theme="dark" aria-label="Warum alles aus einer Hand Sinn ergibt">
      <div class="why-inner">
        <div class="why-copy"><p class="kicker">Projektablauf</p><h2>Ein Bildsystem, <em>mehrere Ausgänge.</em></h2><p class="why-lead">Der Vorteil liegt nicht in möglichst vielen Leistungen, sondern in einem sauber geführten Prozess: Bildsprache, Material, digitale Präsenz und Präsentation wirken am Ende wie ein zusammenhängender Auftritt.</p></div>
        <div class="why-board">
          <article class="why-card"><span>Koordination</span><strong>Ein Ansprechpartner, <em>weniger Reibung.</em></strong><p>Abstimmung, Reihenfolge und Partner werden gebündelt, damit das Projekt nicht zwischen Gewerken zerfällt.</p></article>
          <article class="why-card"><span>Qualität</span><strong>Ein visueller Anspruch <em>über alle Medien.</em></strong><p>Druck, Website, Video oder Event-Auftritt werden nicht einzeln gedacht, sondern auf dieselbe Bildsprache ausgerichtet.</p></article>
          <article class="why-card"><span>Netzwerk</span><strong>Spezialisierte Partner <em>aus Düsseldorf &amp; NRW.</em></strong><p>Kurze Wege, klare Kommunikation und erfahrene Partner für Produktion, Präsentation und digitale Umsetzung.</p></article>
          <article class="why-card"><span>Lösung</span><strong>Keine <em>Standardpakete.</em></strong><p>Format, Material, Umfang und Timing richten sich nach dem Projekt — nicht nach einer festen Schablone.</p></article>
        </div>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-theme="light"
      data-contact-subject="Anfrage weitere Dienstleistungen"
      data-contact-headline="Projekt <em>anfragen.</em>"
      data-contact-lead="Beschreibe kurz, welche Leistung du brauchst — Druck, Webdesign, Video, Werbetechnik, Musik oder eine Kombination. Ich sortiere den Ablauf und die passenden Partner."
    />
  </main>
</NativeLegacyLayout>
