---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import NativeFamilyClusterLinks from './NativeFamilyClusterLinks.astro'
import PreviewToolbar from '../PreviewToolbar.astro'
import {
  localScopePhrase,
  nativeFamilyPageContext,
  type NativeFamilyPreviewState,
} from '../../lib/nativeFamilyPageContext'
import { familyVisualSlots, getFamilyVisualSourceDoc } from '../../lib/localSeoFamilyVisuals'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string
  preview?: NativeFamilyPreviewState
  visualDoc?: PayloadDoc | null
}

const defaultLegacyFile = 'landschaftsfotografie.html'
const props = Astro.props as Props
const { doc: providedDoc = undefined, legacyFile: providedLegacyFile, preview, visualDoc: providedVisualDoc = undefined } = props
const legacyFile = providedLegacyFile || defaultLegacyFile
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))
const shouldUseCmsVisualDoc = import.meta.env.ASTRO_DISABLE_CMS_VISUAL_OVERRIDES !== 'true'
const visualDoc = Object.hasOwn(props, 'visualDoc')
  ? providedVisualDoc
  : shouldUseCmsVisualDoc
    ? await getFamilyVisualSourceDoc('landschaft', doc, legacyFile, defaultLegacyFile)
    : null
const pageContext = nativeFamilyPageContext({
  defaultLegacyFile,
  doc,
  family: 'landschaft',
  legacyFile,
  preview,
})
const { clusterHeading, clusterLinks, isKeywordPage, isParentPage, overviewHref, publishedHref, scope, serviceLabel } = pageContext
const heroLabel = isParentPage || isKeywordPage ? 'Landschaftsfotografie' : `Landschaftsfotografie ${scope.label}`
const heroSecondLine = isParentPage ? 'Fotografie.' : `Fotografie ${isKeywordPage ? 'Düsseldorf' : scope.label}.`
const heroLead = isParentPage
  ? 'Landschaftsfotografie: Licht, Weite, Material und Raumwirkung werden kuratiert — als Fine-Art-Print, Wandbild, Edition oder großformatige Arbeit für Räume mit Ruhe. Bundesweit zählt vor allem die passende Motivwahl, Druckqualität, Materialität und Wirkung im Raum.'
  : isKeywordPage
    ? `${serviceLabel} in ${scope.label}: Landschaftsfotografie für ${scope.label}: Bildräume aus Geduld, Licht und Atmosphäre - als Fine-Art-Print, Wandbild, Edition oder Großformat für Räume, die Ruhe statt Spektakel brauchen. Düsseldorf wird als lokaler Suchraum mit klarer Planung, Lichtfenster und passender Nutzung der Bildserie verstanden.`
    : `Landschaftsfotografie für ${scope.label}: Licht, Weite, Material und Raumwirkung werden kuratiert - als Fine-Art-Print, Wandbild, Edition oder großformatige Arbeit für Räume mit Ruhe. ${localScopePhrase(scope)}`
const metaTitle = isParentPage
  ? 'Landschaftsfotografie - Matthias Ramahi'
  : isKeywordPage
    ? `${serviceLabel} | Matthias Ramahi`
    : `${serviceLabel} ${scope.label} | Matthias Ramahi`
const metaDescription = isParentPage
  ? 'Landschaftsfotografie: Fine-Art-Prints, Wandbilder, Editionen und großformatige Arbeiten für private Räume, Praxen, Hotels und Sammlungen.'
  : isKeywordPage
    ? `${serviceLabel}: Fine-Art-Prints, Wandbilder, Editionen und großformatige Arbeiten.`
    : `${serviceLabel} ${scope.label}: Fine-Art-Prints, Wandbilder, Editionen und großformatige Arbeiten.`
const contactSubject = isParentPage ? 'Landschaftsfotografie Anfrage' : `${serviceLabel}${isKeywordPage ? ' Düsseldorf' : ` ${scope.label}`} Anfrage`
const contactHeadline = isParentPage
  ? 'Landschaft <em>anfragen.</em>'
  : isKeywordPage
    ? `${serviceLabel} Düsseldorf <em>anfragen.</em>`
    : `Landschaft ${scope.label} <em>anfragen.</em>`
const contactLead = isParentPage
  ? 'Schreibe kurz, wofür die Landschaftsbilder eingesetzt werden — Fine-Art-Print, Innenraum, Editorial, Website oder Markenbild. Wichtig sind gewünschte Atmosphäre, Format, Material und Zeitraum.'
  : isKeywordPage
    ? `Schreibe kurz, wofür ${serviceLabel} gebraucht wird, welches Motiv oder welcher Raum im Mittelpunkt steht und welche Nutzung geplant ist. Wir klären Ort, Licht, Umfang und Ausgabe gemeinsam.`
    : `Schreibe kurz, wofür die Landschaftsbilder in ${scope.label} eingesetzt werden - Fine-Art-Print, Innenraum, Editorial, Website oder Markenbild. Wichtig sind gewünschte Atmosphäre, Format, Material und Zeitraum.`

const visualSlots = familyVisualSlots(visualDoc, [
  { alt: 'Landschaft Wasser', full: 'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto5_Wunder_der_Natur2.webp', width: 1920, height: 1280 },
  { alt: 'Landschaft Wald', full: 'assets/optimized/assets-portfolio-20250605-dsc04020-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC04020.webp', width: 1707, height: 2560 },
  { alt: 'Landschaft Licht', full: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto10_Wunder_der_natur.webp', width: 1920, height: 1194 },
  { alt: 'Landschaft Detail', full: 'assets/optimized/assets-portfolio-dsc8032-1920.webp', src: 'assets/portfolio/thumbs/_DSC8032.webp', width: 1920, height: 2400 },
  { alt: 'Landschaft Print', full: 'assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03978.webp', width: 1707, height: 2560 },
  { alt: 'Fine-Art Landschaft', full: 'assets/optimized/assets-portfolio-wettberwerb-foto6-wunder-der-natur-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto6_Wunder_der_Natur.webp', width: 720, height: 520 },
  { alt: 'Aluminium Landschaft', full: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto10_Wunder_der_natur.webp', width: 720, height: 448 },
  { alt: 'Acrylglas Landschaft', full: 'assets/optimized/assets-portfolio-20250414-dsc00341-1920.webp', src: 'assets/portfolio/thumbs/20250414-DSC00341.webp', width: 720, height: 1080 },
  { alt: 'Landschaft Edition', full: 'assets/optimized/assets-portfolio-20250327-dsc01550-1920.webp', src: 'assets/portfolio/thumbs/20250327-DSC01550.webp', width: 720, height: 1090 },
  { alt: 'Landschaft Hauptmotiv', full: 'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto5_Wunder_der_Natur2.webp', width: 720, height: 471 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-wettberwerb-foto6-wunder-der-natur-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto6_Wunder_der_Natur.webp', width: 720, height: 520 },
  { alt: 'Landschaft Atmosphaere', full: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto10_Wunder_der_natur.webp', width: 720, height: 448 },
  { alt: 'Landschaft Cinema', full: 'assets/optimized/assets-portfolio-20250605-dsc04020-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC04020.webp', width: 720, height: 1080 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03978.webp', width: 720, height: 960 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-20250605-dsc03816-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03816.webp', width: 720, height: 960 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-20250605-dsc03793-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03793.webp', width: 720, height: 960 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-20250605-dsc03756-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03756.webp', width: 720, height: 1080 },
  { alt: 'Landschaft Detail', full: 'assets/optimized/assets-portfolio-20250414-dsc00341-1920.webp', src: 'assets/portfolio/thumbs/20250414-DSC00341.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/photos/portrait-blue.webp', src: 'assets/photos/portrait-blue.webp', width: 2048, height: 2560 },
  { alt: 'Oldtimer', full: 'assets/optimized/assets-photos-oldtimer-stage-1920.webp', src: 'assets/optimized/assets-photos-oldtimer-stage-1920.webp', width: 1920, height: 1280 },
  { alt: 'Drucke', full: 'assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp', src: 'assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp', width: 1707, height: 2560 },
  { alt: 'Portfolio', full: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', src: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', width: 1920, height: 1194 },
])
const heroImages = visualSlots.slice(0, 5).map((slot) => slot.full).join(',')

const cityLinks = [
  ['landschaftsfotografie.html', 'Düsseldorf'],
  ['landschaftsfotografie-koeln.html', 'Köln'],
  ['landschaftsfotografie-essen.html', 'Essen'],
  ['landschaftsfotografie-dortmund.html', 'Dortmund'],
  ['landschaftsfotografie-duisburg.html', 'Duisburg'],
  ['landschaftsfotografie-bochum.html', 'Bochum'],
  ['landschaftsfotografie-wuppertal.html', 'Wuppertal'],
  ['landschaftsfotografie-leverkusen.html', 'Leverkusen'],
  ['landschaftsfotografie-oberhausen.html', 'Oberhausen'],
  ['landschaftsfotografie-krefeld.html', 'Krefeld'],
  ['landschaftsfotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['landschaftsfotografie-moers.html', 'Moers'],
  ['landschaftsfotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['landschaftsfotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['landschaftsfotografie-solingen.html', 'Solingen'],
  ['landschaftsfotografie-remscheid.html', 'Remscheid'],
  ['landschaftsfotografie-mettmann.html', 'Mettmann'],
  ['landschaftsfotografie-hilden.html', 'Hilden'],
  ['landschaftsfotografie-dormagen.html', 'Dormagen'],
  ['landschaftsfotografie-neuss.html', 'Neuss'],
  ['landschaftsfotografie-nrw.html', 'NRW'],
  ['landschaftsfotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['landschaftsbilder-kaufen.html', 'Landschaftsbilder kaufen'],
  ['fine-art-prints-landschaft.html', 'Fine Art Prints Landschaft'],
  ['wandbilder-landschaftsfotografie.html', 'Wandbilder Landschaftsfotografie'],
  ['naturfotografie-prints.html', 'Naturfotografie Prints'],
  ['landschaftsfotografie-print-deutschland.html', 'Landschaftsfotografie Print Deutschland'],
] as const
---
<AdoptedPageLayout
  legacyFile={legacyFile}
  current="fotografie"
  doc={doc}
  noIndex={Boolean(preview)}
  title={metaTitle}
  description={metaDescription}
  ogImage={visualSlots[0].full}
  preloadImages={[visualSlots[0].full]}
>
  {preview && (
    <PreviewToolbar
      collection={preview.collection}
      slug={preview.slug}
      status={preview.status}
      publishedHref={publishedHref}
    />
  )}
  <main>
    <section
      class="hero-ls"
      data-header-theme="dark"
      aria-label={heroLabel}
      data-images={heroImages}
    >
      <div class="hero-ls__paper" aria-hidden="true"></div>

      <svg class="hero-ls__stage" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <filter id="liquidEdge" x="-20%" y="-20%" width="140%" height="140%" filterUnits="objectBoundingBox" primitiveUnits="userSpaceOnUse">
            <feTurbulence type="fractalNoise" baseFrequency="0.0055 0.0042" numOctaves="3" seed="11" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="180" xChannelSelector="R" yChannelSelector="G" result="displaced" />
            <feGaussianBlur in="displaced" stdDeviation="6" />
          </filter>
          <mask id="maskA" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1080">
            <rect width="1920" height="1080" fill="black" />
            <g id="blobsA" filter="url(#liquidEdge)"></g>
          </mask>
          <mask id="maskB" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1080">
            <rect width="1920" height="1080" fill="black" />
            <g id="blobsB" filter="url(#liquidEdge)"></g>
          </mask>
        </defs>

        <image id="lsImgBottom" width="1920" height="1080" x="0" y="0" preserveAspectRatio="xMidYMid slice" mask="url(#maskA)" href="" />
        <image id="lsImgTop" width="1920" height="1080" x="0" y="0" preserveAspectRatio="xMidYMid slice" mask="url(#maskB)" href="" />
      </svg>

      <svg class="hero-ls__ripple" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <circle id="lsRipple" cx="960" cy="540" r="0"></circle>
      </svg>

      <div class="hero-ls__grain" aria-hidden="true"></div>
      <div class="hero-ls__chrome-wash" aria-hidden="true"></div>
      <div class="hero-ls__bottom-wash" aria-hidden="true"></div>
      <div class="hero-ls__text-scrim" aria-hidden="true"></div>

      <div class="hero-ls__inner">
        <h1 class="hero-ls__title">
          <span class="l"><span class="w">Landschaft</span></span>
          <span class="l"><span class="w">{heroSecondLine}</span></span>
        </h1>
        <p class="hero-ls__sub">{doc?.intro || heroLead}</p>
        <div class="hero-ls__actions">
          <a class="btn primary" href="#anfrage">Landschafts-Serie anfragen →</a>
          <a class="btn" href="portfolio.html">Portfolio</a>
        </div>
      </div>

      <div class="hero-ls__counter" id="lsCounter" aria-hidden="true"></div>
    </section>

    <section class="st-ls" data-header-theme="light">
      <div class="st-ls__inner">
        <h2 class="st-ls__title">Bilder, die einen <em>Raum verändern.</em></h2>
        <div class="st-ls__body">
          <p>Landschaft entsteht aus Geduld — aus der Entscheidung, was im Bild bleiben darf und was nicht. Aus Wetter, das man nicht herstellen kann, und aus dem richtigen Moment, in dem alles zusammenkommt.</p>
          <p>Jede Aufnahme ist als großformatiger Print gedacht — für Wand, Wohnraum, Praxis, Hotel oder Sammlung. Alle Motive werden farbecht auf Fine-Art-Papier, Aluminium-Dibond oder hinter Acrylglas gefertigt und gedruckt.</p>
          <a class="st-ls__cta" href="#anfrage">Projekt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="mod-ls" data-header-theme="dark">
      <div class="mod-ls__head">
        <h2 class="mod-ls__title">Vier Ausführungen.</h2>
        <p class="mod-ls__lead">Jedes Motiv ist als Print erhältlich.</p>
      </div>
      <div class="mod-ls__grid">
        <article class="mod-ls__card">
          <div class="mod-ls__img" style={`background-image:url('${visualSlots[5].cssFull}')`}></div>
          <div class="mod-ls__body">
            <span class="mod-ls__num">01</span>
            <h3 class="mod-ls__name">Fine-Art</h3>
          </div>
        </article>
        <article class="mod-ls__card">
          <div class="mod-ls__img" style={`background-image:url('${visualSlots[6].cssFull}')`}></div>
          <div class="mod-ls__body">
            <span class="mod-ls__num">02</span>
            <h3 class="mod-ls__name">Aluminium</h3>
          </div>
        </article>
        <article class="mod-ls__card">
          <div class="mod-ls__img" style={`background-image:url('${visualSlots[7].cssFull}')`}></div>
          <div class="mod-ls__body">
            <span class="mod-ls__num">03</span>
            <h3 class="mod-ls__name">Acryl­glas</h3>
          </div>
        </article>
        <article class="mod-ls__card">
          <div class="mod-ls__img" style={`background-image:url('${visualSlots[8].cssFull}')`}></div>
          <div class="mod-ls__body">
            <span class="mod-ls__num">04</span>
            <h3 class="mod-ls__name">Edition</h3>
          </div>
        </article>
      </div>
    </section>

    <section class="bg-ls" data-header-theme="dark" aria-label="Ausgewählte Landschaftsarbeiten">
      <div class="bg-ls__head">
        <h2 class="bg-ls__title">Ausgewählte <em>Landschaften.</em></h2>
        <a class="bg-ls__link" href="portfolio.html">Zum Portfolio →</a>
      </div>
      <div class="bg-ls__grid">
        <button class="bg-ls__tile t-hero" data-full={visualSlots[9].full}><img loading="lazy" src={visualSlots[9].src} alt={visualSlots[9].alt} width={visualSlots[9].width} height={visualSlots[9].height} decoding="async" /></button>
        <button class="bg-ls__tile t-a" data-full={visualSlots[10].full}><img loading="lazy" src={visualSlots[10].src} alt={visualSlots[10].alt} width={visualSlots[10].width} height={visualSlots[10].height} decoding="async" /></button>
        <button class="bg-ls__tile t-b" data-full={visualSlots[11].full}><img loading="lazy" src={visualSlots[11].src} alt={visualSlots[11].alt} width={visualSlots[11].width} height={visualSlots[11].height} decoding="async" /></button>
        <button class="bg-ls__tile t-c" data-full={visualSlots[12].full}><img loading="lazy" src={visualSlots[12].src} alt={visualSlots[12].alt} width={visualSlots[12].width} height={visualSlots[12].height} decoding="async" /></button>
        <button class="bg-ls__tile t-d" data-full={visualSlots[13].full}><img loading="lazy" src={visualSlots[13].src} alt={visualSlots[13].alt} width={visualSlots[13].width} height={visualSlots[13].height} decoding="async" /></button>
        <button class="bg-ls__tile t-e" data-full={visualSlots[14].full}><img loading="lazy" src={visualSlots[14].src} alt={visualSlots[14].alt} width={visualSlots[14].width} height={visualSlots[14].height} decoding="async" /></button>
        <button class="bg-ls__tile t-f" data-full={visualSlots[15].full}><img loading="lazy" src={visualSlots[15].src} alt={visualSlots[15].alt} width={visualSlots[15].width} height={visualSlots[15].height} decoding="async" /></button>
        <button class="bg-ls__tile t-g" data-full={visualSlots[16].full}><img loading="lazy" src={visualSlots[16].src} alt={visualSlots[16].alt} width={visualSlots[16].width} height={visualSlots[16].height} decoding="async" /></button>
        <button class="bg-ls__tile t-h" data-full={visualSlots[17].full}><img loading="lazy" src={visualSlots[17].src} alt={visualSlots[17].alt} width={visualSlots[17].width} height={visualSlots[17].height} decoding="async" /></button>
      </div>
    </section>

    <section class="fw-ls" data-header-theme="light">
      <div class="fw-ls__inner">
        <div class="fw-ls__head">
          <h2 class="fw-ls__title">So entsteht <em>Ihr Druck.</em></h2>
          <p class="fw-ls__lead">Jedes Bild aus dem Portfolio, in jedem Format, mit oder ohne Rahmen — auf Anfrage gefertigt und zu Ihnen geliefert.</p>
        </div>

        <div class="fw-ls__flow">
          <div class="fw-ls__step">
            <span class="fw-ls__step-num">01</span>
            <h3>Anfrage</h3>
          </div>
          <div class="fw-ls__step">
            <span class="fw-ls__step-num">02</span>
            <h3>Beratung</h3>
          </div>
          <div class="fw-ls__step">
            <span class="fw-ls__step-num">03</span>
            <h3>Produktion</h3>
          </div>
          <div class="fw-ls__step">
            <span class="fw-ls__step-num">04</span>
            <h3>Lieferung</h3>
          </div>
        </div>

        <div class="fw-ls__cta">
          <a href="contact.html">Projekt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="rl-ls" data-header-theme="dark" aria-label="Landschaftsfotografie">
      <div class="rl-ls__inner">
        <h2 class="rl-ls__title">Verwandte <em>Bereiche.</em></h2>
        <p class="rl-ls__intro">Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        <div class="rl-ls__grid">
          <a class="rl-ls__card" href="portraitfotografie.html"><div class="rl-ls__card-img" style={`background-image:url('${visualSlots[18].cssSrc}')`}></div><div class="rl-ls__card-body"><strong>Portrait</strong><span>→</span></div></a>
          <a class="rl-ls__card" href="oldtimer-fotografie.html"><div class="rl-ls__card-img" style={`background-image:url('${visualSlots[19].cssSrc}')`}></div><div class="rl-ls__card-body"><strong>Oldtimer</strong><span>→</span></div></a>
          <a class="rl-ls__card" href="drucke-sonderanfertigungen-duesseldorf.html"><div class="rl-ls__card-img" style={`background-image:url('${visualSlots[20].cssSrc}')`}></div><div class="rl-ls__card-body"><strong>Drucke</strong><span>→</span></div></a>
          <a class="rl-ls__card" href="portfolio.html"><div class="rl-ls__card-img" style={`background-image:url('${visualSlots[21].cssSrc}')`}></div><div class="rl-ls__card-body"><strong>Portfolio</strong><span>→</span></div></a>
        </div>
      </div>
    </section>

    {!isParentPage && (
      <NativeFamilyClusterLinks
        clusterHeading={clusterHeading}
        clusterLinks={clusterLinks}
        overviewHref={overviewHref}
        scopeLabel={scope.label}
      />
    )}

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Landschaftsfotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2 class="mr-cities__title">Landschaftsfotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Landschaftsfotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Landschaftsfotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject={contactSubject}
      data-contact-headline={contactHeadline}
      data-contact-lead={contactLead}
    ></section>
  </main>
</AdoptedPageLayout>
