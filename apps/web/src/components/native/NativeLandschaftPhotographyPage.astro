---
import NativeLegacyLayout from '../../layouts/NativeLegacyLayout.astro'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

const legacyFile = 'landschaftsfotografie.html'
const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))

const heroImages = [
  'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp',
  'assets/optimized/assets-portfolio-20250605-dsc04020-1920.webp',
  'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp',
  'assets/optimized/assets-portfolio-dsc8032-1920.webp',
  'assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp',
]

const modules = [
  {
    image: 'assets/optimized/assets-portfolio-wettberwerb-foto6-wunder-der-natur-1920.webp',
    label: '01 · Fine-Art',
    title: 'Licht & Weite',
    text: 'Ruhige Landschaftsmotive mit natürlicher Tiefe — für Räume, in denen ein Bild nicht schreien muss.',
  },
  {
    image: 'assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp',
    label: '02 · Aluminium',
    title: 'Material & Präsenz',
    text: 'Drucke auf Alu-Dibond, Acrylglas oder Fine-Art-Papier werden auf Raum, Grösse und Wirkung abgestimmt.',
  },
  {
    image: 'assets/optimized/assets-portfolio-20250414-dsc00341-1920.webp',
    label: '03 · Acrylglas',
    title: 'Tiefe & Glanz',
    text: 'Für Motive mit Lichtkante, Reflexion und klarer Farbe. Besonders stark, wenn das Bild im Raum als Objekt wirken soll.',
  },
  {
    image: 'assets/optimized/assets-portfolio-20250327-dsc01550-1920.webp',
    label: '04 · Edition',
    title: 'Serien & Auswahl',
    text: 'Motiv, Format, Material und Hängung werden gemeinsam entschieden — von Einzelbild bis kleiner Serie.',
  },
]

const galleryTiles = [
  ['assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', 'assets/portfolio/thumbs/Wettberwerb_Foto5_Wunder_der_Natur2.webp', 'Landschaft Hauptmotiv', 720, 471],
  ['assets/optimized/assets-portfolio-wettberwerb-foto6-wunder-der-natur-1920.webp', 'assets/portfolio/thumbs/Wettberwerb_Foto6_Wunder_der_Natur.webp', 'Landschaft Wasser und Stein', 720, 520],
  ['assets/optimized/assets-portfolio-wettberwerb-foto10-wunder-der-natur-1920.webp', 'assets/portfolio/thumbs/Wettberwerb_Foto10_Wunder_der_natur.webp', 'Landschaft Lichtkante', 720, 448],
  ['assets/optimized/assets-portfolio-20250605-dsc04020-1920.webp', 'assets/portfolio/thumbs/20250605-DSC04020.webp', 'Landschaft Hochformat', 720, 1080],
  ['assets/optimized/assets-portfolio-20250605-dsc03978-1920.webp', 'assets/portfolio/thumbs/20250605-DSC03978.webp', 'Landschaft Detail', 720, 960],
  ['assets/optimized/assets-portfolio-20250605-dsc03816-1920.webp', 'assets/portfolio/thumbs/20250605-DSC03816.webp', 'Landschaft Stimmung', 720, 960],
  ['assets/optimized/assets-portfolio-20250605-dsc03793-1920.webp', 'assets/portfolio/thumbs/20250605-DSC03793.webp', 'Landschaft Serie', 720, 960],
  ['assets/optimized/assets-portfolio-20250605-dsc03756-1920.webp', 'assets/portfolio/thumbs/20250605-DSC03756.webp', 'Landschaft Printmotiv', 720, 1080],
  ['assets/optimized/assets-portfolio-20250414-dsc00341-1920.webp', 'assets/portfolio/thumbs/20250414-DSC00341.webp', 'Landschaft Fels und Licht', 720, 1080],
] as const

const processSteps = [
  ['01', 'Anfrage', 'Sie schicken Raum, gewünschte Wirkung, Grössenidee und erste Motivauswahl. Wenn noch nichts feststeht, starten wir mit der Bildwirkung.'],
  ['02', 'Beratung', 'Wir klären Material, Format, Oberfläche, Budget und ob ein Einzelbild oder eine kleine Serie besser passt.'],
  ['03', 'Produktion', 'Druckdaten, Proof, Material und Fertigung werden vorbereitet. Ziel: keine Zufallswirkung, sondern kontrolliertes Ergebnis.'],
  ['04', 'Lieferung', 'Je nach Format wird Versand, Abholung oder Hängung abgestimmt. Die Ausgabe bleibt nachvollziehbar dokumentiert.'],
] as const

const relatedAreas = [
  ['portraitfotografie.html', 'assets/portraits/_DSC0470-Enhanced-NR.webp', 'Portraitfotografie', '01 / Mensch', 'Portrait'],
  ['oldtimer-fotografie.html', 'assets/optimized/assets-photos-oldtimer-stage-1920.webp', 'Oldtimerfotografie', '02 / Objekt', 'Oldtimer'],
  ['drucke-sonderanfertigungen-duesseldorf.html', 'assets/optimized/assets-portfolio-dsc8032-1920.webp', 'Drucke und Sonderanfertigungen', '03 / Ausgabe', 'Drucke'],
  ['portfolio.html', 'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', 'Vollständiges Portfolio', '04 / Übersicht', 'Portfolio'],
] as const

const cityLinks = [
  ['landschaftsfotografie.html', 'Düsseldorf'],
  ['landschaftsfotografie-koeln.html', 'Köln'],
  ['landschaftsfotografie-essen.html', 'Essen'],
  ['landschaftsfotografie-dortmund.html', 'Dortmund'],
  ['landschaftsfotografie-duisburg.html', 'Duisburg'],
  ['landschaftsfotografie-bochum.html', 'Bochum'],
  ['landschaftsfotografie-wuppertal.html', 'Wuppertal'],
  ['landschaftsfotografie-leverkusen.html', 'Leverkusen'],
  ['landschaftsfotografie-oberhausen.html', 'Oberhausen'],
  ['landschaftsfotografie-krefeld.html', 'Krefeld'],
  ['landschaftsfotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['landschaftsfotografie-moers.html', 'Moers'],
  ['landschaftsfotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['landschaftsfotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['landschaftsfotografie-solingen.html', 'Solingen'],
  ['landschaftsfotografie-remscheid.html', 'Remscheid'],
  ['landschaftsfotografie-mettmann.html', 'Mettmann'],
  ['landschaftsfotografie-hilden.html', 'Hilden'],
  ['landschaftsfotografie-dormagen.html', 'Dormagen'],
  ['landschaftsfotografie-neuss.html', 'Neuss'],
  ['landschaftsfotografie-nrw.html', 'NRW'],
  ['landschaftsfotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['landschaftsbilder-kaufen.html', 'Landschaftsbilder kaufen'],
  ['fine-art-prints-landschaft.html', 'Fine Art Prints Landschaft'],
  ['wandbilder-landschaftsfotografie.html', 'Wandbilder Landschaftsfotografie'],
  ['naturfotografie-prints.html', 'Naturfotografie Prints'],
  ['landschaftsfotografie-print-deutschland.html', 'Landschaftsfotografie Print Deutschland'],
] as const
---
<NativeLegacyLayout legacyFile={legacyFile} current="fotografie" doc={doc}>
  <main>
    <section
      class="hero-ls"
      data-header-theme="dark"
      aria-label="Landschaftsfotografie"
      data-images={heroImages.join(',')}
    >
      <div class="hero-ls__paper" aria-hidden="true"></div>

      <svg class="hero-ls__stage" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <filter id="liquidEdge" x="-20%" y="-20%" width="140%" height="140%" filterUnits="objectBoundingBox" primitiveUnits="userSpaceOnUse">
            <feTurbulence type="fractalNoise" baseFrequency="0.0055 0.0042" numOctaves="3" seed="11" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="180" xChannelSelector="R" yChannelSelector="G" result="displaced" />
            <feGaussianBlur in="displaced" stdDeviation="6" />
          </filter>
          <mask id="maskA" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1080">
            <rect width="1920" height="1080" fill="black" />
            <g id="blobsA" filter="url(#liquidEdge)"></g>
          </mask>
          <mask id="maskB" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1080">
            <rect width="1920" height="1080" fill="black" />
            <g id="blobsB" filter="url(#liquidEdge)"></g>
          </mask>
        </defs>

        <image id="lsImgBottom" width="1920" height="1080" x="0" y="0" preserveAspectRatio="xMidYMid slice" mask="url(#maskA)" href="" />
        <image id="lsImgTop" width="1920" height="1080" x="0" y="0" preserveAspectRatio="xMidYMid slice" mask="url(#maskB)" href="" />
      </svg>

      <svg class="hero-ls__ripple" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <circle id="lsRipple" cx="960" cy="540" r="0"></circle>
      </svg>

      <div class="hero-ls__grain" aria-hidden="true"></div>
      <div class="hero-ls__chrome-wash" aria-hidden="true"></div>
      <div class="hero-ls__bottom-wash" aria-hidden="true"></div>
      <div class="hero-ls__text-scrim" aria-hidden="true"></div>

      <div class="hero-ls__inner">
        <h1 class="hero-ls__title">
          <span class="l"><span class="w">Landschaft</span></span>
          <span class="l"><span class="w">Fotografie.</span></span>
        </h1>
        <p class="hero-ls__sub">Landschaftsfotografie: Licht, Weite, Material und Raumwirkung werden kuratiert — als Fine-Art-Print, Wandbild, Edition oder großformatige Arbeit für Räume mit Ruhe. Bundesweit zählt vor allem die passende Motivwahl, Druckqualität, Materialität und Wirkung im Raum.</p>
        <div class="hero-ls__actions">
          <a class="btn primary" href="#anfrage">Landschafts-Serie anfragen →</a>
          <a class="btn" href="portfolio.html">Portfolio</a>
        </div>
      </div>

      <div class="hero-ls__counter" id="lsCounter" aria-hidden="true"></div>
    </section>

    <section class="st-ls" data-header-theme="light">
      <div class="section-inner">
        <h2>Räume brauchen <em>Bilder mit Ruhe.</em></h2>
        <div class="st-ls__body">
          <p>Landschaftsbilder funktionieren erst dann wirklich, wenn Motiv, Material, Grösse und Raum zusammenpassen. Ich denke Motive deshalb nicht nur als Datei, sondern als fertiges Objekt an der Wand.</p>
          <p>Ob Fine-Art-Print, Alu-Dibond, Acrylglas oder Sonderformat: Entscheidend ist eine Bildwirkung, die lange trägt — ruhig, präzise und hochwertig produziert.</p>
        </div>
      </div>
    </section>

    <section class="mod-ls" data-header-theme="dark">
      <div class="section-inner">
        <div class="mod-ls__head">
          <h2>Von Motiv zu <em>Objekt.</em></h2>
          <p>Jedes Landschaftsbild wird über Wirkung, Format und Material geplant. So entsteht aus einem Motiv ein ruhiges, belastbares Raumobjekt.</p>
        </div>
        <div class="mod-ls__grid">
          {modules.map((item) => (
            <article class="mod-ls__card" style={`background-image:url('${item.image}')`}>
              <div>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-ls" data-header-theme="dark" aria-label="Landschaft Galerie">
      <div class="bg-ls__inner">
        <div class="bg-ls__head">
          <h2>Ausgewählte <em>Landschaften.</em></h2>
          <p>Eine kuratierte Auswahl aus Landschafts- und Naturmotiven, gedacht für Druck, Edition und Raumwirkung.</p>
        </div>
        <div class="bg-ls__grid">
          {galleryTiles.map(([full, image, alt, width, height]) => (
            <button class="bg-ls__tile" type="button" data-full={full}>
              <img src={image} loading="lazy" alt={alt} width={width} height={height} decoding="async" />
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="fw-ls" data-header-theme="light">
      <div class="section-inner">
        <div class="fw-ls__head">
          <h2>So entsteht <em>Ihr Druck.</em></h2>
          <p>Von der Motivwahl bis zur Ausgabe bleibt der Prozess nachvollziehbar. Ziel ist ein Bild, das im Raum funktioniert — nicht nur am Bildschirm.</p>
        </div>
        <div class="fw-ls__grid">
          {processSteps.map(([number, title, text]) => (
            <article class="fw-ls__card">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
        <a class="fw-ls__cta" href="contact.html">Projekt anfragen →</a>
      </div>
    </section>

    <section class="rl-ls" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-ls__head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Landschaft hängt oft mit Raum, Objekt und Druck zusammen. Diese Bereiche passen häufig dazu — je nachdem, ob Bildsprache, Ausgabe oder Portfolio im Vordergrund stehen.</p>
        </div>
        <div class="rl-ls__grid">
          {relatedAreas.map(([href, image, alt, meta, title]) => (
            <a class="rl-ls__card" href={href} style={`background-image:url('${image}')`}>
              <span>{meta}</span>
              <strong>{title}</strong>
              <em>{alt}</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Landschaftsfotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Landschaftsfotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Landschaftsfotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Landschaftsfotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject="Landschaftsfotografie Anfrage"
      data-contact-headline="Landschaft &lt;em&gt;anfragen.&lt;/em&gt;"
      data-contact-lead="Schreibe kurz, welches Motiv oder welche Raumwirkung gesucht ist — Fine-Art-Print, Wandbild, Edition oder Sonderformat. Wenn Raum, Format oder Material noch offen sind, klären wir das gemeinsam."
    />
  </main>
</NativeLegacyLayout>
