---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import { blockParagraphs, homeHeroSlidesFor, photographyTopics } from '../../lib/nativeContent'
import { getSitePageByType, liveCmsFetchOptions, type PayloadDoc } from '../../lib/payload'

type Props = {
  doc?: PayloadDoc
  legacyFile?: string
}

const overviewMeta: Record<string, { description: string; heroLines: [string, string]; intro: string; title: string }> = {
  'fotografie.html': {
    description:
      'Fotografie als klare Übersicht: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft - sechs spezialisierte Bereiche mit eigenem Einstieg.',
    heroLines: ['Fotografie-', 'Bereiche.'],
    intro:
      'Sechs Fotografie-Bereiche - Automobil, Sportwagen, Oldtimer und Motorrad, Portrait und Fine-Art-Landschaft. Jede Kategorie mit eigener Bildsprache und eigenem Einstieg.',
    title: 'Fotografie | Übersicht der Bereiche | Matthias Ramahi',
  },
  'fotografie-duesseldorf.html': {
    description:
      'Fotografie Düsseldorf als klare Übersicht: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft - sechs spezialisierte Bereiche mit eigenem Einstieg.',
    heroLines: ['Fotografie', 'Düsseldorf.'],
    intro:
      'Fotografie in Düsseldorf als strukturierter Einstieg: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft führen in sechs spezialisierte Bereiche.',
    title: 'Fotografie Düsseldorf | Übersicht | Matthias Ramahi',
  },
  'fotografie-nrw.html': {
    description:
      'Fotografie NRW als klare Übersicht: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft - sechs spezialisierte Bereiche für Rheinland, Ruhrgebiet und Deutschland.',
    heroLines: ['Fotografie', 'NRW.'],
    intro:
      'Fotografie in NRW als klare Übersicht für Rheinland, Ruhrgebiet und angrenzende Regionen - mit sechs Bereichen und direkten Einstiegen in lokale Seiten.',
    title: 'Fotografie NRW | Übersicht | Matthias Ramahi',
  },
  'fotografie-deutschland.html': {
    description:
      'Fotografie Deutschland als klare Übersicht: Automobil, Sportwagen, Oldtimer, Motorrad, Portrait und Landschaft - sechs spezialisierte Bereiche für hochwertige Bildserien.',
    heroLines: ['Fotografie', 'Deutschland.'],
    intro:
      'Fotografie deutschlandweit gedacht, aber in klaren Bereichen geführt: Fahrzeuge, Menschen und Landschaften bleiben eigenständige Bild- und Suchintentionen.',
    title: 'Fotografie Deutschland | Übersicht | Matthias Ramahi',
  },
}

const { legacyFile = 'fotografie.html' } = Astro.props as Props
const meta = overviewMeta[legacyFile] || overviewMeta['fotografie.html']
const providedDoc = (Astro.props as Props).doc
const doc = providedDoc || (await getSitePageByType('photography-index', liveCmsFetchOptions({ depth: 2 })))
// Hero = identischer Startseiten-Hero (Shader/Slides), aber eigenständig ueber das
// CMS-Feld `heroSlides` der Fotografie-Uebersicht pflegbar — nicht mehr vom Home-Doc.
const heroSlides = homeHeroSlidesFor(doc)
const firstHeroSlide = heroSlides[0]
const heroImages = heroSlides.map((slide) => slide.image)
const heroSlidesJson = JSON.stringify(heroSlides)
const clusterParagraphs = blockParagraphs(doc, 'Ein Einstieg', [
  'Die Übersicht ist der Einstiegspunkt. Von hier aus führen die sechs Bereiche auf eigene Hauptseiten — und von dort weiter in lokale Varianten, NRW- und Deutschland-Hubs sowie die jeweiligen Keyword-Seiten.',
  'Nutzer wählen nicht aus einem generischen Portfolio, sondern steigen direkt in Automobil, Sportwagen, Oldtimer, Motorrad, Portrait oder Landschaft ein. Jede Kategorie zeigt auf ihrer Hauptseite die zugehörigen Städte und Regionen.',
])
---
<AdoptedPageLayout legacyFile={legacyFile} current="fotografie" doc={doc} title={meta.title} description={meta.description} ctaHref="#anfrage" preloadImages={[firstHeroSlide.image]} liveCms>
  <main>
    <section class="hero" data-theme="dark" aria-label="Intro" style={`background-image:url('${firstHeroSlide.image}')`}>
      <canvas id="hero-shader" aria-hidden="true" data-imgs={heroImages.join(',')} data-slides={heroSlidesJson}></canvas>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-aperture" aria-hidden="true"></div>
      <div class="hero-grid">
        <div class="hero-stage">
          <h1 class="hero-title" id="hero-title" data-text-idx="0">
            {firstHeroSlide.titleLines.map((line) => (
              <span class="line"><span class="word">{line}</span></span>
            ))}
          </h1>
          <p class="hero-lead" id="hero-lead">{firstHeroSlide.lead}</p>
          <div class="hero-actions" aria-label="Direkte Aktionen">
            <a class="btn dark" href={firstHeroSlide.primaryHref} data-hero-primary hidden={!firstHeroSlide.primaryHref || !firstHeroSlide.primaryLabel}>{firstHeroSlide.primaryLabel}</a>
            <a class="btn" href={firstHeroSlide.secondaryHref} data-hero-secondary hidden={!firstHeroSlide.secondaryHref || !firstHeroSlide.secondaryLabel}>{firstHeroSlide.secondaryLabel}</a>
          </div>
        </div>
      </div>
      <div class="hero-cursor" id="hero-cursor" aria-hidden="true"><span class="ring"></span></div>
    </section>

    {photographyTopics.map((topic, index) => (
      <section class={`topic ${topic.theme} ${topic.className}`} id={topic.id} data-theme={topic.theme} data-no={`${String(index + 1).padStart(2, '0')} / ${topic.id.toUpperCase()}`}>
        <div class="topic-grid">
          <div class="topic-copy">
            <p class={`kicker ${topic.theme === 'light' ? 'dark' : ''}`}>{topic.kicker}</p>
            <h2><span>{topic.title}</span><em>{topic.emphasis}</em></h2>
            <p>{topic.text}</p>
            <p class="topic-note">{topic.note}</p>
            <a class="topic-link" href={topic.href}>{topic.linkLabel}</a>
          </div>
          <div class="topic-media" aria-hidden="true">
            <figure class="topic-frame" style={`--topic-ar:${topic.width}/${topic.height}`}>
              <img src={topic.image} alt={topic.alt} loading="lazy" width={topic.width} height={topic.height} decoding="async" />
            </figure>
          </div>
        </div>
      </section>
    ))}

    <section class="cluster" data-theme="light" aria-label="Fotografie-Bereiche">
      <div class="section-inner cluster-grid">
        <div><p class="kicker dark">Bereiche</p><h2>Ein Einstieg, <em>sechs Bereiche.</em></h2></div>
        <div class="cluster-copy">
          {clusterParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          <div class="cluster-links">
            {photographyTopics.map((topic) => <a href={topic.href}>{topic.title.replace('.', '')} Fotografie</a>)}
          </div>
        </div>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-theme="light"
      data-contact-subject="Fotografie Anfrage"
      data-contact-headline="Fotografie <em>anfragen.</em>"
      data-contact-lead="Beschreibe kurz, welcher Bereich passt — Automobil, Sportwagen, Oldtimer, Motorrad, Portrait oder Landschaft — und wofür die Bilder genutzt werden sollen. Dann klären wir Stil, Umfang, Ort, Rechte und Ausgabeformat sauber vor der Produktion."
    />
  </main>
</AdoptedPageLayout>
