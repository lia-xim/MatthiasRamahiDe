---
import NativeLegacyLayout from '../../layouts/NativeLegacyLayout.astro'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

const legacyFile = 'portraitfotografie.html'
const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))

