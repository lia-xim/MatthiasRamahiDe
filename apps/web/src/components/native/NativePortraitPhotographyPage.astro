const relatedAreas = [
  ['landschaftsfotografie.html', 'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', 'Landschaftsfotografie', '01 / Ruhig', 'Landschaft'],
  ['automobil-fotografie.html', 'assets/optimized/assets-photos-automobil-neon-1920.webp', 'Automobilfotografie', '02 / Marke', 'Automobil'],
  ['videografie-duesseldorf.html', 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp', 'Videografie Düsseldorf', '03 / Bewegtbild', 'Videografie'],
  ['portfolio.html', 'assets/portraits/_DSC9321-Enhanced-NR.webp', 'Vollständiges Portfolio', '04 / Übersicht', 'Portfolio'],
] as const

const cityLinks = [
  ['portraitfotografie.html', 'Düsseldorf'],
  ['portraitfotografie-koeln.html', 'Köln'],
  ['portraitfotografie-essen.html', 'Essen'],
  ['portraitfotografie-dortmund.html', 'Dortmund'],
  ['portraitfotografie-duisburg.html', 'Duisburg'],
  ['portraitfotografie-bochum.html', 'Bochum'],
  ['portraitfotografie-wuppertal.html', 'Wuppertal'],
  ['portraitfotografie-leverkusen.html', 'Leverkusen'],
  ['portraitfotografie-oberhausen.html', 'Oberhausen'],
  ['portraitfotografie-krefeld.html', 'Krefeld'],
  ['portraitfotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['portraitfotografie-moers.html', 'Moers'],
  ['portraitfotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['portraitfotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['portraitfotografie-solingen.html', 'Solingen'],
  ['portraitfotografie-remscheid.html', 'Remscheid'],
  ['portraitfotografie-mettmann.html', 'Mettmann'],
  ['portraitfotografie-hilden.html', 'Hilden'],
  ['portraitfotografie-dormagen.html', 'Dormagen'],
  ['portraitfotografie-neuss.html', 'Neuss'],
  ['portraitfotografie-nrw.html', 'NRW'],
  ['portraitfotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['business-portrait-duesseldorf.html', 'Business Portrait'],
  ['headshot-fotograf-duesseldorf.html', 'Headshot Fotograf'],
  ['personal-branding-fotografie.html', 'Personal Branding Fotografie'],
  ['unternehmensportrait-duesseldorf.html', 'Unternehmensportrait'],
  ['pressefoto-duesseldorf.html', 'Pressefoto'],
] as const
---
<NativeLegacyLayout legacyFile={legacyFile} current="fotografie" doc={doc}>
  <main>
    <section class="hero-pt" id="heroPt" data-header-theme="dark" aria-label="Portraitfotografie">
      <div class="hero-pt__catch" aria-hidden="true"></div>
      <div class="hero-pt__slides" aria-hidden="true">
        {heroSlides.map(([image, alt, width, height], index) => (
          <div class={`hero-pt__slide${index === 0 ? ' is-active' : ''}`}>
            <img
              class="hero-pt__image"
              src={image}
              alt={alt}
              width={width}
              height={height}
              decoding="async"
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </div>
        ))}
      </div>
      <div class="hero-pt__scrim" aria-hidden="true"></div>
      <div class="hero-pt__copy">
        <p class="eyebrow">Portraitfotografie Düsseldorf</p>
        <h1>Portrait <em>Fotografie.</em></h1>
        <p>Portraitfotografie: Blick, Licht, Distanz und Haltung werden auf Nutzung und Persönlichkeit abgestimmt — für Personal Branding, Business Portraits, Team, Presse und Editorial. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.</p>
        <div class="hero-pt__actions">
          <a href="#anfrage">Portraitshooting anfragen →</a>
          <a class="ghost" href="portfolio.html">Portfolio</a>
        </div>
      </div>
    </section>

    <section class="st-pt" data-header-theme="light">
      <div class="section-inner">
        <h2>Ein Portrait muss <em>führen.</em></h2>
        <div class="st-pt__body">
          <p>Gute Portraits entstehen nicht durch Zufall. Entscheidend sind Abstand, Licht, Gespräch, Haltung, Kleidung, Hintergrund und die Frage, wofür das Bild später stehen soll.</p>
          <p>Ich arbeite ruhig und klar geführt — damit Bilder entstehen, die professionell wirken, ohne künstlich zu sein. Für Einzelpersonen, Teams, Unternehmen, Magazine und persönliche Marken.</p>
        </div>
      </div>
    </section>

    <section class="mod-pt" data-header-theme="dark">
      <div class="section-inner">
        <div class="mod-pt__head">
          <h2>Portraits für <em>Kontext.</em></h2>
          <p>Nicht jedes Portrait hat dieselbe Aufgabe. Deshalb werden Licht, Distanz, Ausschnitt und Tonalität pro Nutzung geplant.</p>
        </div>
        <div class="mod-pt__grid">
          {modules.map((item) => (
            <article class="mod-pt__card" style={`background-image:url('${item.image}')`}>
              <div>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-pt" data-header-theme="dark" aria-label="Portrait Galerie">
      <div class="bg-pt__inner">
        <div class="bg-pt__head">
          <h2>Ausgewählte <em>Portraits.</em></h2>
          <p>Eine kuratierte Auswahl aus ruhigen, editorial geführten und professionellen Portraitstrecken.</p>
        </div>
        <div class="bg-pt__grid">
          {galleryTiles.map(([full, image, alt, width, height]) => (
            <button class="bg-pt__tile" type="button" data-full={full}>
              <img data-src={image} src={image} loading="lazy" alt={alt} width={width} height={height} decoding="async" />
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="fw-pt" data-header-theme="light">
      <div class="section-inner">
        <div class="fw-pt__head">
          <h2>Ablauf <em>ohne Druck.</em></h2>
          <p>Portraitshootings funktionieren besser, wenn vorher klar ist, was gebraucht wird und was nicht. So bleibt der Termin ruhig.</p>
        </div>
        <div class="fw-pt__list">
          {workflow.map((item) => (
            <article class="fw-pt__row">
              <img loading="lazy" src={item.image} alt={item.alt} width={item.width} height={item.height} decoding="async" />
              <div>
                <span>{item.number}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="rl-pt" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-pt__head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Portraits verbinden Person, Marke und Umgebung. Diese Bereiche passen häufig dazu — je nachdem, ob Bildsprache, Bewegung oder Portfolio im Vordergrund stehen.</p>
        </div>
        <div class="rl-pt__grid">
          {relatedAreas.map(([href, image, alt, meta, title]) => (
            <a class="rl-pt__card" href={href} style={`background-image:url('${image}')`}>
              <span>{meta}</span>
              <strong>{title}</strong>
              <em>{alt}</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Portraitfotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Portraitfotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Portraitfotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Portraitfotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject="Portrait Fotografie Anfrage"
      data-contact-headline="Portrait &lt;em&gt;anfragen.&lt;/em&gt;"
      data-contact-lead="Schreibe kurz, wofür die Portraits gedacht sind — Personal Branding, Editorial, Team, Presse oder Bewerbung. Wichtig sind Person/Team, gewünschte Wirkung, Ort und Zeitraum. Stil und Licht klären wir vor dem ersten Klick."
    />
  </main>
</NativeLegacyLayout>
