const workflow = [
  {
    image: 'assets/portraits/_DSC9301-Enhanced-NR.webp',
    alt: 'Portrait Anfrage',
    width: 2048,
    height: 2560,
    number: '01',
    title: 'Anfrage',
    text: 'Wofür werden die Portraits gebraucht? Website, LinkedIn, Presse, Teamseite, Magazin oder Bewerbung — die Nutzung bestimmt Stil und Formate.',
  },
  {
    image: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp',
    alt: 'Portrait Kennenlernen',
    width: 1920,
    height: 1280,
    number: '02',
    title: 'Kennenlernen',
    text: 'Wir klären Wirkung, Tonalität, Outfit, Location und ob die Bilder eher ruhig, nahbar, editorial oder sehr klar wirken sollen.',
  },
  {
    image: 'assets/optimized/assets-portfolio-20250605-dsc03756-1920.webp',
    alt: 'Portrait Konzept',
    width: 1707,
    height: 2560,
