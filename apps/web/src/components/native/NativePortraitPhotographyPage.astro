---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import NativeFamilyClusterLinks from './NativeFamilyClusterLinks.astro'
import PreviewToolbar from '../PreviewToolbar.astro'
import {
  localScopePhrase,
  nativeFamilyPageContext,
  type NativeFamilyPreviewState,
} from '../../lib/nativeFamilyPageContext'
import { familyVisualSlots, getFamilyVisualSourceDoc } from '../../lib/localSeoFamilyVisuals'
import { getLegacyBackedDoc, type PayloadDoc } from '../../lib/payload'

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string
  preview?: NativeFamilyPreviewState
  visualDoc?: PayloadDoc | null
}

const defaultLegacyFile = 'portraitfotografie.html'
const props = Astro.props as Props
const { doc: providedDoc = undefined, legacyFile: providedLegacyFile, preview, visualDoc: providedVisualDoc = undefined } = props
const legacyFile = providedLegacyFile || defaultLegacyFile
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))
const shouldUseCmsVisualDoc = Boolean(preview) || import.meta.env.ASTRO_ENABLE_CMS_VISUAL_OVERRIDES === 'true'
const visualDoc = Object.hasOwn(props, 'visualDoc')
  ? providedVisualDoc
  : shouldUseCmsVisualDoc
    ? await getFamilyVisualSourceDoc('portrait', doc, legacyFile, defaultLegacyFile)
    : null
const pageContext = nativeFamilyPageContext({
  defaultLegacyFile,
  doc,
  family: 'portrait',
  legacyFile,
  preview,
})
const { clusterHeading, clusterLinks, isKeywordPage, isParentPage, overviewHref, publishedHref, scope, serviceLabel } = pageContext
const heroLabel = isParentPage || isKeywordPage ? 'Portraitfotografie' : `Portraitfotografie ${scope.label}`
const heroTitle = isParentPage || isKeywordPage ? 'Portrait' : 'Portraitfotografie'
const heroEmphasis = isParentPage || isKeywordPage ? 'Fotografie.' : `${scope.label}.`
const heroLead = isParentPage
  ? 'Portraitfotografie: Blick, Licht, Distanz und Haltung werden auf Nutzung und Persönlichkeit abgestimmt — für Personal Branding, Business Portraits, Team, Presse und Editorial. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.'
  : isKeywordPage
    ? `${serviceLabel}: eigenständiger Einstieg in den Portrait Fotografie-Cluster. Blick, Licht, Distanz und Haltung werden auf Nutzung und Persönlichkeit abgestimmt - für Personal Branding, Business Portraits, Team, Presse und Editorial. Die Seite bleibt bewusst im Layout der übergeordneten Kategorie, setzt den Text aber auf diese konkrete Suchintention.`
    : `Portraitfotografie in ${scope.label}: Blick, Licht, Distanz und Haltung werden auf Nutzung und Persönlichkeit abgestimmt - für Personal Branding, Business Portraits, Team, Presse und Editorial. ${localScopePhrase(scope)}`
const metaTitle = isParentPage
  ? 'Portraitfotografie - Matthias Ramahi'
  : isKeywordPage
    ? `${serviceLabel} | Matthias Ramahi`
    : `${serviceLabel} ${scope.label} | Matthias Ramahi`
const metaDescription = isParentPage
  ? 'Portraitfotografie: Personal Branding, Business Portraits, Editorial, Team und Presse - professionell, ruhig, nahbar und nicht glattgebuegelt.'
  : isKeywordPage
    ? `${serviceLabel}: Personal Branding, Business Portraits, Editorial, Team und Presse.`
    : `${serviceLabel} ${scope.label}: Personal Branding, Business Portraits, Editorial, Team und Presse.`
const contactSubject = isParentPage ? 'Portrait Fotografie Anfrage' : `${serviceLabel}${isKeywordPage ? '' : ` ${scope.label}`} Anfrage`
const contactHeadline = isParentPage
  ? 'Portrait &lt;em&gt;anfragen.&lt;/em&gt;'
  : isKeywordPage
    ? `${serviceLabel} &lt;em&gt;anfragen.&lt;/em&gt;`
    : `Portrait ${scope.label} &lt;em&gt;anfragen.&lt;/em&gt;`
const contactLead = isParentPage
  ? 'Schreibe kurz, wofür die Portraits gedacht sind — Personal Branding, Editorial, Team, Presse oder Bewerbung. Wichtig sind Person/Team, gewünschte Wirkung, Ort und Zeitraum. Stil und Licht klären wir vor dem ersten Klick.'
  : isKeywordPage
    ? `Schreibe kurz, wofür ${serviceLabel} gebraucht wird, welche Person oder welches Team im Mittelpunkt steht und welche Nutzung geplant ist. Wir klären Stil, Ort, Umfang und Ausgabe gemeinsam.`
    : `Schreibe kurz, wofür die Portraits in ${scope.label} gedacht sind - Personal Branding, Editorial, Team, Presse oder Bewerbung. Wichtig sind Person oder Team, gewünschte Wirkung, Ort und Zeitraum. Stil und Licht klären wir vor dem ersten Klick.`

const visualSlots = familyVisualSlots(visualDoc, [
  { alt: 'Portrait warm', full: 'assets/portraits/_DSC0470-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC0470-Enhanced-NR.webp', width: 1600, height: 2560 },
  { alt: 'Portrait Profil', full: 'assets/portraits/_DSC9301-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9301-Enhanced-NR.webp', width: 2048, height: 2560 },
  { alt: 'Portrait Editorial', full: 'assets/portraits/_DSC9321-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9321-Enhanced-NR.webp', width: 1707, height: 2560 },
  { alt: 'Portrait Konzept', full: 'assets/optimized/assets-portraits-20250327-dsc01550-1920.webp', src: 'assets/portfolio/thumbs/20250327-DSC01550.webp', width: 1691, height: 2560 },
  { alt: 'Portrait Modul', full: 'assets/portraits/_DSC0470-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC0470-Enhanced-NR.webp', width: 720, height: 1152 },
  { alt: 'Portrait Team', full: 'assets/optimized/assets-portraits-dsc3908-1920.webp', src: 'assets/portfolio/thumbs/_DSC3908.webp', width: 720, height: 480 },
  { alt: 'Portrait Konzept', full: 'assets/optimized/assets-portraits-20250605-dsc04020-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC04020.webp', width: 720, height: 1080 },
  { alt: 'Portrait Headshot', full: 'assets/portraits/_DSC9321-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9321-Enhanced-NR.webp', width: 720, height: 1080 },
  { alt: 'Portrait Stimmung', full: 'assets/optimized/assets-portraits-dsc2986-1920.webp', src: 'assets/portfolio/thumbs/_DSC2986.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/portraits/_DSC0470-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC0470-Enhanced-NR.webp', width: 720, height: 1152 },
  { alt: 'Portrait', full: 'assets/portraits/_DSC9321-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9321-Enhanced-NR.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc3908-1920.webp', src: 'assets/portfolio/thumbs/_DSC3908.webp', width: 720, height: 480 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc3878-1920.webp', src: 'assets/portfolio/thumbs/_DSC3878.webp', width: 720, height: 480 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc2986-1920.webp', src: 'assets/portfolio/thumbs/_DSC2986.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc2744-1920.webp', src: 'assets/portfolio/thumbs/_DSC2744.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-20250605-dsc04020-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC04020.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc2358-1920.webp', src: 'assets/portfolio/thumbs/_DSC2358.webp', width: 720, height: 1080 },
  { alt: 'Portrait', full: 'assets/optimized/assets-portraits-dsc2310-1920.webp', src: 'assets/portfolio/thumbs/_DSC2310.webp', width: 720, height: 480 },
  { alt: 'Anfrage', full: 'assets/portraits/_DSC9301-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9301-Enhanced-NR.webp', width: 720, height: 900 },
  { alt: 'Kennenlernen', full: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp', src: 'assets/portfolio/thumbs/_DSC3032_genErase (1).webp', width: 720, height: 480 },
  { alt: 'Konzept', full: 'assets/optimized/assets-portfolio-20250605-dsc03756-1920.webp', src: 'assets/portfolio/thumbs/20250605-DSC03756.webp', width: 720, height: 1080 },
  { alt: 'Shooting', full: 'assets/optimized/assets-portraits-dsc2310-1920.webp', src: 'assets/portfolio/thumbs/_DSC2310.webp', width: 720, height: 480 },
  { alt: 'Auswahl und Lieferung', full: 'assets/portraits/_DSC0470-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC0470-Enhanced-NR.webp', width: 720, height: 1152 },
  { alt: 'Landschaft', full: 'assets/optimized/assets-portfolio-wettberwerb-foto5-wunder-der-natur2-1920.webp', src: 'assets/portfolio/thumbs/Wettberwerb_Foto5_Wunder_der_Natur2.webp', width: 720, height: 471 },
  { alt: 'Automobil', full: 'assets/optimized/assets-photos-automobil-neon-1920.webp', src: 'assets/optimized/assets-photos-automobil-neon-960.webp', width: 960, height: 640 },
  { alt: 'Videografie', full: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp', src: 'assets/portfolio/thumbs/_DSC3032_genErase (1).webp', width: 720, height: 480 },
  { alt: 'Portfolio', full: 'assets/portraits/_DSC9321-Enhanced-NR.webp', src: 'assets/portfolio/thumbs/_DSC9321-Enhanced-NR.webp', width: 720, height: 1080 },
])

const cityLinks = [
  ['portraitfotografie.html', 'Düsseldorf'],
  ['portraitfotografie-koeln.html', 'Köln'],
  ['portraitfotografie-essen.html', 'Essen'],
  ['portraitfotografie-dortmund.html', 'Dortmund'],
  ['portraitfotografie-duisburg.html', 'Duisburg'],
  ['portraitfotografie-bochum.html', 'Bochum'],
  ['portraitfotografie-wuppertal.html', 'Wuppertal'],
  ['portraitfotografie-leverkusen.html', 'Leverkusen'],
  ['portraitfotografie-oberhausen.html', 'Oberhausen'],
  ['portraitfotografie-krefeld.html', 'Krefeld'],
  ['portraitfotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['portraitfotografie-moers.html', 'Moers'],
  ['portraitfotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['portraitfotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['portraitfotografie-solingen.html', 'Solingen'],
  ['portraitfotografie-remscheid.html', 'Remscheid'],
  ['portraitfotografie-mettmann.html', 'Mettmann'],
  ['portraitfotografie-hilden.html', 'Hilden'],
  ['portraitfotografie-dormagen.html', 'Dormagen'],
  ['portraitfotografie-neuss.html', 'Neuss'],
  ['portraitfotografie-nrw.html', 'NRW'],
  ['portraitfotografie-deutschland.html', 'Deutschland'],
] as const

const searchLinks = [
  ['business-portrait-duesseldorf.html', 'Business Portrait'],
  ['headshot-fotograf-duesseldorf.html', 'Headshot Fotograf'],
  ['personal-branding-fotografie.html', 'Personal Branding Fotografie'],
  ['unternehmensportrait-duesseldorf.html', 'Unternehmensportrait'],
  ['pressefoto-duesseldorf.html', 'Pressefoto'],
] as const
---
<AdoptedPageLayout
  legacyFile={legacyFile}
  current="fotografie"
  doc={doc}
  noIndex={Boolean(preview)}
  title={metaTitle}
  description={metaDescription}
  ogImage={visualSlots[0].full}
>
  {preview && (
    <PreviewToolbar
      collection={preview.collection}
      slug={preview.slug}
      status={preview.status}
      publishedHref={publishedHref}
    />
  )}
  <main>
    <section class="hero-pt" id="heroPt" data-header-theme="dark" aria-label={heroLabel}>
      <div class="hero-pt__stage" aria-hidden="true">
        <div class="hero-pt__slides">
          <div class="hero-pt__slide" data-i="0">
            <div class="hero-pt__zoom">
              <img class="hero-pt__image" src={visualSlots[0].src} srcset={visualSlots[0].srcset} sizes="100vw" alt="" fetchpriority="high" decoding="async" width={visualSlots[0].width} height={visualSlots[0].height} />
            </div>
          </div>
          <div class="hero-pt__slide" data-i="1">
            <div class="hero-pt__zoom">
              <img class="hero-pt__image" src={visualSlots[1].src} srcset={visualSlots[1].srcset} sizes="100vw" alt="" loading="lazy" decoding="async" width={visualSlots[1].width} height={visualSlots[1].height} />
            </div>
          </div>
          <div class="hero-pt__slide" data-i="2">
            <div class="hero-pt__zoom">
              <img class="hero-pt__image" src={visualSlots[2].src} srcset={visualSlots[2].srcset} sizes="100vw" alt="" loading="lazy" decoding="async" width={visualSlots[2].width} height={visualSlots[2].height} />
            </div>
          </div>
          <div class="hero-pt__slide" data-i="3">
            <div class="hero-pt__zoom">
              <img class="hero-pt__image" src={visualSlots[3].src} srcset={visualSlots[3].srcset} sizes="100vw" alt="" loading="lazy" decoding="async" width={visualSlots[3].width} height={visualSlots[3].height} />
            </div>
          </div>
        </div>
        <span class="hero-pt__vignette"></span>
        <span class="hero-pt__catchlight"></span>
      </div>

      <h1 class="hero-pt__title">{heroTitle} <em>{heroEmphasis}</em></h1>

      <div class="hero-pt__sub-block">
        <p class="hero-pt__sub">{doc?.intro || heroLead}</p>
        <div class="hero-pt__actions">
          <a href="#anfrage">Portraitshooting anfragen →</a>
          <a class="ghost" href="portfolio.html">Portfolio</a>
        </div>
      </div>
    </section>

    <section class="st-pt" data-header-theme="light">
      <div class="st-pt__inner">
        <h2 class="st-pt__title">Nähe ohne <em>Beliebigkeit.</em></h2>
        <div class="st-pt__body">
          <p>Ein gutes Portrait entsteht nicht durch Requisiten, sondern durch Haltung, Timing und ein Licht, das zur Person passt. Die Bilder sollen eindeutig wirken — nicht inszeniert.</p>
          <p>Für Personal Branding, Founder, Teams, Editorials und Kampagnen, die mehr Persönlichkeit tragen sollen als ein Standard-Headshot.</p>
          <a class="st-pt__cta" href="#anfrage">Jetzt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="mod-pt" data-header-theme="dark">
      <div class="mod-pt__head">
        <h2 class="mod-pt__title">Verschiedene <em>Perspektiven.</em></h2>
        <p class="mod-pt__lead">Fünf Felder, in denen ein Portrait konkret etwas verschiebt — vom Personal Brand bis zur redaktionellen Strecke.</p>
      </div>
      <div class="mod-pt__grid">
        <article class="mod-pt__card">
          <div class="mod-pt__img" style={`background-image:url('${visualSlots[4].cssSrc}')`}></div>
          <div class="mod-pt__body">
            <span class="mod-pt__num">01 · Personal Brand</span>
            <h3 class="mod-pt__name">Founder & Speaker</h3>
            <p class="mod-pt__desc">Selbstständige, Coaches, Speaker, Founder — ein Bild, das wirkt, ohne sich aufzudrängen.</p>
          </div>
        </article>
        <article class="mod-pt__card">
          <div class="mod-pt__img" style={`background-image:url('${visualSlots[5].cssSrc}')`}></div>
          <div class="mod-pt__body">
            <span class="mod-pt__num">02 · Team</span>
            <h3 class="mod-pt__name">Agentur & Kanzlei</h3>
            <p class="mod-pt__desc">Agenturen, Kanzleien, Praxen, Marken — eine konsistente Bildsprache, ohne jeden Charakter zu glätten.</p>
          </div>
        </article>
        <article class="mod-pt__card">
          <div class="mod-pt__img" style={`background-image:url('${visualSlots[6].cssSrc}')`}></div>
          <div class="mod-pt__body">
            <span class="mod-pt__num">03 · Editorial</span>
            <h3 class="mod-pt__name">Magazin & Strecke</h3>
            <p class="mod-pt__desc">Magazine, Bildstrecken, Künstler-Features — Portraits mit Haltung und Erzählung statt Pose.</p>
          </div>
        </article>
        <article class="mod-pt__card">
          <div class="mod-pt__img" style={`background-image:url('${visualSlots[7].cssSrc}')`}></div>
          <div class="mod-pt__body">
            <span class="mod-pt__num">04 · Presse</span>
            <h3 class="mod-pt__name">Headshot & Profil</h3>
            <p class="mod-pt__desc">Pressefotos, Headshots, Bewerbung, Profil — klare, ruhige Bilder für den professionellen Auftritt.</p>
          </div>
        </article>
        <article class="mod-pt__card">
          <div class="mod-pt__img" style={`background-image:url('${visualSlots[8].cssSrc}')`}></div>
          <div class="mod-pt__body">
            <span class="mod-pt__num">05 · Kampagne</span>
            <h3 class="mod-pt__name">Cover & Konzept</h3>
            <p class="mod-pt__desc">Marken-Portraits, Cover, Konzept-Strecken — inszenierte Bilder mit einem klaren Standpunkt.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="bg-pt" data-header-theme="dark" aria-label="Aus dem Portfolio">
      <div class="bg-pt__head">
        <h2 class="bg-pt__title">Aus dem <em>Portfolio.</em></h2>
        <a class="bg-pt__link" href="portfolio.html">Komplettes Portfolio ansehen →</a>
      </div>
      <div class="bg-pt__grid">
        <button class="bg-pt__tile t-hero" data-full={visualSlots[9].full}><img src={visualSlots[9].src} data-full={visualSlots[9].full} alt={visualSlots[9].alt} width={visualSlots[9].width} height={visualSlots[9].height} decoding="async" loading="lazy" /></button>
        <button class="bg-pt__tile t-a" data-full={visualSlots[10].full}><img src={visualSlots[10].src} data-full={visualSlots[10].full} loading="lazy" alt={visualSlots[10].alt} width={visualSlots[10].width} height={visualSlots[10].height} decoding="async" /></button>
        <button class="bg-pt__tile t-b" data-full={visualSlots[11].full}><img loading="lazy" src={visualSlots[11].src} data-full={visualSlots[11].full} alt={visualSlots[11].alt} width={visualSlots[11].width} height={visualSlots[11].height} decoding="async" /></button>
        <button class="bg-pt__tile t-c" data-full={visualSlots[12].full}><img loading="lazy" src={visualSlots[12].src} data-full={visualSlots[12].full} alt={visualSlots[12].alt} width={visualSlots[12].width} height={visualSlots[12].height} decoding="async" /></button>
        <button class="bg-pt__tile t-d" data-full={visualSlots[13].full}><img loading="lazy" src={visualSlots[13].src} data-full={visualSlots[13].full} alt={visualSlots[13].alt} width={visualSlots[13].width} height={visualSlots[13].height} decoding="async" /></button>
        <button class="bg-pt__tile t-e" data-full={visualSlots[14].full}><img loading="lazy" src={visualSlots[14].src} data-full={visualSlots[14].full} alt={visualSlots[14].alt} width={visualSlots[14].width} height={visualSlots[14].height} decoding="async" /></button>
        <button class="bg-pt__tile t-f" data-full={visualSlots[15].full}><img loading="lazy" src={visualSlots[15].src} data-full={visualSlots[15].full} alt={visualSlots[15].alt} width={visualSlots[15].width} height={visualSlots[15].height} decoding="async" /></button>
        <button class="bg-pt__tile t-g" data-full={visualSlots[16].full}><img loading="lazy" src={visualSlots[16].src} data-full={visualSlots[16].full} alt={visualSlots[16].alt} width={visualSlots[16].width} height={visualSlots[16].height} decoding="async" /></button>
        <button class="bg-pt__tile t-h" data-full={visualSlots[17].full}><img loading="lazy" src={visualSlots[17].src} data-full={visualSlots[17].full} alt={visualSlots[17].alt} width={visualSlots[17].width} height={visualSlots[17].height} decoding="async" /></button>
      </div>
    </section>

    <section class="fw-pt" data-header-theme="light">
      <div class="fw-pt__inner">
        <div class="fw-pt__head">
          <h2 class="fw-pt__title"><em>Ablauf.</em></h2>
          <p class="fw-pt__lead">Vom ersten Kontakt bis zur Bildabgabe — fünf ruhige Schritte, damit du vor dem Shooting weißt, was passiert und nach dem Shooting weißt, was kommt.</p>
        </div>
        <ul class="fw-pt__list">
          <li class="fw-pt__row">
            <span class="fw-pt__num">01</span>
            <div class="fw-pt__thumb" style={`background-image:url('${visualSlots[18].cssSrc}')`} role="img" aria-label="Anfrage"></div>
            <h3 class="fw-pt__name">Anfrage</h3>
            <p class="fw-pt__copy">Kurze Nachricht reicht — Anlass, Person oder Team, gewünschte Wirkung, Zeitraum. Antwort innerhalb von 24 Stunden mit erster Einordnung und nächsten Schritten.</p>
            <span class="fw-pt__arrow" aria-hidden="true">→</span>
          </li>
          <li class="fw-pt__row">
            <span class="fw-pt__num">02</span>
            <div class="fw-pt__thumb" style={`background-image:url('${visualSlots[19].cssSrc}')`} role="img" aria-label="Kennenlernen"></div>
            <h3 class="fw-pt__name">Kennenlernen</h3>
            <p class="fw-pt__copy">Ein lockeres Gespräch — telefonisch oder vor Ort. Wir klären den Kontext, wer die Bilder sehen wird und welche Tonalität dazu passt. Ohne Verkaufsdruck.</p>
            <span class="fw-pt__arrow" aria-hidden="true">→</span>
          </li>
          <li class="fw-pt__row">
            <span class="fw-pt__num">03</span>
            <div class="fw-pt__thumb" style={`background-image:url('${visualSlots[20].cssSrc}')`} role="img" aria-label="Konzept"></div>
            <h3 class="fw-pt__name">Konzept &amp; Briefing</h3>
            <p class="fw-pt__copy">Wir sammeln Referenzen, definieren Licht, Hintergrund, Outfit und ein paar Schlüsselbilder. Du bekommst ein klares Mini-Briefing — keine 30-Seiten-Decks.</p>
            <span class="fw-pt__arrow" aria-hidden="true">→</span>
          </li>
          <li class="fw-pt__row">
            <span class="fw-pt__num">04</span>
            <div class="fw-pt__thumb" style={`background-image:url('${visualSlots[21].cssSrc}')`} role="img" aria-label="Shooting"></div>
            <h3 class="fw-pt__name">Shooting</h3>
            <p class="fw-pt__copy">Location in Düsseldorf oder vor Ort. Ruhiges Setup, viel Raum zum Ankommen, klare Regie ohne Pose-Drill. Zwischendurch ein gemeinsamer Blick auf den Monitor.</p>
            <span class="fw-pt__arrow" aria-hidden="true">→</span>
          </li>
          <li class="fw-pt__row">
            <span class="fw-pt__num">05</span>
            <div class="fw-pt__thumb" style={`background-image:url('${visualSlots[22].cssSrc}')`} role="img" aria-label="Auswahl und Lieferung"></div>
            <h3 class="fw-pt__name">Auswahl &amp; Lieferung</h3>
            <p class="fw-pt__copy">Eine kuratierte Vorauswahl als Web-Galerie. Du wählst die finalen Bilder, ich retuschiere zurückhaltend und liefere in den Formaten, die du brauchst — Web, Print, Social.</p>
            <span class="fw-pt__arrow" aria-hidden="true">→</span>
          </li>
        </ul>
        <div class="fw-pt__cta">
          <p>Klingt nach dem richtigen Rahmen? <em>Lass uns sprechen.</em></p>
          <a href="#anfrage">Projekt anfragen →</a>
        </div>
      </div>
    </section>

    <section class="rl-pt" data-header-theme="dark" aria-label="Portrait Fotografie">
      <div class="rl-pt__inner">
        <h2 class="rl-pt__title">Verwandte <em>Bereiche.</em></h2>
        <p class="rl-pt__intro">Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        <div class="rl-pt__grid">
          <a class="rl-pt__card" href="landschaftsfotografie.html"><div class="rl-pt__card-img" style={`background-image:url('${visualSlots[23].cssSrc}')`}></div><div class="rl-pt__card-body"><strong>Landschaft</strong><span>→</span></div></a>
          <a class="rl-pt__card" href="automobil-fotografie.html"><div class="rl-pt__card-img" style={`background-image:url('${visualSlots[24].cssSrc}')`}></div><div class="rl-pt__card-body"><strong>Automobil</strong><span>→</span></div></a>
          <a class="rl-pt__card" href="videografie-duesseldorf.html"><div class="rl-pt__card-img" style={`background-image:url('${visualSlots[25].cssSrc}')`}></div><div class="rl-pt__card-body"><strong>Videografie</strong><span>→</span></div></a>
          <a class="rl-pt__card" href="portfolio.html"><div class="rl-pt__card-img" style={`background-image:url('${visualSlots[26].cssSrc}')`}></div><div class="rl-pt__card-body"><strong>Portfolio</strong><span>→</span></div></a>
        </div>
      </div>
    </section>

    {!isParentPage && (
      <NativeFamilyClusterLinks
        clusterHeading={clusterHeading}
        clusterLinks={clusterLinks}
        overviewHref={overviewHref}
        scopeLabel={scope.label}
      />
    )}

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Portrait Fotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2 class="mr-cities__title">Portrait Fotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Portrait Fotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Portrait Fotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject={contactSubject}
      data-contact-headline={contactHeadline}
      data-contact-lead={contactLead}
    ></section>
  </main>
</AdoptedPageLayout>
