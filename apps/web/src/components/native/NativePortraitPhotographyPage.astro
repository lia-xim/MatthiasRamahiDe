  ['assets/optimized/assets-portraits-dsc2986-1920.webp', 'assets/optimized/assets-portraits-dsc2986-1920.webp', 'Portrait Licht', 1707, 2560],
  ['assets/optimized/assets-portraits-dsc2744-1920.webp', 'assets/optimized/assets-portraits-dsc2744-1920.webp', 'Portrait Profil', 1707, 2560],
  ['assets/optimized/assets-portraits-20250605-dsc04020-1920.webp', 'assets/optimized/assets-portraits-20250605-dsc04020-1920.webp', 'Editorial Portrait Serie', 1707, 2560],
  ['assets/optimized/assets-portraits-dsc2358-1920.webp', 'assets/optimized/assets-portraits-dsc2358-1920.webp', 'Portrait im Raum', 1707, 2560],
  ['assets/optimized/assets-portraits-dsc2310-1920.webp', 'assets/optimized/assets-portraits-dsc2310-1920.webp', 'Portrait Detail', 1920, 1280],
