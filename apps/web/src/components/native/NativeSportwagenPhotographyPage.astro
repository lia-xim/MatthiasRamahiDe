const visualSlots = familyVisualSlots(visualDoc, [
  ...heroPanels.map(([, src, mobile]) => ({ alt: 'Sportwagen Hero', src, mobile })),
  ...shootingStyles.map(({ image, alt, width, height }) => ({ alt, height, src: image, width })),
  ...portfolioTiles.map(({ alt, full, height, src, width }) => ({ alt, full, height, src, width })),
  ...audiences.map(({ alt, height, image, width }) => ({ alt, height, src: image, width })),
])
const inheritedHeroPanels = heroPanels.map(([name], index) => {
  const visual = visualSlots[index]
  return [name, visual.full, visual.mobile, visual] as const
})
const inheritedShootingStyles = shootingStyles.map((style, index) => {
  const visual = visualSlots[index + heroPanels.length]
  return { ...style, alt: visual.alt, height: visual.height, image: visual.src, width: visual.width }
})
const inheritedPortfolioTiles = portfolioTiles.map((tile, index) => {
  const visual = visualSlots[index + heroPanels.length + shootingStyles.length]
  return { ...tile, alt: visual.alt, full: visual.full, height: visual.height, src: visual.src, width: visual.width }
})
const statementImage = inheritedPortfolioTiles[0] || visualSlots[0]
const inheritedAudiences = audiences.map((audience, index) => {
  const visual = visualSlots[index + heroPanels.length + shootingStyles.length + portfolioTiles.length]
  return { ...audience, alt: visual.alt, height: visual.height, image: visual.src, width: visual.width }
})

// ===== CMS-Overrides der Themen-Sektionen =====
// Jede Sektion liest aus dem ServicePages-Doc (Tab „Themen-Sektionen"); ist sie leer,
// greift der bisherige Wert (inherited*/Hardcode) als Fallback. So bricht nichts,
// solange das CMS-Feld nicht gepflegt ist.
type SectionMedia = PayloadMedia | string | undefined
const resolveSectionImage = <T extends { src?: string; full?: string; image?: string; mobile?: string; srcset?: string; width?: number; height?: number; alt?: string }>(
  media: SectionMedia,
  fallback: T,
) => {
  const full = imageDisplayUrl(media as PayloadMedia | string | undefined, 'wide', { allowOriginal: true })
  if (!full) return fallback
  const src = imageDisplayUrl(media as PayloadMedia | string | undefined, 'card', { allowOriginal: true }) || full
  const mobile = imageDisplayUrl(media as PayloadMedia | string | undefined, 'mobile', { allowOriginal: true }) || src
  const dim = imageDimensions(media as PayloadMedia | undefined, 'card')
  return {
    ...fallback,
    src,
    full,
    image: src,
    mobile,
    srcset: imageSrcset(media as PayloadMedia | undefined, ['mobile', 'card', 'hero', 'wide']) || fallback.srcset || '',
    width: dim.width || fallback.width,
    height: dim.height || fallback.height,
    alt: imageAlt(media as PayloadMedia | undefined, fallback.alt || ''),
  }
}

const finalHeroPanels = doc?.heroPanels?.length
  ? doc.heroPanels.map((panel, index) => {
      const fbTuple = inheritedHeroPanels[index % inheritedHeroPanels.length]
      const resolved = resolveSectionImage(panel.image, fbTuple[3])
      return [fbTuple[0], resolved.full, resolved.mobile, resolved] as const
    })
  : inheritedHeroPanels

const finalShootingStyles = doc?.shootingStyles?.length
  ? doc.shootingStyles.map((style, index) => {
      const fb = inheritedShootingStyles[index] || inheritedShootingStyles[inheritedShootingStyles.length - 1]
      const resolved = resolveSectionImage(style.image, fb)
      return { ...resolved, title: style.title || fb.title, text: style.text || fb.text }
    })
  : inheritedShootingStyles

const finalPortfolioTiles = doc?.portfolioTiles?.length
  ? doc.portfolioTiles.map((tile, index) => {
      const fb = inheritedPortfolioTiles[index] || inheritedPortfolioTiles[inheritedPortfolioTiles.length - 1]
      const resolved = resolveSectionImage(tile.image, fb)
      return { ...resolved, className: fb.className, label: tile.label || fb.label }
    })
  : inheritedPortfolioTiles

const finalAudiences = doc?.audienceCards?.length
  ? doc.audienceCards.map((card, index) => {
      const fb = inheritedAudiences[index] || inheritedAudiences[inheritedAudiences.length - 1]
      const resolved = resolveSectionImage(card.image, fb)
      return { ...resolved, number: card.number || fb.number, title: card.title || fb.title, text: card.text || fb.text }
    })
  : inheritedAudiences

const finalStatementImage = finalPortfolioTiles[0] || statementImage
const statementHeadline = (typeof doc?.statement?.headline === 'string' && doc.statement.headline.trim()) || 'Bilder mit'
const statementEmphasis = (typeof doc?.statement?.emphasis === 'string' && doc.statement.emphasis.trim()) || 'Druckqualität.'
const statementBody = doc?.statement?.body?.length
  ? doc.statement.body.map((entry) => entry.text).filter((text): text is string => Boolean(text))
  : [
      'Sportwagen verlangen Präzision. Ich arbeite mit mobilem Licht, Reflektoren und einem klaren Plan — kontrollierte Reflexe, ruhige Hintergründe, echte Farben. Lack, Linien und Proportionen wirken stimmig, nicht überzeichnet.',
      'Ob Verkauf, Branding, Redaktion oder persönliches Geschenk: ich kombiniere klares Licht, saubere Komposition und einen Blick für Details. Sie erhalten Dateien für Web, Social Media und Druck — aufbereitet und sofort einsatzbereit.',
    ]

const relatedAreas = [
  {
    href: 'automobil-fotografie.html',
