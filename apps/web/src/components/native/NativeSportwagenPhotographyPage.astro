---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import NativeFamilyClusterLinks from './NativeFamilyClusterLinks.astro'
import PreviewToolbar from '../PreviewToolbar.astro'
import {
  localScopePhrase,
  nativeFamilyPageContext,
  type NativeFamilyPreviewState,
} from '../../lib/nativeFamilyPageContext'
import { familyVisualSlots, getFamilyVisualSourceDoc } from '../../lib/localSeoFamilyVisuals'
import { getLegacyBackedDoc, imageAlt, imageDimensions, imageDisplayUrl, imageSrcset, type PayloadDoc, type PayloadMedia } from '../../lib/payload'

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string
  preview?: NativeFamilyPreviewState
  visualDoc?: PayloadDoc | null
}

const defaultLegacyFile = 'sportwagen-fotografie.html'
const props = Astro.props as Props
const { doc: providedDoc = undefined, legacyFile: providedLegacyFile, preview, visualDoc: providedVisualDoc = undefined } = props
const legacyFile = providedLegacyFile || defaultLegacyFile
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))
const shouldUseCmsVisualDoc = import.meta.env.ASTRO_DISABLE_CMS_VISUAL_OVERRIDES !== 'true'
const visualDoc = Object.hasOwn(props, 'visualDoc')
  ? providedVisualDoc
  : shouldUseCmsVisualDoc
    ? await getFamilyVisualSourceDoc('sportwagen', doc, legacyFile, defaultLegacyFile)
    : null
const pageContext = nativeFamilyPageContext({
  defaultLegacyFile,
  doc,
  family: 'sportwagen',
  legacyFile,
  preview,
})
const { clusterHeading, clusterLinks, isKeywordPage, isParentPage, overviewHref, publishedHref, scope, serviceLabel } = pageContext
const cmsHeroLine2 = typeof doc?.heroLine2 === 'string' ? doc.heroLine2.trim() : ''
const heroSecondLine = cmsHeroLine2 || (isParentPage || isKeywordPage ? 'Fotografie.' : `Fotografie ${scope.label}.`)
const heroLabel = isParentPage || isKeywordPage ? 'Sportwagenfotografie' : `Sportwagenfotografie ${scope.label}`
const heroLead = isParentPage
  ? 'Sportwagenfotografie: Performance, Form, Innenraum und Details werden mit kontrollierten Reflexen und ruhiger Dramaturgie sichtbar — für Sammler, Händler, Marke, Verkauf und Druck. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.'
  : isKeywordPage
    ? `${serviceLabel}: eigenständiger Einstieg in den Sportwagen Fotografie-Cluster. Performance, Form, Innenraum und Details werden mit kontrollierten Reflexen und ruhiger Dramaturgie sichtbar - für Sammler, Händler, Marke, Verkauf und Druck. Die Seite bleibt bewusst im Layout der übergeordneten Kategorie, setzt den Text aber auf diese konkrete Suchintention.`
    : `Sportwagenfotografie in ${scope.label}: Performance, Form, Innenraum und Details werden mit kontrollierten Reflexen und ruhiger Dramaturgie sichtbar - für Sammler, Händler, Marke, Verkauf und Druck. ${localScopePhrase(scope)}`
const metaTitle = isParentPage
  ? 'Sportwagenfotografie - Matthias Ramahi'
  : isKeywordPage
    ? `${serviceLabel} | Matthias Ramahi`
    : `${serviceLabel} ${scope.label} | Matthias Ramahi`
const metaDescription = isParentPage
  ? 'Sportwagenfotografie: hochwertige Serien für Performance Cars, Sammlerfahrzeuge, Händler und Marken - Exterieur, Interieur, Details und Druckqualität.'
  : isKeywordPage
    ? `${serviceLabel}: hochwertige Serien für Performance Cars, Sammlerfahrzeuge, Händler und Marken.`
    : `${serviceLabel} ${scope.label}: hochwertige Serien für Performance Cars, Sammlerfahrzeuge, Händler und Marken.`
const contactSubject = isParentPage ? 'Sportwagen Fotografie Anfrage' : `${serviceLabel}${isKeywordPage ? '' : ` ${scope.label}`} Anfrage`
const contactHeadline = isParentPage
  ? 'Sportwagen <em>anfragen.</em>'
