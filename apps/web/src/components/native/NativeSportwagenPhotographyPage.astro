---
<AdoptedPageLayout
  legacyFile={legacyFile}
  current="fotografie"
  doc={doc}
  noIndex={Boolean(preview)}
  title={metaTitle}
  description={metaDescription}
  ogImage={visualSlots[1].full}
  preloadImages={[finalHeroPanels[0][3].full]}
>
  {preview && (
    <PreviewToolbar
      collection={preview.collection}
      slug={preview.slug}
      status={preview.status}
      publishedHref={publishedHref}
    />
  )}
  <main>
    <section class="hero-tri" id="top" data-header-theme="dark" aria-label={heroLabel}>
      <div class="tri-stage" aria-hidden="true">
        {finalHeroPanels.map(([name, image, mobileImage, visual], index) => (
          <div class="tri-col" data-tri={name}>
            <div class="tri-img">
              <picture>
                <source media="(max-width: 720px)" srcset={mobileImage} />
                <img
                  src={image}
                  srcset={visual.srcset || undefined}
                  sizes="(max-width: 720px) 100vw, 34vw"
                  alt=""
                  loading="eager"
                  fetchpriority={index === 0 ? 'high' : 'auto'}
                  width={visual.width}
                  height={visual.height}
                  decoding="async"
                />
              </picture>
            </div>
          </div>
        ))}
      </div>

      <div class="tri-overlay">
        <h1 class="tri-title">
          <span class="line"><span class="word">Sportwagen</span></span>
          <span class="line"><span class="word">{heroSecondLine}</span></span>
        </h1>
        <p class="tri-sub">{doc?.intro || heroLead}</p>
        <div class="tri-actions">
          <a href="#anfrage">Shooting buchen →</a>
          <a class="ghost" href="portfolio.html">Portfolio</a>
        </div>
      </div>
    </section>

    <section class="st" data-header-theme="light">
      <div class="section-inner">
        <div class="st-copy">
          <h2>{statementHeadline} <em>{statementEmphasis}</em></h2>
          <div class="st-body">
            {statementBody.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
        <figure class="st-image">
          <img loading="lazy" src={finalStatementImage.src} alt={finalStatementImage.alt} width={finalStatementImage.width} height={finalStatementImage.height} decoding="async" />
        </figure>
      </div>
    </section>

    <section class="sh" data-header-theme="dark">
      <div class="section-inner">
        <div class="sh-head">
          <h2>Das Auto, <em>aus jedem Winkel.</em></h2>
          <p>Exterieur, Interieur, Details und cineastische Perspektiven greifen ineinander — ein Bildsatz, der Fahrzeug, Atmosphäre und Material gleichermaßen zeigt.</p>
        </div>
        <div class="sh-grid">
          {finalShootingStyles.map((style) => (
            <article class="sh-card">
              <figure class="sh-img"><img loading="lazy" src={style.image} alt={style.alt} width={style.width} height={style.height} decoding="async" /></figure>
              <div class="sh-text">
                <h3>{style.title}</h3>
                <p>{style.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="po" data-header-theme="dark" aria-label="Ausgewählte Sportwagen-Arbeiten">
      <div class="po-grid" id="poGrid">
        <header class="po-head">
          <h2>Aktuelle <em>Arbeiten.</em></h2>
          <div class="head-foot">
            <p>Sechs kuratierte Sportwagen-Bilder aus jüngeren Serien. Klicken zum Vergrößern.</p>
          </div>
        </header>

        {finalPortfolioTiles.map((tile, index) => (
          <button type="button" class={`po-tile ${tile.className}`} data-i={index} data-full={tile.full} aria-label={`Bild ${index + 1} vergrößern`}>
            <img
              src={tile.src}
              data-full={tile.full}
              loading="lazy"
              alt={tile.alt}
              width={tile.width}
              height={tile.height}
              decoding="async"
            />
            <span class="corner tl" aria-hidden="true"></span>
            <span class="corner tr" aria-hidden="true"></span>
            <span class="corner bl" aria-hidden="true"></span>
            <span class="corner br" aria-hidden="true"></span>
            <span class="zoom">Zoom</span>
            <span class="lbl">{tile.label}</span>
          </button>
        ))}
      </div>
    </section>

    <section class="fw" data-header-theme="light">
      <div class="section-inner">
        <div class="fw-head">
          <h2>Für <em>wen</em> ich arbeite.</h2>
          <p>Vom privaten Fahrzeug bis zur internationalen Kampagne. Jede Serie wird auf Nutzung, Marke und Zielgruppe zugeschnitten — ein Hero-Motiv oder ein vollständiges Launch-Asset-Paket.</p>
        </div>
        <div class="fw-grid">
          {finalAudiences.map((audience) => (
            <article class="fw-card">
              <img loading="lazy" src={audience.image} alt={audience.alt} width={audience.width} height={audience.height} decoding="async" />
              <div class="overlay"></div>
              <div class="content">
                <span class="num">{audience.number}</span>
                <strong>{audience.title}</strong>
                <p>{audience.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="rl" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Sportwagen ist ein Teil der Automobil-Welt. Schau dir die anderen Disziplinen an — gleicher Anspruch, anderer Bildfokus. Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        </div>
        <div class="rl-grid">
          {relatedAreas.map((area) => (
            <a class="rl-card" href={area.href}>
              <img data-src={area.dataSrc} src={area.src || area.dataSrc} loading="lazy" alt={area.alt} width={area.width} height={area.height} decoding="async" />
              <div class="overlay"></div>
              <div class="content"><div><span>{area.meta}</span><strong>{area.title}</strong></div><span class="arrow">→</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {!isParentPage && (
      <NativeFamilyClusterLinks
        clusterHeading={clusterHeading}
        clusterLinks={clusterLinks}
        overviewHref={overviewHref}
        scopeLabel={scope.label}
      />
    )}

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Sportwagen Fotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Sportwagen Fotografie <em>vor Ort.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Sportwagen Fotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Sportwagen Fotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject={contactSubject}
      data-contact-headline={contactHeadline}
      data-contact-lead={contactLead}
    />
  </main>
</AdoptedPageLayout>
