---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import {
  portfolioArchivePhotos,
  portfolioContext,
  portfolioIndexLinks,
  portfolioSpreads,
} from '../../lib/portfolioIndexContent'
import { homeHeroSlidesFor } from '../../lib/nativeContent'
import { getSitePageByType, liveCmsFetchOptions, type PayloadDoc } from '../../lib/payload'

const providedDoc = Astro.props.doc as PayloadDoc | undefined
const doc = providedDoc || (await getSitePageByType('portfolio-index', liveCmsFetchOptions({ depth: 2 })))
const heroSlides = homeHeroSlidesFor(doc)
const firstHeroSlide = heroSlides[0]
const heroImages = heroSlides.map((slide) => slide.image)
const heroSlidesJson = JSON.stringify(heroSlides)
const emptyImage =
  'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%221%22 height=%221%22 viewBox=%220 0 1 1%22%3E%3C/svg%3E'
---
<AdoptedPageLayout
  legacyFile="portfolio.html"
  current="portfolio"
  doc={doc}
  ctaHref="#anfrage"
  preloadImages={[firstHeroSlide.image]}
  liveCms
>
  <main>
    <section class="hero" data-theme="dark" data-header-theme="dark" aria-label="Portfolio" style={`background-image:url('${firstHeroSlide.image}')`}>
      <canvas id="hero-shader" aria-hidden="true" data-imgs={heroImages.join(',')} data-slides={heroSlidesJson}></canvas>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-aperture" aria-hidden="true"></div>
      <div class="hero-grid">
        <div class="hero-stage">
          <h1 class="hero-title" id="hero-title" data-text-idx="0">
            {firstHeroSlide.titleLines.map((line) => (
              <span class="line"><span class="word">{line}</span></span>
            ))}
          </h1>
          <p class="hero-lead" id="hero-lead">{firstHeroSlide.lead}</p>
          <div class="hero-actions" aria-label="Direkte Aktionen">
            <a class="btn dark" href={firstHeroSlide.primaryHref} data-hero-primary hidden={!firstHeroSlide.primaryHref || !firstHeroSlide.primaryLabel}>{firstHeroSlide.primaryLabel}</a>
            <a class="btn" href={firstHeroSlide.secondaryHref} data-hero-secondary hidden={!firstHeroSlide.secondaryHref || !firstHeroSlide.secondaryLabel}>{firstHeroSlide.secondaryLabel}</a>
          </div>
        </div>
      </div>
      <div class="hero-cursor" id="hero-cursor" aria-hidden="true"><span class="ring"></span></div>
    </section>

    <nav class="pf-index" id="pfIndex" aria-label="Kategorien">
      <ol>
        {portfolioIndexLinks.map((link) => (
          <li><a href={link.href}><b>{link.number}</b>{link.label}</a></li>
        ))}
      </ol>
    </nav>

    <section class="pf-context" data-header-theme="light" aria-label="Portfolio einordnen">
      <div class="pf-context__inner">
        <div>
          <div class="pf-context__kicker">Einordnung</div>
          <h2>Serien statt Sammelmappe.</h2>
        </div>
        <div>
          {portfolioContext.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </section>

    {portfolioSpreads.map((spread) => (
      <section
        class={`pf-spread ${spread.theme === 'light' ? 'is-light' : ''}`.trim()}
        id={spread.id}
        data-header-theme={spread.theme}
        aria-label={spread.label.replace(/^\d+\s*\/\s*/, '')}
      >
        <div class="pf-spread__head">
          <div>
            <div class="pf-spread__kicker">{spread.label}</div>
            <h2>{spread.heading}</h2>
          </div>
          <a class="pf-spread__link" href={spread.href}>{spread.linkLabel}</a>
        </div>
        <div class="pf-spread__strip">
          {spread.photos.map((photo) => (
            <a class="pf-photo" data-caption={photo.caption} href={photo.href} aria-label={photo.caption || 'Bild im Großformat ansehen'}>
              <img src={photo.src} alt="" loading="lazy" decoding="async" width={photo.width} height={photo.height} />
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="pf-archive" id="archive" data-header-theme="light" aria-label="Archiv">
      <div class="pf-archive__head">
        <div class="pf-archive__kicker">∞ / Archiv</div>
        <h2>Bildarchiv, vollständig.</h2>
      </div>
      <div class="pf-archive__grid" id="pfArchiveGrid">
        {portfolioArchivePhotos.map((photo) => (
          <a class="pf-photo" data-caption={photo.caption} href={photo.href} aria-label={photo.caption || 'Bild im Großformat ansehen'}>
            <img
              src={photo.src}
              data-src={photo.src}
              alt=""
              loading="lazy"
              decoding="async"
              width={photo.width}
              height={photo.height}
            />
          </a>
        ))}
      </div>
      <div class="pf-archive__foot">
        <span>Aktualisierter Bestand · 2026</span>
        <a href="/contact.html">Anfrage stellen ↗</a>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-theme="light"
      data-contact-subject="Portfolio Anfrage"
      data-contact-headline="Portfolio <em>anfragen.</em>"
      data-contact-lead="Schreiben Sie kurz, welche Bildsprache Sie interessiert, wofür die Aufnahmen genutzt werden und welchen Zeitraum Sie planen. Dann klären wir Motiv, Umfang, Rechte und Ausgabe sauber gemeinsam."
    />

    <div class="pf-viewer" id="pfViewer" aria-hidden="true" role="dialog" aria-label="Bildansicht">
      <button class="pf-viewer__close" type="button" id="pfClose">Schließen</button>
      <button class="pf-viewer__prev" type="button" id="pfPrev" aria-label="Vorheriges Bild">‹</button>
      <button class="pf-viewer__next" type="button" id="pfNext" aria-label="Nächstes Bild">›</button>
      <figure class="pf-viewer__figure">
        <img id="pfViewerImg" src={emptyImage} alt="" decoding="async" loading="lazy" width="1" height="1" />
      </figure>
      <span class="pf-viewer__cap" id="pfViewerCap"></span>
    </div>
  </main>
</AdoptedPageLayout>
