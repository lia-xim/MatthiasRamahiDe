          </div>
          <div class="pf-row row-2">
            <div class="pf-track" id="pfTrack2"></div>
          </div>
        </div>
        <div class="pf-foot">
          <a class="btn dark" href="/portfolio.html">Vollst√É¬§ndiges Portfolio √¢‚ÄÝ‚Äô</a>
        </div>
      </div>
    </section>

    <section class="about sec-dark" data-theme="dark" aria-label="√É≈ìber mich">
      <div class="section-inner">
        <div class="about-img">
          <img src="/mpissxxj-portfolio_webp_full_063-1.webp" alt="Matthias Ramahi" loading="lazy" width="1628" height="1920" decoding="async" />
        </div>
        <div class="about-copy">
          <p class="kicker">√É≈ìber mich</p>
