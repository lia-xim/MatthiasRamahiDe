        </div>
        <div class="chapter-grid">
          {homeChapters.map((chapter, index) => (
            <a class="chapter" href={chapter.href}>
              <div class="img">
                <img src={chapter.image} srcset={chapter.srcset} sizes={chapter.sizes} alt={chapter.alt} loading="lazy" width={chapter.width} height={chapter.height} decoding="async" />
              </div>
              <div class="head"><h3>{chapter.title}</h3><span class="num">N√Ç¬∞ {String(index + 1).padStart(2, '0')}</span></div>
              <span class="meta"><span>{chapter.meta}</span><span class="arr">√¢‚ÄÝ‚Äô</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="pf-teaser sec-light" data-theme="light" aria-label="Portfolio">
      <div class="section-inner">
        <div class="pf-head">
