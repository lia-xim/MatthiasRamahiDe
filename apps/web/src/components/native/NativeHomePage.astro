        </div>
        <div class="services-list">
          {homeServices.map((service) => (
            <a class="service-row" href={service.href}>
              <span class="num">{service.number}</span><h3>{service.title}</h3><p>{service.text}</p><span class="arr">Detail √¢‚ÄÝ‚Äô</span>
            </a>
          ))}
        </div>
        <div style="margin-top:32px;display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:center">
          <span style="font:10px var(--mono);letter-spacing:.22em;text-transform:uppercase;color:var(--quiet-l)">07 Bereiche √Ç¬∑ ein Netzwerk</span>
