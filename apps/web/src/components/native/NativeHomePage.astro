const firstHeroSlide = heroSlides[0]
const heroImages = heroSlides.map((slide) => slide.image)
const heroSlidesJson = JSON.stringify(heroSlides)
const statementParagraphs = blockParagraphs(doc, 'Bilder', [
  'Seit √É¬ºber zehn Jahren entstehen meine Serien im Spannungsfeld von Pr√É¬§zision und Atmosph√É¬§re √¢‚Ç¨‚Äù Automobile, Oldtimer, Sportwagen, Motorr√É¬§der, Portraits und Landschaften. Jede Arbeit folgt einer ruhigen redaktionellen Logik: Licht, Komposition, Material, Zeit.',
  'Auftraggeber sind Marken, Sammler, Manufakturen und private Eigent√É¬ºmer aus D√É¬ºsseldorf, K√É¬∂ln, Essen, Dortmund und dem gesamten Rheinland √¢‚Ç¨‚Äù √É¬ºberall dort, wo Bilder √É¬ºber Auflage, Sammlung oder Markenwert mitentscheiden.',
])
const chaptersParagraphs = blockParagraphs(doc, 'Sechs Bereiche', [
  'Jeder Bereich hat eine eigene visuelle Logik √¢‚Ç¨‚Äù Bewegung, Material, Mensch, Raum. Ausw√É¬§hlen, weiterlesen, eine Serie sehen.',
])
const portfolioParagraphs = blockParagraphs(doc, 'Ausgew√É¬§hlte', [
  'Ein Strom aus aktuellen Serien √¢‚Ç¨‚Äù kontinuierlich in Bewegung. Klick auf ein Bild √É¬∂ffnet die Vorschau.',
])
const aboutParagraphs = blockParagraphs(doc, 'Hinter der Kamera', [
  'Ausgebildet im Handwerk, denkend wie ein Editor √¢‚Ç¨‚Äù ich arbeite ruhig, pr√É¬§zise und in engem Dialog mit dem Auftraggeber. Vom ersten Briefing bis zum finalen Druck.',
  'Meine Location steht in D√É¬ºsseldorf, mein Netzwerk im gesamten Rheinland. Ich begleite Marken, Manufakturen, Sammler und private Eigent√É¬ºmer dort, wo ein Bild √É¬ºber Auflage, Sammlung oder Markenwert mitentscheidet.',
])
const servicesParagraphs = blockParagraphs(doc, 'Weitere Leistungen', [
  'F√É¬ºr Projekte, die √É¬ºber die Fotografie hinausgehen √¢‚Ç¨‚Äù Druck, Gro√É≈∏format, Werbetechnik, Webdesign, Video, Sonderanfertigungen und Musik. Kuratiert, koordiniert, ein Ansprechpartner.',
])
---
<AdoptedPageLayout legacyFile="index.html" current="home" doc={doc} ctaHref="#anfrage" preloadImages={[firstHeroSlide.image]} liveCms>
  <main>
    <section class="hero" data-theme="dark" aria-label="Intro" style={`background-image:url("${firstHeroSlide.image}")`}>
      <canvas id="hero-shader" aria-hidden="true" data-imgs={heroImages.join(',')} data-slides={heroSlidesJson}></canvas>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-aperture" aria-hidden="true"></div>
      <div class="hero-grid">
        <div class="hero-stage">
          <h1 class="hero-title" id="hero-title" data-text-idx="0">
            {firstHeroSlide.titleLines.map((line) => (
              <span class="line"><span class="word">{line}</span></span>
            ))}
          </h1>
          <p class="hero-lead" id="hero-lead">{firstHeroSlide.lead}</p>
          <div class="hero-actions" aria-label="Direkte Aktionen">
            <a class="btn dark" href={firstHeroSlide.primaryHref} data-hero-primary hidden={!firstHeroSlide.primaryHref || !firstHeroSlide.primaryLabel}>{firstHeroSlide.primaryLabel}</a>
            <a class="btn" href={firstHeroSlide.secondaryHref} data-hero-secondary hidden={!firstHeroSlide.secondaryHref || !firstHeroSlide.secondaryLabel}>{firstHeroSlide.secondaryLabel}</a>
