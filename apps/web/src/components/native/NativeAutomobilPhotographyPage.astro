---
import AdoptedPageLayout from '../../layouts/AdoptedPageLayout.astro'
import NativeFamilyClusterLinks from './NativeFamilyClusterLinks.astro'
import PreviewToolbar from '../PreviewToolbar.astro'
import {
  localSeoFamilyContent,
  scopeFromSlug,
  serviceLabelFromSlug,
  siblingFamilyLinks,
} from '../../lib/localSeoFamilyContent'
import { familyVisualSlots, getFamilyVisualSourceDoc } from '../../lib/localSeoFamilyVisuals'
import { getLegacyBackedDoc, routeForDoc, type PayloadDoc } from '../../lib/payload'

type PreviewState = {
  collection: string
  publishedHref: string
  slug: string
  status?: string
}

type Props = {
  doc?: PayloadDoc | null
  legacyFile?: string
  preview?: PreviewState
  visualDoc?: PayloadDoc | null
}

const defaultLegacyFile = 'automobil-fotografie.html'
const props = Astro.props as Props
const { doc: providedDoc = undefined, legacyFile: providedLegacyFile, preview, visualDoc: providedVisualDoc = undefined } = props
const legacyFile = providedLegacyFile || defaultLegacyFile
const doc = providedDoc || (await getLegacyBackedDoc(legacyFile, { depth: 2 }))
const shouldUseCmsVisualDoc = Boolean(preview) || import.meta.env.ASTRO_ENABLE_CMS_VISUAL_OVERRIDES === 'true'
const visualDoc = Object.hasOwn(props, 'visualDoc')
  ? providedVisualDoc
  : shouldUseCmsVisualDoc
    ? await getFamilyVisualSourceDoc('automobil', doc, legacyFile, defaultLegacyFile)
    : null
const familyContent = localSeoFamilyContent.automobil
const scope = scopeFromSlug(legacyFile)
const isParentPage = legacyFile === defaultLegacyFile
const isKeywordPage = scope.generic
const serviceLabel = serviceLabelFromSlug(legacyFile, familyContent)
const localSuffix = !isParentPage && !isKeywordPage ? ` ${scope.label}` : ''
const heroSecondLine = `Fotografie${localSuffix}.`
const heroLabel = isParentPage ? 'Automobilfotografie' : `Automobilfotografie${localSuffix}`
const heroLead = isParentPage
  ? 'Automobilfotografie: Exterieur, Interieur, Details und Cinematic werden als kuratierte Bildserie geplant - für Marke, Showroom, Verkauf, Kampagne und hochwertige private Fahrzeuge. Produktionen werden über Motiv, Nutzung, Reise, Lichtfenster und Output geplant; Düsseldorf bleibt der organisatorische Ausgangspunkt.'
  : isKeywordPage
    ? `${serviceLabel}: eigenständiger Einstieg in den Automobil Fotografie-Cluster. Exterieur, Interieur, Details und Cinematic werden als kuratierte Serie geplant - für Marke, Showroom, Verkauf, Kampagne und hochwertige private Fahrzeuge. Die Seite bleibt bewusst im Layout der übergeordneten Kategorie, setzt den Text aber auf diese konkrete Suchintention.`
    : `Automobilfotografie in ${scope.label}: Exterieur, Interieur, Details und Cinematic werden als kuratierte Bildserie geplant - für Marke, Showroom, Verkauf, Kampagne und hochwertige private Fahrzeuge. ${scope.label} wird als lokaler Suchraum mit klarer Planung, passendem Lichtfenster und sauberer Nutzung der Bildserie geführt.`
const metaTitle = isParentPage
  ? 'Automobilfotografie | Matthias Ramahi'
  : isKeywordPage
    ? `${serviceLabel} | Matthias Ramahi`
    : `${serviceLabel} ${scope.label} | Matthias Ramahi`
const metaDescription = isParentPage
  ? 'Automobilfotografie fuer Exterieur, Interieur, Details und Kampagne in Duesseldorf und NRW. Bildserien fuer Verkauf, Marke, Showroom und hochwertige private Fahrzeuge.'
  : isKeywordPage
    ? `${serviceLabel} fuer Fahrzeuge, Marken, Showrooms und Verkauf. Exterieur, Interieur, Details und Cinematic werden als nutzbare Bildserie geplant.`
    : `${serviceLabel} in ${scope.label}: Exterieur, Interieur, Details und Cinematic als kuratierte Bildserie fuer Verkauf, Marke, Showroom und Kampagne.`
const contactSubject = isParentPage ? 'Automobil Fotografie Anfrage' : `${serviceLabel}${isKeywordPage ? '' : ` ${scope.label}`} Anfrage`
const contactHeadline = isParentPage
  ? 'Automobil &lt;em&gt;anfragen.&lt;/em&gt;'
  : isKeywordPage
    ? `${serviceLabel} &lt;em&gt;anfragen.&lt;/em&gt;`
    : `Automobil ${scope.label} &lt;em&gt;anfragen.&lt;/em&gt;`
const contactLead = isParentPage
  ? 'Schreibe kurz, welches Fahrzeug fotografiert werden soll, wo es steht, welche Wirkung die Bilder tragen sollen und ob die Serie privat, kommerziell oder als Kampagne genutzt wird. Wir klären Location, Licht und Ablauf gemeinsam vor dem ersten Klick.'
  : isKeywordPage
    ? `Schreibe kurz, wofür ${serviceLabel} gebraucht wird, welches Motiv im Mittelpunkt steht und welche Nutzung geplant ist. Wir klären Stil, Ort, Umfang und Ausgabe gemeinsam.`
    : `Schreibe kurz, welches Fahrzeug in ${scope.label} fotografiert werden soll, wo es steht, welche Wirkung die Bilder tragen sollen und ob die Serie privat, kommerziell oder als Kampagne genutzt wird. Wir klären Location, Licht und Ablauf gemeinsam vor dem ersten Klick.`
const cityHeading = isParentPage ? 'Automobil Fotografie <em>vor Ort.</em>' : `Automobilfotografie <em>vor Ort in ${scope.label}.</em>`
const clusterHeading = `Weitere Fotografie-Bereiche <em>${scope.label}.</em>`
const clusterLinks = siblingFamilyLinks(scope, 'automobil')
const overviewHref = 'fotografie-duesseldorf.html'
const publishedHref = preview?.publishedHref || (doc ? routeForDoc('local-seo-pages', doc) : `/${legacyFile}`)
const heroDevelopInitial = 'assets/optimized/mpjpgo2b-dsc3032-generase-1-1920.webp'
const heroDevelopInitialMobile = 'assets/optimized/mpjpgo2b-dsc3032-generase-1-1280.webp'

const switchFrames = [
  {
    image: 'assets/optimized/assets-portfolio-dsc3879-1920.webp',
    label: 'Exterieur',
  },
  {
    image: 'assets/optimized/assets-portfolio-dsc2986-1920.webp',
    label: 'Interieur',
  },
  {
    image: 'assets/optimized/assets-portfolio-dsc3892-1920.webp',
    label: 'Details',
  },
  {
    image: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp',
    label: 'Cinematic',
  },
]

const galleryTiles = [
  {
    className: 'bg-t-hero',
    src: 'assets/portfolio/thumbs/_DSC3879.webp',
    full: 'assets/optimized/assets-portfolio-dsc3879-1920.webp',
    alt: 'Ferrari F12 Berlinetta in Düsseldorfer Ausstellungsraum — Automobilfotografie',
    width: 720,
    height: 480,
    left: '01 · Showroom',
    right: 'Düsseldorf · 2025',
  },
  {
    className: 'bg-t-a',
    src: 'assets/portfolio/thumbs/_DSC9301-Enhanced-NR.webp',
    full: 'assets/portfolio/_DSC9301-Enhanced-NR.webp',
    alt: 'Sportwagen-Cockpit mit Leder und Carbon — Interieur',
    width: 720,
    height: 900,
    left: '02 · Cockpit',
    right: 'Fotograf',
  },
  {
    className: 'bg-t-b',
    src: 'assets/portfolio/thumbs/_DSC3892.webp',
    full: 'assets/optimized/assets-portfolio-dsc3892-1920.webp',
    alt: 'Detail von Lack und Sicke an einem Automobil',
    width: 720,
    height: 480,
    left: '03 · Detail',
    right: 'NRW',
  },
  {
    className: 'bg-t-c',
    src: 'assets/portfolio/thumbs/_DSC3982.webp',
    full: 'assets/optimized/assets-portfolio-dsc3982-1920.webp',
    alt: 'Cineastische Automobilaufnahme bei Nacht',
    width: 720,
    height: 480,
    left: '04 · Night',
    right: 'Editorial',
  },
  {
    className: 'bg-t-d',
    src: 'assets/portfolio/thumbs/_DSC2316.webp',
    full: 'assets/optimized/assets-portfolio-dsc2316-1920.webp',
    alt: 'Automobil-Detail in Architektur',
    width: 720,
    height: 450,
    left: '05 · Lines',
    right: 'Architektur',
  },
  {
    className: 'bg-t-e',
    src: 'assets/portfolio/thumbs/_DSC2310.webp',
    full: 'assets/optimized/assets-portfolio-dsc2310-1920.webp',
    alt: 'Automobil — Showroom-Tiefschwarz',
    width: 720,
    height: 480,
    left: '06 · Black',
    right: 'Hall',
  },
  {
    className: 'bg-t-f',
    src: 'assets/portfolio/thumbs/_DSC3032_genErase (1).webp',
    full: 'assets/optimized/assets-portfolio-dsc3032-generase-1-1920.webp',
    alt: 'Cineastische Aufnahme — Automobil in Bewegung',
    width: 720,
    height: 480,
    left: '07 · Motion',
    right: 'Rheinland',
  },
  {
    className: 'bg-t-g',
    src: 'assets/portfolio/thumbs/_DSC6982.webp',
    full: 'assets/optimized/assets-portfolio-dsc6982-1920.webp',
    alt: 'Automobil — Editorial-Frame im Tageslicht',
    width: 720,
    height: 1080,
    left: '08 · Daylight',
    right: 'Editorial',
  },
  {
    className: 'bg-t-h',
    src: 'assets/portfolio/thumbs/_DSC8032.webp',
    full: 'assets/optimized/assets-portfolio-dsc8032-1920.webp',
    alt: 'Automobil — Detail-Komposition',
    width: 720,
    height: 900,
    left: '09 · Frame',
    right: 'Fotograf',
  },
]

const audiences = [
  ['01', 'Privatkund·innen', 'Privat · Geschenk'],
  ['02', 'Hersteller & Marken', 'Kampagne · CI'],
  ['03', 'Autohäuser & Händler', 'Showroom · Serie'],
  ['04', 'Clubs & Redaktionen', 'Magazin · Editorial'],
  ['05', 'Sammler & Besitzer', 'Edition · Archiv'],
]

const relatedAreas = [
  {
    href: 'sportwagen-fotografie.html',
    image: 'assets/portfolio/thumbs/_DSC3982.webp',
    alt: 'Sportwagenfotografie',
    width: 720,
    height: 480,
    meta: '01 / Verwandt',
    title: 'Sportwagen',
  },
  {
    href: 'oldtimer-fotografie.html',
    image: 'assets/optimized/assets-photos-oldtimer-stage-1920.webp',
    alt: 'Oldtimerfotografie',
    width: 1920,
    height: 1280,
    meta: '02 / Verwandt',
    title: 'Oldtimer',
  },
  {
    href: 'motorrad-fotografie.html',
    image: 'assets/optimized/assets-photos-motorrad-1920.webp',
    alt: 'Motorradfotografie',
    width: 1707,
    height: 2560,
    meta: '03 / Verwandt',
    title: 'Motorrad',
  },
  {
    href: 'portfolio.html',
    image: 'assets/portfolio/thumbs/_DSC3879.webp',
    alt: 'Vollständiges Portfolio',
    width: 720,
    height: 480,
    meta: '04 / Übersicht',
    title: 'Portfolio',
  },
]

const visualSlots = familyVisualSlots(visualDoc, [
  { alt: 'Automobil Hero', mobile: heroDevelopInitialMobile, src: heroDevelopInitial },
  ...switchFrames.map(({ image, label }) => ({ alt: `Automobil ${label}`, src: image })),
  ...galleryTiles.map(({ alt, full, height, src, width }) => ({ alt, full, height, src, width })),
  ...relatedAreas.map(({ alt, height, image, width }) => ({ alt, height, src: image, width })),
])
const inheritedHeroDevelopInitial = visualSlots[0].cssFull
const inheritedHeroDevelopInitialMobile = visualSlots[0].cssMobile
const inheritedSwitchFrames = switchFrames.map((frame, index) => ({
  ...frame,
  image: visualSlots[index + 1].full,
}))
const inheritedGalleryTiles = galleryTiles.map((tile, index) => {
  const visual = visualSlots[index + 1 + switchFrames.length]
  return { ...tile, alt: visual.alt, full: visual.full, height: visual.height, src: visual.src, width: visual.width }
})
const inheritedRelatedAreas = relatedAreas.map((area, index) => {
  const visual = visualSlots[index + 1 + switchFrames.length + galleryTiles.length]
  return { ...area, alt: visual.alt, height: visual.height, image: visual.src, width: visual.width }
})

const cityLinks = [
  ['automobil-fotografie.html', 'Düsseldorf'],
  ['automobil-fotografie-koeln.html', 'Köln'],
  ['automobil-fotografie-essen.html', 'Essen'],
  ['automobil-fotografie-dortmund.html', 'Dortmund'],
  ['automobil-fotografie-duisburg.html', 'Duisburg'],
  ['automobil-fotografie-bochum.html', 'Bochum'],
  ['automobil-fotografie-wuppertal.html', 'Wuppertal'],
  ['automobil-fotografie-leverkusen.html', 'Leverkusen'],
  ['automobil-fotografie-oberhausen.html', 'Oberhausen'],
  ['automobil-fotografie-krefeld.html', 'Krefeld'],
  ['automobil-fotografie-moenchengladbach.html', 'Mönchengladbach'],
  ['automobil-fotografie-moers.html', 'Moers'],
  ['automobil-fotografie-gelsenkirchen.html', 'Gelsenkirchen'],
  ['automobil-fotografie-bergisch-gladbach.html', 'Bergisch Gladbach'],
  ['automobil-fotografie-solingen.html', 'Solingen'],
  ['automobil-fotografie-remscheid.html', 'Remscheid'],
  ['automobil-fotografie-mettmann.html', 'Mettmann'],
  ['automobil-fotografie-hilden.html', 'Hilden'],
  ['automobil-fotografie-dormagen.html', 'Dormagen'],
  ['automobil-fotografie-neuss.html', 'Neuss'],
  ['automobil-fotografie-nrw.html', 'NRW'],
  ['automobil-fotografie-deutschland.html', 'Deutschland'],
]

const searchLinks = [
  ['automotive-fotografie.html', 'Automotive Fotografie'],
  ['autofotografie.html', 'Autofotografie'],
  ['fahrzeugfotografie.html', 'Fahrzeugfotografie'],
  ['autohaus-fotografie.html', 'Autohaus Fotografie'],
  ['autoverkauf-fotos-duesseldorf.html', 'Autoverkauf Fotos'],
]
---
<AdoptedPageLayout
  legacyFile={legacyFile}
  current="fotografie"
  doc={doc}
  noIndex={Boolean(preview)}
  title={metaTitle}
  description={metaDescription}
  ogImage={visualSlots[0].full}
>
  {preview && (
    <PreviewToolbar
      collection={preview.collection}
      slug={preview.slug}
      status={preview.status}
      publishedHref={publishedHref}
    />
  )}
  <main>
    <section class="hero-pd" id="top" data-header-theme="dark" aria-label={heroLabel}>
      <div class="pd-stage" aria-hidden="true">
        <div class="pd-frame is-in" id="pdFrameA" style="--cx:50%;--cy:50%">
          <div
            class="pd-frame-inner"
            style={`--pd-bg-mobile:url('${inheritedHeroDevelopInitialMobile}');--pd-bg-desktop:url('${inheritedHeroDevelopInitial}')`}
          ></div>
        </div>
        <div class="pd-frame" id="pdFrameB"><div class="pd-frame-inner"></div></div>
      </div>
      <div class="pd-paper" aria-hidden="true"></div>
      <div class="pd-glow" aria-hidden="true"></div>
      <div class="pd-streak" aria-hidden="true"></div>
      <div class="pd-flare pd-flare-2" aria-hidden="true"></div>
      <div class="pd-vignette" aria-hidden="true"></div>
      <div class="pd-grain" aria-hidden="true"></div>
      <div class="pd-overlay">
        <div class="pd-bottom">
          <h1 class="pd-title">
            <span class="line"><span class="word">Automobil</span></span>
            <span class="line"><span class="word">{heroSecondLine}</span></span>
          </h1>
          <p class="pd-sub">{doc?.intro || heroLead}</p>
          <div class="pd-actions">
            <a href="#anfrage">Shooting buchen →</a>
            <a class="ghost" href="portfolio.html">Portfolio</a>
          </div>
        </div>
      </div>
    </section>

    <section class="st-pull" data-header-theme="light">
      <div class="st-pull-inner">
        <blockquote class="st-pull-quote">
          <strong>Vom Inserat bis zur <span class="accent">Kampagne.</span></strong>
        </blockquote>
        <div class="st-pull-foot">
          <div class="col">
            <span>01 · Verkauf</span>
            <p>Klare, nachvollziehbare Ansichten. Lack, Innenraum und Zustand ehrlich und repräsentativ — web-fertige Dateien für Inserate und Portale.</p>
          </div>
          <div class="col">
            <span>02 · Editorial</span>
            <p>Bildsprache mit Charakter. Lack, Linien und Proportionen werden inszeniert statt nur dokumentiert — für Magazin, Print und Marken-Stories.</p>
          </div>
          <div class="col">
            <span>03 · Kampagne</span>
            <p>Hochformate, Teaser, Banner. Konsistente Licht-Atmosphäre über die ganze Serie — direkt einsatzbereit für Social und Web-Ads.</p>
          </div>
        </div>
        <div class="st-pull-cta">
          <a href="#anfrage">Shooting buchen <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section class="sw" id="sichten" data-header-theme="dark">
      <header class="sw-head">
        <div class="ttl">
          <h2>Ein Bildsatz, <em>vier Blickwinkel.</em></h2>
        </div>
      </header>

      <div class="sw-body">
        <nav class="sw-tabs" role="tablist" aria-label="Bildkategorien">
          {inheritedSwitchFrames.map((frame, index) => (
            <button class="sw-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-cat={index}>
              <span class="lbl">{frame.label}</span>
            </button>
          ))}
        </nav>

        <div class="sw-stage" id="swStage" role="region" aria-live="polite">
          {inheritedSwitchFrames.map((frame, index) => (
            <div
              class={`frame${index === 0 ? ' is-active' : ''}`}
              data-frame={index}
              style={`background-image:url('${frame.image}')`}
            />
          ))}
          <div class="vignette"></div>
          <div class="grain"></div>
        </div>

        <aside class="sw-desc" id="swDesc">
          <div class="group g2 is-in"><h3 class="d-title" id="swTitle">Vollformat, ruhige Linien.</h3></div>
          <div class="group g3 is-in"><p class="d-body" id="swBody">Außenaufnahmen mit kontrolliertem Licht und ruhigen Reflexen. Lack, Proportionen und Linienführung wirken stimmig — Showroom, Industrie oder urbanes Setting.</p></div>
          <div class="group g4 is-in"><ul class="d-list" id="swList"><li>Showroom &amp; Location</li><li>Architektur &amp; Industrie</li><li>Tages- und Nachtlicht</li></ul></div>
          <div class="group g4 is-in"><a class="d-cta" href="#anfrage">Bildsatz anfragen</a></div>
        </aside>
      </div>

      <div class="sw-progress" id="swProgress"><div class="rail"><div class="fill" id="swFill"></div></div></div>
    </section>

    <section class="bg" data-header-theme="dark" aria-label="Ausgewählte Automobil-Arbeiten" id="bgSec">
      <div class="bg-head">
        <div class="ttl">
          <span class="kicker">Auswahl · Bildsatz</span>
          <h2>Aktuelle <em>Arbeiten.</em></h2>
        </div>
        <div class="meta">
          <span>09 Frames</span>
          <a href="portfolio.html">Mehr als 240 Arbeiten im Portfolio →</a>
        </div>
      </div>

      <div class="bg-grid" id="bgGrid">
        {inheritedGalleryTiles.map((tile, index) => (
          <button type="button" class={`bg-tile ${tile.className}`} data-i={index} data-full={tile.full} aria-label={`Frame ${index + 1} vergrößern`}>
            <img loading="lazy" src={tile.src} alt={tile.alt} width={tile.width} height={tile.height} decoding="async" />
            <div class="bg-cap"><span class="l">{tile.left}</span><span class="r">{tile.right}</span></div>
          </button>
        ))}
      </div>
    </section>

    <section class="ki" data-header-theme="light" aria-label="Für wen ich arbeite">
      <div class="section-inner">
        <div class="ki-head">
          <h2>Für <em>wen</em> ich arbeite.</h2>
        </div>

        <div class="ki-grid">
          {audiences.map(([number, title, label]) => (
            <a href="#anfrage" class="ki-card">
              <span class="no">{number}</span>
              <h3>{title}</h3>
              <span class="lbl">{label}</span>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
        <div class="ki-cta">
          <p>Du erkennst dich wieder? <a href="#anfrage">Lass uns sprechen <span aria-hidden="true">→</span></a></p>
        </div>
      </div>
    </section>

    <section class="rl" data-header-theme="dark">
      <div class="section-inner">
        <div class="rl-head">
          <h2>Verwandte <em>Bereiche</em>.</h2>
          <p>Automobil ist die Klammer. Schau dir die spezialisierten Disziplinen an — gleicher Anspruch, anderer Bildfokus. Diese Kategorie ist Teil eines bewusst getrennten Fotografie-Clusters: Fahrzeug, Mensch und Raum bleiben eigenständige Suchintentionen, sind aber intern so verbunden, dass Nutzer schnell in den passenden Bildbereich wechseln können.</p>
        </div>
        <div class="rl-grid">
          {inheritedRelatedAreas.map((area) => (
            <a class="rl-card" href={area.href}>
              <img loading="lazy" src={area.image} alt={area.alt} width={area.width} height={area.height} decoding="async" />
              <div class="overlay"></div>
              <div class="content"><div><span>{area.meta}</span><strong>{area.title}</strong></div><span class="arrow">→</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {!isParentPage && (
      <NativeFamilyClusterLinks
        clusterHeading={clusterHeading}
        clusterLinks={clusterLinks}
        overviewHref={overviewHref}
        scopeLabel={scope.label}
      />
    )}

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Automobil Fotografie in NRW">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2 set:html={cityHeading}></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Städte">
          {cityLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section class="mr-cities" data-header-theme="light" data-theme="light" aria-label="Automobil Fotografie Suchbegriffe">
      <div class="mr-cities__inner">
        <div class="mr-cities__head">
          <h2>Automobil Fotografie <em>Suchbegriffe.</em></h2>
        </div>
        <nav class="mr-cities__grid" aria-label="Suchvarianten">
          {searchLinks.map(([href, label]) => <a class="mr-cities__cell" href={href}>{label}</a>)}
        </nav>
      </div>
    </section>

    <section
      id="anfrage"
      data-contact-section
      data-header-theme="light"
      data-contact-subject={contactSubject}
      data-contact-headline={contactHeadline}
      data-contact-lead={contactLead}
    />
  </main>
</AdoptedPageLayout>
