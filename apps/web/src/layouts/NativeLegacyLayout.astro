---
import fs from 'node:fs/promises'
import path from 'node:path'

import LegacyFooter from '../components/legacy/LegacyFooter.astro'
import LegacyHeader from '../components/legacy/LegacyHeader.astro'
import { getComponentizedLegacyParts, getLegacyHomeParts } from '../lib/legacyParts'
import { imageUrl, routeForDoc, toAbsoluteSiteUrl, type PayloadDoc, type PayloadMedia } from '../lib/payload'

type Props = {
  bodyClass?: string
  current?: string
  doc?: PayloadDoc | null
  headerTheme?: string
  legacyFile: string
}

const {
  bodyClass: providedBodyClass,
  current: providedCurrent,
  doc = null,
  headerTheme: providedHeaderTheme,
  legacyFile,
} = Astro.props as Props
const isHome = legacyFile === 'index.html'
const legacyParts = isHome ? null : await getComponentizedLegacyParts(legacyFile)
const homeParts = isHome ? await getLegacyHomeParts() : null
let head = withCmsSeo(homeParts?.head || legacyParts?.head || '', doc, legacyFile)
head = withFavicons(head)
head = isHome ? await withHomeCriticalCss(head) : stripHomeCriticalCss(head)
const bodyClass = providedBodyClass || legacyParts?.bodyClass || 'has-mr-footer'
const current = providedCurrent || legacyParts?.current
const headerTheme = providedHeaderTheme || legacyParts?.headerTheme
const afterFooter = homeParts?.afterFooter || legacyParts?.afterFooter || ''

Astro.response.headers.set('x-cms-render-source', 'structured-astro')
Astro.response.headers.set('x-cms-migration-status', 'native-component')

function escapeAttribute(value: string) {
  return value
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
}

function upsertTitle(headHtml: string, title?: string) {
  if (!title) return headHtml
  const tag = `<title>${escapeAttribute(title)}</title>`
  return /<title[^>]*>[\s\S]*?<\/title>/i.test(headHtml)
    ? headHtml.replace(/<title[^>]*>[\s\S]*?<\/title>/i, tag)
    : `${headHtml}\n${tag}`
}

function upsertMeta(headHtml: string, selector: string, value?: string) {
  if (!value) return headHtml
  const escaped = escapeAttribute(value)
  const [kind, name] = selector.split(':')
  const attrName = kind === 'property' ? 'property' : 'name'
  const pattern = new RegExp(`<meta\\s+${attrName}=["']${name}["'][^>]*>`, 'i')
  const tag = `<meta ${attrName}="${name}" content="${escaped}" />`
  return pattern.test(headHtml) ? headHtml.replace(pattern, tag) : `${headHtml}\n${tag}`
}

function upsertCanonical(headHtml: string, value?: string) {
  if (!value) return headHtml
  const tag = `<link rel="canonical" href="${escapeAttribute(value)}" />`
  return /<link\s+rel=["']canonical["'][^>]*>/i.test(headHtml)
    ? headHtml.replace(/<link\s+rel=["']canonical["'][^>]*>/i, tag)
    : `${headHtml}\n${tag}`
}

function withFavicons(headHtml: string) {
  const cleaned = headHtml.replace(
    /<link\s+[^>]*rel=["'](?:icon|apple-touch-icon|manifest)["'][^>]*>\s*/gi,
    '',
  )

  return `${cleaned}
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />`
}

function withCmsSeo(headHtml: string, pageDoc: PayloadDoc | null, pageLegacyFile: string) {
  if (!pageDoc?.seo) return headHtml

  const seoTitle = pageDoc.seo.title || pageDoc.title
  const description = pageDoc.seo.description || pageDoc.excerpt || pageDoc.intro
  const canonical = toAbsoluteSiteUrl(pageDoc.seo.canonicalUrl || (pageDoc.slug ? routeForDoc('site-pages', pageDoc) : pageLegacyFile))
  const socialImage = imageUrl(
    (pageDoc.seo.ogImage || pageDoc.coverImage || pageDoc.heroImage || pageDoc.teaserImage) as PayloadMedia | string | undefined,
    'hero',
  )

  let nextHead = upsertTitle(headHtml, seoTitle)
  nextHead = upsertMeta(nextHead, 'name:description', description)
  nextHead = upsertCanonical(nextHead, canonical)
  nextHead = upsertMeta(nextHead, 'property:og:title', seoTitle)
  nextHead = upsertMeta(nextHead, 'property:og:description', description)
  nextHead = upsertMeta(nextHead, 'property:og:url', canonical)
  nextHead = upsertMeta(nextHead, 'name:twitter:title', seoTitle)
  nextHead = upsertMeta(nextHead, 'name:twitter:description', description)
  if (socialImage) {
    nextHead = upsertMeta(nextHead, 'property:og:image', socialImage)
    nextHead = upsertMeta(nextHead, 'name:twitter:image', socialImage)
  }
  if (pageDoc.seo.noIndex) nextHead = upsertMeta(nextHead, 'name:robots', 'noindex,nofollow')

  return nextHead
}

function stripHomeCriticalCss(headHtml: string) {
  return headHtml.replace(/\s*<style\b[^>]*data-critical=["']home["'][^>]*>[\s\S]*?<\/style>\s*/i, '\n')
}

function minifyCriticalCss(css: string) {
  return css
    .replace(/\/\*[\s\S]*?\*\//g, '')
    .replace(/\s+/g, ' ')
    .replace(/\s*([{}:;,>])\s*/g, '$1')
    .replace(/;}/g, '}')
    .trim()
}

async function withHomeCriticalCss(headHtml: string) {
  const cleaned = stripHomeCriticalCss(headHtml)
  const css = minifyCriticalCss(await readPublicCss('assets/critical-home.css'))
  if (!css) return cleaned

  const criticalTag = `<style data-critical="home">${css}</style>`
  const stylesheetMatch = cleaned.match(/<link\b[^>]*rel=["']stylesheet["'][^>]*>/i)
  if (stylesheetMatch?.index === undefined) return `${cleaned}\n${criticalTag}`

  return `${cleaned.slice(0, stylesheetMatch.index)}${criticalTag}\n${cleaned.slice(stylesheetMatch.index)}`
}

const restoreCssCache = new Map<string, Promise<string>>()

function criticalLegacyRulesFrom(css: string) {
  return [
    ...css.matchAll(/:root\s*\{[\s\S]*?\}/gi),
    ...css.matchAll(/html\s*,\s*body\s*\{[\s\S]*?\}/gi),
  ]
    .map((match) => match[0])
    .join('\n')
}

function stylesheetHrefsFrom(headHtml: string) {
  return [...headHtml.matchAll(/<link\b[^>]*rel=["']stylesheet["'][^>]*href=["']([^"']+\.css(?:\?[^"']*)?)["'][^>]*>/gi)]
    .map((match) => match[1])
    .filter((href) => /(?:^|\/)assets\/legacy-|(?:^|\/)assets\/site-chrome\.css|(?:^|\/)assets\/photo-main-service\.css/.test(href))
}

async function readPublicCss(href: string) {
  const cleanHref = href.replace(/^\/+/, '').split('?')[0]
  if (!cleanHref.startsWith('assets/') || !cleanHref.endsWith('.css')) return ''

  const publicPath = path.join(process.cwd(), 'public', cleanHref)
  const workspacePath = path.resolve(process.cwd(), '..', '..', cleanHref)
  try {
    return await fs.readFile(publicPath, 'utf8')
  } catch {
    try {
      return await fs.readFile(workspacePath, 'utf8')
    } catch {
      return ''
    }
  }
}

async function restoreLegacyCascadeCss(headHtml: string) {
  const cacheKey = `cascade-v3:${headHtml}`
  const cached = restoreCssCache.get(cacheKey)
  if (cached) return cached

  const read = (async () => {
    const inlineRules = criticalLegacyRulesFrom(headHtml)
    const linkedRules = await Promise.all(
      stylesheetHrefsFrom(headHtml).map(async (href) => criticalLegacyRulesFrom(await readPublicCss(href))),
    )

    const rules = [inlineRules, ...linkedRules].filter(Boolean).join('\n')
    return /--accent\s*:/.test(rules) ? rules : `${rules}\n:root{--accent:#c8ccc6;}`
  })()

  restoreCssCache.set(cacheKey, read)
  return read
}

const legacyCascadeRestoreCss = isHome ? '' : await restoreLegacyCascadeCss(head)
---
<!doctype html>
<html lang="de">
  <head>
    <Fragment set:html={head} />
  </head>
  <body class={bodyClass}>
    {legacyCascadeRestoreCss && <style is:inline set:html={legacyCascadeRestoreCss} />}
    <LegacyHeader current={current} ctaHref={isHome ? '#anfrage' : undefined} headerTheme={headerTheme} />
    <slot />
    <LegacyFooter />
    <Fragment set:html={afterFooter} />
  </body>
</html>
