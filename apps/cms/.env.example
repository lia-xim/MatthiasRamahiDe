# Payload CMS
PAYLOAD_SECRET=change-me-use-a-long-random-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
# Extra comma-separated origins for media/API CORS, e.g. Vercel preview URLs.
PAYLOAD_CORS_ORIGINS=

# Production/staging target: Postgres
PAYLOAD_DB=postgres
PAYLOAD_DB_PUSH=false
DATABASE_URI=

# Local no-Docker demo option:
# PAYLOAD_DB=sqlite
# DATABASE_URL=file:./payload-dev.db
# For Postgres, set DATABASE_URI locally or in your host's secret store. Do not commit a real value.
# Set PAYLOAD_DB_PUSH=true only for a fresh local schema bootstrap, then switch back to false.

# Astro preview + rebuild integration
ASTRO_PREVIEW_URL=http://localhost:4321
ASTRO_PUBLIC_SITE_URL=https://matthiasramahi.de
PREVIEW_SECRET=change-me-preview-secret
ASTRO_REBUILD_WEBHOOK_URL=
ASTRO_REBUILD_WEBHOOK_SECRET=

# Payload transactional email via Resend. Leave RESEND_API_KEY empty locally if
# you want Payload to write email to the console instead.
RESEND_API_KEY=
PAYLOAD_EMAIL_FROM_ADDRESS=anfrage@matthiasramahi.de
PAYLOAD_EMAIL_FROM_NAME=Matthias Ramahi CMS

# Optional SEO suggestion harness.
# OpenAI-compatible endpoint:
SEO_LLM_BASE_URL=
SEO_LLM_API_KEY=
SEO_LLM_MODEL=
# Or local command that reads the prompt from stdin and returns JSON.
SEO_LLM_COMMAND=
SEO_LLM_ARGS=[]

# Optional S3-compatible media storage, e.g. Cloudflare R2 or Hetzner Object Storage
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
