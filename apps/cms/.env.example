# Payload CMS
PAYLOAD_SECRET=change-me-use-a-long-random-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Production/staging target: Postgres
PAYLOAD_DB=postgres
DATABASE_URI=postgres://payload:payload-local-password@localhost:5432/matthias_ramahi_cms

# Local no-Docker demo option:
# PAYLOAD_DB=sqlite
# DATABASE_URL=file:./payload-dev.db

# Astro preview + rebuild integration
ASTRO_PREVIEW_URL=http://localhost:4321
ASTRO_PUBLIC_SITE_URL=https://matthiasramahi.de
PREVIEW_SECRET=change-me-preview-secret
ASTRO_REBUILD_WEBHOOK_URL=
ASTRO_REBUILD_WEBHOOK_SECRET=

# Optional S3-compatible media storage, e.g. Cloudflare R2 or Hetzner Object Storage
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
