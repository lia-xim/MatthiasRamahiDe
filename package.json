{
  "name": "matthias-ramahi-astro-payload-stack",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "corepack pnpm web:build && corepack pnpm cms:build",
    "seo:audit": "node tools/seo-audit.mjs --target=apps/web/dist/client",
    "seo:audit:strict": "node tools/seo-audit.mjs --target=apps/web/dist/client --strict",
    "seo:audit:deep": "node tools/seo-deep-audit.mjs --target=apps/web/dist/client",
    "seo:audit:deep:strict": "node tools/seo-deep-audit.mjs --target=apps/web/dist/client --strict",
    "seo:fix": "node tools/regenerate-local-pages-from-category-templates.mjs && node tools/strengthen-photography-clusters.mjs && node tools/generate-blog-support-pages.mjs && node tools/optimize-legacy-media.mjs && node tools/harden-legacy-seo.mjs && node tools/harden-legacy-performance.mjs && node tools/replace-heavy-legacy-image-references.mjs && node tools/extract-repeated-inline-assets.mjs",
    "perf:audit": "node tools/performance-audit.mjs --target=apps/web/dist/client",
    "local:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "local:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-local.ps1",
    "stack:dev": "corepack pnpm --parallel --filter @matthias-ramahi/cms --filter @matthias-ramahi/web dev",
    "cms:dev": "corepack pnpm --filter @matthias-ramahi/cms dev",
    "cms:build": "corepack pnpm --filter @matthias-ramahi/cms build",
    "cms:start": "corepack pnpm --filter @matthias-ramahi/cms start",
    "cms:audit-readiness": "corepack pnpm --filter @matthias-ramahi/cms audit:readiness",
    "cms:audit-seo": "corepack pnpm --filter @matthias-ramahi/cms audit:seo",
    "cms:suggest-seo": "corepack pnpm --filter @matthias-ramahi/cms suggest:seo",
    "cms:migrate": "corepack pnpm --filter @matthias-ramahi/cms migrate",
    "cms:migrate:create": "corepack pnpm --filter @matthias-ramahi/cms migrate:create",
    "cms:migrate:status": "corepack pnpm --filter @matthias-ramahi/cms migrate:status",
    "cms:types": "corepack pnpm --filter @matthias-ramahi/cms generate:types",
    "cms:importmap": "corepack pnpm --filter @matthias-ramahi/cms generate:importmap",
    "images:optimize": "node tools/optimize-site-images.mjs",
    "web:dev": "corepack pnpm --filter @matthias-ramahi/web dev",
    "web:build": "corepack pnpm --filter @matthias-ramahi/web build",
    "web:preview": "corepack pnpm --filter @matthias-ramahi/web preview",
    "web:test:legacy-routes": "corepack pnpm --filter @matthias-ramahi/web test:legacy-routes",
    "web:test:visual": "corepack pnpm --filter @matthias-ramahi/web test:visual"
  }
}
