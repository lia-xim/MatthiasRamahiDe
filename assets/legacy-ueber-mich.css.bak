:root{
    --ink:#0a0c11;--ink-2:#1a1d24;
    --paper:#f3f1ea;--paper-2:#ebe7dc;--paper-3:#e2dccd;
    --muted:#5b6068;--quiet:rgba(10,12,17,.42);
    --rule:rgba(10,12,17,.14);
    --accent:oklch(54% 0.13 36);--accent-2:oklch(62% 0.10 60);--accent-soft:oklch(82% 0.06 60);
    --mono:'JetBrains Mono','IBM Plex Mono','SFMono-Regular',ui-monospace,Menlo,monospace;
    --serif:'Iowan Old Style','Charter','Iowan',Georgia,'Times New Roman',serif;
    --sans:'Inter Tight','Inter','Söhne','Avenir Next','Helvetica Neue',Arial,system-ui,sans-serif;
    --ease:cubic-bezier(.23,1,.32,1);
  }
  body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;overflow-x:hidden}
  main{display:block}
  img{display:block;max-width:100%;height:auto}
  .am-eyebrow{font:11px var(--mono);letter-spacing:.32em;text-transform:uppercase;color:var(--muted);margin:0;display:inline-flex;align-items:center;gap:12px}
  .am-eyebrow::before{content:"";width:28px;height:1px;background:currentColor;opacity:.55}

  /* =========================================================
     HERO — 2-col, large name + framed portrait + meta strip
     ========================================================= */
  .am-hero{position:relative;min-height:100svh;display:grid;grid-template-columns:1.05fr .95fr;gap:0;background:var(--paper);overflow:hidden;isolation:isolate}
  .am-hero__copy{position:relative;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(120px,14vw,200px) clamp(28px,5vw,84px) clamp(56px,7vw,96px);z-index:2;min-width:0}
  .am-hero__kicker{margin:0 0 36px}
  .am-hero__name{margin:0;font-family:var(--serif);font-weight:600;font-size:clamp(58px,9.2vw,156px);line-height:.88;letter-spacing:-.028em;color:var(--ink);hanging-punctuation:first last;overflow-wrap:break-word}
  .am-hero__name em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 78%,var(--ink) 22%)}
  .am-hero__sub{margin:32px 0 0;font-family:var(--serif);font-style:italic;font-size:clamp(20px,1.95vw,30px);line-height:1.34;color:var(--muted);max-width:34ch}
  .am-hero__meta{margin-top:44px;display:flex;flex-wrap:wrap;gap:10px 30px;font:11px var(--mono);letter-spacing:.22em;text-transform:uppercase;color:var(--muted)}
  .am-hero__meta span{display:inline-flex;align-items:center;gap:10px}
  .am-hero__meta span::before{content:"";display:inline-block;width:6px;height:6px;background:var(--accent);border-radius:50%}

  .am-hero__photo{position:relative;overflow:hidden;background:#0a0c11;min-height:60svh}
  .am-hero__photo img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;filter:contrast(1.04) saturate(.92);transform:scale(1.04);animation:amKB 26s ease-out forwards}
  @keyframes amKB{0%{transform:scale(1.08) translate3d(-.8%,1.2%,0)}100%{transform:scale(1.01) translate3d(.4%,-.4%,0)}}
  .am-hero__photo::after{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(180deg,rgba(243,241,234,.62) 0%,rgba(243,241,234,.16) 96px,rgba(243,241,234,0) 160px),linear-gradient(180deg,rgba(2,3,6,0) 60%,rgba(2,3,6,.34) 100%),linear-gradient(270deg,rgba(2,3,6,0) 86%,rgba(243,241,234,.42) 100%)}
  .am-hero__credit{position:absolute;left:22px;bottom:22px;font:10px var(--mono);letter-spacing:.26em;text-transform:uppercase;color:rgba(243,241,234,.84);text-shadow:0 1px 12px rgba(0,0,0,.6);z-index:1}

  /* tape number top right of photo */
  .am-hero__tag{position:absolute;top:24px;right:22px;display:flex;flex-direction:column;align-items:flex-end;gap:6px;z-index:1;font:10px var(--mono);letter-spacing:.28em;text-transform:uppercase;color:rgba(243,241,234,.86);text-shadow:0 1px 12px rgba(0,0,0,.6)}

  /* =========================================================
     STATS BAND — quick facts
     ========================================================= */
  .am-stats{background:var(--ink);color:#f3f1ea;padding:clamp(56px,7vw,96px) clamp(28px,5vw,84px);border-top:1px solid rgba(255,255,255,.08);border-bottom:1px solid rgba(255,255,255,.08)}
  .am-stats__inner{max-width:1320px;margin:0 auto;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:clamp(24px,4vw,72px);align-items:start}
  .am-stat{position:relative;padding-top:18px;border-top:1px solid rgba(255,255,255,.18)}
  .am-stat__num{font-family:var(--serif);font-style:italic;font-weight:500;font-size:clamp(48px,5.4vw,80px);line-height:1;letter-spacing:-.02em;color:#f7f4ec;font-variant-numeric:lining-nums tabular-nums}
  .am-stat__num em{font-style:italic;color:color-mix(in oklch,var(--accent) 80%,#fff 20%)}
  .am-stat__label{margin:14px 0 0;font:11px var(--mono);letter-spacing:.24em;text-transform:uppercase;color:rgba(243,241,234,.62)}
  .am-stat__note{margin:6px 0 0;font-size:14px;line-height:1.45;color:rgba(243,241,234,.78)}

  /* =========================================================
     INTRO — short, single column with side image
     ========================================================= */
  .am-intro{position:relative;padding:clamp(96px,12vw,180px) clamp(28px,5vw,84px);background:var(--paper)}
  .am-intro__inner{max-width:1320px;margin:0 auto;display:grid;grid-template-columns:6fr 6fr;gap:clamp(40px,7vw,120px);align-items:center}
  .am-intro__copy{min-width:0;display:grid;gap:22px}
  .am-intro__head{margin:0;font-family:var(--serif);font-weight:600;font-size:clamp(40px,5.2vw,80px);line-height:.98;letter-spacing:-.022em}
  .am-intro__head em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 78%,var(--ink) 22%)}
  .am-intro__prose{font-size:clamp(16px,1.16vw,19px);line-height:1.62;color:color-mix(in oklch,var(--ink) 80%,#fff 20%);max-width:56ch;text-wrap:pretty}
  .am-intro__prose p{margin:0 0 1.05em}
  .am-intro__photo{position:relative;aspect-ratio:4/5;overflow:hidden;border:1px solid var(--rule);box-shadow:0 44px 110px rgba(10,12,17,.16)}
  .am-intro__photo img{width:100%;height:100%;object-fit:cover}
  .am-intro__caption{position:absolute;left:16px;bottom:16px;font:10px var(--mono);letter-spacing:.26em;text-transform:uppercase;color:#fff;text-shadow:0 1px 10px rgba(0,0,0,.65)}

  /* =========================================================
     PASSION — second dark editorial text section
     ========================================================= */
  .am-passion{position:relative;padding:clamp(96px,12vw,180px) clamp(28px,5vw,84px);background:var(--ink);color:#f3f1ea;overflow:hidden;isolation:isolate}
  .am-passion::before{content:"";position:absolute;inset:0;background:radial-gradient(70% 60% at 88% 12%,rgba(200,134,82,.10),transparent 65%),radial-gradient(60% 70% at 8% 100%,rgba(120,140,160,.08),transparent 60%);pointer-events:none}
  .am-passion__inner{position:relative;max-width:1320px;margin:0 auto;display:grid;grid-template-columns:5fr 7fr;gap:clamp(40px,7vw,120px);align-items:start}
  .am-passion__lead{min-width:0;display:flex;flex-direction:column;gap:24px}
  .am-passion__kicker{color:rgba(243,241,234,.62)}
  .am-passion__head{margin:0;font-family:var(--serif);font-weight:600;font-size:clamp(40px,5.4vw,86px);line-height:.98;letter-spacing:-.022em;color:#f7f4ec;max-width:14ch}
  .am-passion__head em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 80%,#fff 20%)}
  .am-passion__rule{width:64px;height:1px;background:rgba(243,241,234,.34);margin-top:10px}
  .am-passion__body{min-width:0;display:grid;gap:32px}
  .am-passion__prose{font-size:clamp(16px,1.18vw,19px);line-height:1.66;color:rgba(243,241,234,.84);max-width:62ch;text-wrap:pretty}
  .am-passion__prose p{margin:0 0 1.1em}
  .am-passion__prose p:last-child{margin:0}
  .am-passion__notes{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:clamp(20px,2.6vw,40px);margin-top:8px;border-top:1px solid rgba(243,241,234,.18);padding-top:32px}
  .am-passion__note{min-width:0}
  .am-passion__note-tag{font:10px var(--mono);letter-spacing:.28em;text-transform:uppercase;color:rgba(243,241,234,.5);margin:0 0 8px}
  .am-passion__note-text{font-family:var(--serif);font-style:italic;font-size:clamp(16px,1.18vw,20px);line-height:1.4;color:rgba(243,241,234,.92);margin:0}

  /* =========================================================
     QUOTE — full-bleed dark editorial pull-quote
     ========================================================= */
  .am-quote{position:relative;padding:clamp(120px,15vw,200px) clamp(28px,5vw,84px);background:var(--paper);color:var(--ink);overflow:hidden;isolation:isolate}
  .am-quote::before{content:"";position:absolute;inset:0;background:radial-gradient(60% 70% at 22% 30%,rgba(200,134,82,.10),transparent 60%),radial-gradient(50% 60% at 80% 70%,rgba(120,130,140,.06),transparent 65%);pointer-events:none}
  .am-quote__inner{position:relative;max-width:1100px;margin:0 auto}
  .am-quote__mark{position:absolute;left:-6px;top:-58px;font-family:var(--serif);font-style:italic;font-size:clamp(140px,16vw,240px);line-height:.7;color:color-mix(in oklch,var(--accent) 60%,var(--ink) 18%);opacity:.16;pointer-events:none;user-select:none}
  .am-quote__text{margin:0;font-family:var(--serif);font-weight:500;font-style:italic;font-size:clamp(30px,3.8vw,60px);line-height:1.18;letter-spacing:-.018em;color:var(--ink);text-wrap:balance;max-width:24ch}
  .am-quote__text em{font-style:italic;color:color-mix(in oklch,var(--accent) 80%,var(--ink) 20%)}
  .am-quote__cite{margin-top:42px;font:11px var(--mono);letter-spacing:.28em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:14px}
  .am-quote__cite::before{content:"";width:36px;height:1px;background:var(--rule)}

  /* =========================================================
     SOPHIA — sister, video companion
     ========================================================= */
  .am-sister{padding:clamp(96px,12vw,180px) clamp(28px,5vw,84px);background:var(--ink);color:#f3f1ea;position:relative;overflow:hidden;isolation:isolate}
  .am-sister::before{content:"";position:absolute;inset:0;background:radial-gradient(60% 70% at 80% 20%,rgba(200,134,82,.13),transparent 65%),radial-gradient(50% 60% at 10% 80%,rgba(140,160,170,.08),transparent 60%);pointer-events:none}
  .am-sister__inner{position:relative;max-width:1320px;margin:0 auto;display:grid;grid-template-columns:7fr 5fr;gap:clamp(40px,7vw,120px);align-items:center}
  .am-sister__copy{min-width:0}
  .am-sister__copy .am-eyebrow{color:rgba(243,241,234,.62)}
  .am-sister__copy .am-eyebrow::before{background:rgba(243,241,234,.42)}
  .am-sister__head{margin:18px 0 22px;font-family:var(--serif);font-weight:600;font-size:clamp(36px,4.8vw,72px);line-height:1.02;letter-spacing:-.022em;max-width:20ch;color:#f7f4ec}
  .am-sister__head em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 84%,#fff 16%)}
  .am-sister__lead{font-size:clamp(17px,1.24vw,20px);line-height:1.55;color:rgba(243,241,234,.78);max-width:54ch;margin:0 0 18px;font-style:italic;font-family:var(--serif)}
  .am-sister__prose{font-size:16px;line-height:1.6;color:rgba(243,241,234,.72);max-width:54ch;margin:0 0 28px}
  .am-sister__btn{display:inline-flex;align-items:center;gap:12px;padding:14px 20px;border:1px solid rgba(243,241,234,.42);font:11px var(--mono);letter-spacing:.24em;text-transform:uppercase;color:#f3f1ea;text-decoration:none;background:transparent;transition:background .3s var(--ease),color .3s var(--ease),border-color .3s var(--ease)}
  .am-sister__btn:hover{background:rgba(243,241,234,.96);color:var(--ink);border-color:rgba(243,241,234,.96)}
  .am-sister__card{position:relative;padding:clamp(28px,3vw,44px);background:var(--paper);color:var(--ink);border:1px solid color-mix(in oklch,var(--paper) 70%,var(--ink) 30%);min-height:380px;display:flex;flex-direction:column;justify-content:space-between;gap:32px;overflow:hidden}
  .am-sister__card::before{content:"";position:absolute;inset:0;background:radial-gradient(80% 60% at 0% 100%,rgba(200,134,82,.12),transparent 65%);pointer-events:none}
  .am-sister__card-tag{position:relative;font:10px var(--mono);letter-spacing:.28em;text-transform:uppercase;color:var(--muted)}
  .am-sister__card-name{position:relative;margin:0;font-family:var(--serif);font-weight:600;font-size:clamp(40px,4.6vw,68px);line-height:.96;letter-spacing:-.022em;color:var(--ink)}
  .am-sister__card-name em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 78%,var(--ink) 22%)}
  .am-sister__card-role{position:relative;font:11px var(--mono);letter-spacing:.24em;text-transform:uppercase;color:var(--muted);display:flex;flex-wrap:wrap;gap:8px 18px}
  .am-sister__card-role span{display:inline-flex;align-items:center;gap:8px}
  .am-sister__card-role span::before{content:"";width:5px;height:5px;background:var(--accent);border-radius:50%}

  /* =========================================================
     CTA — closing
     ========================================================= */
  .am-cta{position:relative;padding:clamp(120px,14vw,200px) clamp(28px,5vw,84px);background:var(--paper);color:var(--ink);overflow:hidden}
  .am-cta::before{content:"";position:absolute;inset:0;background:radial-gradient(60% 80% at 80% 30%,rgba(200,134,82,.10),transparent 65%),radial-gradient(50% 70% at 10% 80%,rgba(120,140,150,.06),transparent 60%);pointer-events:none}
  .am-cta__inner{position:relative;max-width:1320px;margin:0 auto;display:grid;grid-template-columns:7fr 5fr;gap:clamp(40px,6vw,96px);align-items:end}
  .am-cta__head{margin:24px 0 0;font-family:var(--serif);font-weight:600;font-size:clamp(48px,6.4vw,108px);line-height:.96;letter-spacing:-.026em;color:var(--ink);max-width:14ch}
  .am-cta__head em{font-style:italic;font-weight:500;color:color-mix(in oklch,var(--accent) 80%,var(--ink) 20%)}
  .am-cta__side{display:flex;flex-direction:column;gap:18px}
  .am-cta__lead{margin:0;font-family:var(--serif);font-style:italic;font-size:clamp(17px,1.4vw,22px);line-height:1.45;color:var(--muted);max-width:36ch}
  .am-cta__actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}
  .am-cta__btn{display:inline-flex;align-items:center;gap:12px;padding:16px 24px;border:1px solid var(--ink);font:11px var(--mono);letter-spacing:.24em;text-transform:uppercase;color:var(--ink);background:transparent;transition:background .3s var(--ease),color .3s var(--ease),border-color .3s var(--ease)}
  .am-cta__btn:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  .am-cta__btn--ghost{border-color:var(--rule);color:var(--muted)}

  /* =========================================================
     RESPONSIVE
     ========================================================= */
  @media(max-width:1080px){
    .am-hero{grid-template-columns:1fr;min-height:auto}
    .am-hero__copy{padding-bottom:clamp(40px,6vw,72px)}
    .am-hero__photo{min-height:62svh;aspect-ratio:4/5}
    .am-intro__inner,.am-sister__inner,.am-passion__inner{grid-template-columns:1fr;gap:40px}
    .am-passion__notes{grid-template-columns:1fr;gap:20px;padding-top:24px}
    .am-intro__photo{max-height:62svh}
    .am-cta__inner{grid-template-columns:1fr;align-items:start;gap:40px}
    .am-stats__inner{grid-template-columns:repeat(2,1fr);gap:32px}
  }
  @media(max-width:680px){
    .am-stats__inner{grid-template-columns:1fr}
    .am-quote__mark{font-size:clamp(100px,28vw,160px);top:-30px}
  }
  @media(prefers-reduced-motion:reduce){
    .am-hero__photo img{animation:none;transform:scale(1.01)}
  }
