---
// apps/web/src/components/ContentBlocks.astro — AFTER
//
// Only the additions for `clientLogosStrip` are shown in full. Existing
// blocks (textBlock, imageSequence, quoteBlock, faqBlock, linkList, ctaBlock)
// are unchanged from before; their code is elided with comments.

import ResponsiveImage from './ResponsiveImage.astro'
import type { PayloadMedia } from '../lib/payload'

type RichText = {
  root?: {
    children?: Array<{
      children?: Array<{ text?: string }>
    }>
  }
}

type ImageSequenceItem = {
  image?: PayloadMedia | string
  caption?: string
  cropIntent?: string
}

type FaqItem = { question?: string; answer?: string }
type LinkItem = { label?: string; href?: string; description?: string }

// NEW — client-logo strip item type.
type ClientLogoItem = {
  image?: PayloadMedia | string
  name?: string
  note?: string
  href?: string
}

type ContentBlock =
  | { blockType: 'textBlock'; eyebrow?: string; headline?: string; body?: RichText }
  | { blockType: 'imageSequence'; headline?: string; layout?: string; items?: ImageSequenceItem[] }
  | { blockType: 'quoteBlock'; quote?: string; attribution?: string }
  | { blockType: 'faqBlock'; headline?: string; items?: FaqItem[] }
  | { blockType: 'linkList'; headline?: string; links?: LinkItem[] }
  | { blockType: 'ctaBlock'; headline?: string; text?: string; buttonLabel?: string; emailSubject?: string }
  // NEW
  | {
      blockType: 'clientLogosStrip'
      eyebrow?: string
      headline?: string
      theme?: 'dark' | 'light'
      logos?: ClientLogoItem[]
    }

const { blocks = [] } = Astro.props as { blocks?: ContentBlock[] }

const richTextToPlainText = (body?: RichText) =>
  body?.root?.children
    ?.map((node) => node.children?.map((child) => child.text).filter(Boolean).join(' ') || '')
    .filter(Boolean)
    .join('\n\n') || ''
---
{
  blocks.map((block: ContentBlock) => {
    // … existing branches (textBlock, imageSequence, quoteBlock, faqBlock,
    //   linkList, ctaBlock) unchanged — keep them exactly as they were …

    // ── NEW BRANCH ─────────────────────────────────────────────────────────
    if (block.blockType === 'clientLogosStrip') {
      const theme = block.theme === 'light' ? 'light' : 'dark'
      const logos = block.logos ?? []
      if (logos.length === 0) return null
      return (
        <section
          class={`logo-strip is-${theme}`}
          data-theme={theme}
          data-header-theme={theme}
          aria-label={block.eyebrow || 'Auftraggeber'}
        >
          <div class="container logo-strip__inner">
            {(block.eyebrow || block.headline) && (
              <header class="logo-strip__head">
                {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
                {block.headline && (
                  <h2 class="display" style="font-size: clamp(28px, 3.4vw, 52px); margin: 8px 0 0;">
                    {block.headline}
                  </h2>
                )}
              </header>
            )}
            <ul class="logo-strip__grid" role="list">
              {logos.map((logo: ClientLogoItem) => {
                const cellInner = (
                  <>
                    <span class="logo-strip__media">
                      <ResponsiveImage
                        media={logo.image}
                        size="card"
                        sizes="(max-width: 640px) 40vw, 160px"
                        fallback={logo.name || 'Logo'}
                      />
                    </span>
                    {logo.name && <span class="logo-strip__name">{logo.name}</span>}
                    {logo.note && <span class="logo-strip__note">{logo.note}</span>}
                  </>
                )
                return (
                  <li class="logo-strip__cell">
                    {logo.href ? (
                      <a
                        class="logo-strip__link"
                        href={logo.href}
                        rel={logo.href.startsWith('http') ? 'noopener external' : undefined}
                        target={logo.href.startsWith('http') ? '_blank' : undefined}
                      >
                        {cellInner}
                      </a>
                    ) : (
                      cellInner
                    )}
                  </li>
                )
              })}
            </ul>
          </div>
        </section>
      )
    }
    // ── /NEW BRANCH ────────────────────────────────────────────────────────

    return null
  })
}

<style>
  /* ──────────────────────────────────────────────────────────────────────
     clientLogosStrip — editorial colophon, NOT a "trusted by" badge wall.
     Visual borrows:
       • cell matrix joined by 1px gap on --border  → audience__grid, mr-cities__grid
       • monochrome-by-default, quiet on hover      → related__card filter posture
       • mono micro-metadata under each item        → topic-spread __note line
       • container, eyebrow, display class reuse    → site-wide typography
     ────────────────────────────────────────────────────────────────────── */
  .logo-strip {
    padding: clamp(48px, 7vw, 96px) 0;
  }
  .logo-strip.is-dark {
    background: var(--bg);
    color: var(--fg);
  }
  .logo-strip.is-light {
    background: var(--paper);
    color: var(--paper-ink);
  }

  .logo-strip__head {
    margin-bottom: clamp(22px, 3.4vw, 36px);
    max-width: 56rem;
  }
  .logo-strip.is-light .logo-strip__head .eyebrow {
    color: color-mix(in oklch, var(--paper-ink) 58%, transparent);
  }

  /* Joined matrix — 1px gap on a rule background, same idiom as audience cards
     and the mr-cities grid. auto-fit lets the editor put in 4 or 14 logos
     without us re-tuning columns. */
  .logo-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .logo-strip.is-light .logo-strip__grid {
    background: color-mix(in oklch, var(--paper-ink) 12%, transparent);
    border-color: color-mix(in oklch, var(--paper-ink) 13%, transparent);
  }

  .logo-strip__cell {
    background: var(--surface);
    min-height: clamp(96px, 11vw, 140px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: clamp(18px, 2.4vw, 28px) clamp(14px, 2vw, 22px);
    text-align: center;
  }
  .logo-strip.is-light .logo-strip__cell {
    background: var(--paper);
  }

  .logo-strip__link {
    display: contents; /* keep the cell's flex layout; just make it activatable */
  }

  /* The logo itself: monochrome by default; on hover it un-mutes slightly.
     No scale-up, no card-lift, no color flash. Same restraint as related__card. */
  .logo-strip__media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 140px;
    height: clamp(28px, 3.4vw, 44px);
  }
  .logo-strip__media :global(picture),
  .logo-strip__media :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) contrast(0.95);
    opacity: 0.66;
    transition: opacity 0.45s var(--ease), filter 0.45s var(--ease);
  }
  .logo-strip.is-light .logo-strip__media :global(img) {
    /* On paper, brighten the monochrome curve so dark logos sit clearly,
       light logos don't disappear into the page. */
    filter: grayscale(1) brightness(0.55) contrast(1.05);
    opacity: 0.72;
  }
  .logo-strip__cell:hover .logo-strip__media :global(img),
  .logo-strip__link:focus-visible .logo-strip__media :global(img) {
    opacity: 1;
    filter: grayscale(1) contrast(1);
  }
  .logo-strip.is-light .logo-strip__cell:hover .logo-strip__media :global(img) {
    filter: grayscale(1) brightness(0.4) contrast(1.1);
    opacity: 1;
  }

  /* Name fallback — hidden visually when the image renders, but the
     ResponsiveImage component handles its own fallback via alt text, so this
     stays as supplementary editorial credit if the editor wants it visible.
     We render it as visually-hidden by default; uncomment the second rule to
     show it permanently as a label. */
  .logo-strip__name {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .logo-strip__note {
    font: 700 9.5px/1.4 var(--font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }
  .logo-strip.is-light .logo-strip__note {
    color: color-mix(in oklch, var(--paper-ink) 55%, transparent);
  }

  /* Reduced motion: nothing to do — there are no transforms to suppress.
     Transitions on opacity/filter are below the threshold; honor reduce
     by making them instant. */
  @media (prefers-reduced-motion: reduce) {
    .logo-strip__media :global(img) {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .logo-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .logo-strip__cell {
      min-height: 92px;
    }
  }
</style>
