---
import ResponsiveImage from './ResponsiveImage.astro'
import type { PayloadMedia } from '../lib/payload'

type RichText = {
  root?: {
    children?: Array<{
      children?: Array<{ text?: string }>
    }>
  }
}

type ImageSequenceItem = {
  image?: PayloadMedia | string
  caption?: string
  cropIntent?: string
}

type FaqItem = { question?: string; answer?: string }
type LinkItem = { label?: string; href?: string; description?: string }
type ClientLogoItem = {
  logo?: PayloadMedia | string
  name?: string
  href?: string
}

type ContentBlock =
  | { blockType: 'textBlock'; eyebrow?: string; headline?: string; body?: RichText }
  | { blockType: 'imageSequence'; headline?: string; layout?: string; items?: ImageSequenceItem[] }
  | { blockType: 'quoteBlock'; quote?: string; attribution?: string }
  | { blockType: 'faqBlock'; headline?: string; items?: FaqItem[] }
  | { blockType: 'linkList'; headline?: string; links?: LinkItem[] }
  | {
      blockType: 'clientLogosStrip'
      eyebrow?: string
      headline?: string
      theme?: 'dark' | 'light'
      treatment?: 'monochrome' | 'original'
      logos?: ClientLogoItem[]
    }
  | { blockType: 'ctaBlock'; headline?: string; text?: string; buttonLabel?: string; emailSubject?: string }

const { blocks = [] } = Astro.props as { blocks?: ContentBlock[] }

const richTextToPlainText = (body?: RichText) =>
  body?.root?.children
    ?.map((node) => node.children?.map((child) => child.text).filter(Boolean).join(' ') || '')
    .filter(Boolean)
    .join('\n\n') || ''

/**
 * Splits a headline on a single *…* pair so we can render the inside as a
 * steel-/sage-coloured <em> — the site's canonical headline em-treatment.
 * Falls back to plain text if no markers are present.
 */
const splitHeadlineEm = (headline?: string) => {
  if (!headline) return null
  const match = headline.match(/^(.*?)\*([^*]+)\*(.*)$/)
  if (!match) return { lead: headline, em: '', tail: '' }
  return { lead: match[1], em: match[2], tail: match[3] }
}

const resolveLogoUrl = (logo?: PayloadMedia | string) => {
  if (!logo) return null
  if (typeof logo === 'string') return logo
  return logo.url ?? null
}
---
{
  blocks.map((block: ContentBlock) => {
    if (block.blockType === 'textBlock') {
      return (
        <section class="container" style="padding: clamp(58px, 8vw, 120px) 0;">
          {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
          {block.headline && <h2 class="display" style="font-size: clamp(42px, 8vw, 124px); margin: 14px 0 24px;">{block.headline}</h2>}
          <p class="copy" style="max-width: 62rem; font-size: clamp(18px, 1.8vw, 24px); white-space: pre-line;">{richTextToPlainText(block.body)}</p>
        </section>
      )
    }

    if (block.blockType === 'imageSequence') {
      return (
        <section class="container" style="padding: clamp(42px, 6vw, 96px) 0;">
          {block.headline && <p class="eyebrow" style="margin-bottom: 18px;">{block.headline}</p>}
          <div class="card-grid">
            {(block.items ?? []).map((item: ImageSequenceItem) => (
              <article class="card" style="padding: 0; min-height: 0;">
                <ResponsiveImage media={item.image} size="card" fallback="Bild aus CMS" />
                {item.caption && <p class="copy" style="padding: 18px;">{item.caption}</p>}
              </article>
            ))}
          </div>
        </section>
      )
    }

    if (block.blockType === 'quoteBlock') {
      return (
        <section class="container" style="padding: clamp(64px, 10vw, 150px) 0;">
          <blockquote class="display" style="font-size: clamp(40px, 7vw, 112px); margin: 0;">„{block.quote}“</blockquote>
          {block.attribution && <p class="eyebrow" style="margin-top: 20px;">{block.attribution}</p>}
        </section>
      )
    }

    if (block.blockType === 'faqBlock') {
      return (
        <section class="container" style="padding: clamp(54px, 8vw, 120px) 0;">
          {block.headline && <h2 class="display" style="font-size: clamp(38px, 6vw, 96px); margin: 0 0 28px;">{block.headline}</h2>}
          <div class="stack-list">
            {(block.items ?? []).map((item: FaqItem) => (
              <article class="stack-item">
                <h3>{item.question}</h3>
                <p class="copy">{item.answer}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    if (block.blockType === 'linkList') {
      return (
        <section class="container" style="padding: clamp(54px, 8vw, 120px) 0;">
          {block.headline && <p class="eyebrow" style="margin-bottom: 18px;">{block.headline}</p>}
          <div class="stack-list">
            {(block.links ?? []).map((link: LinkItem) => (
              <a class="stack-item" href={link.href || '#'}>
                <h3>{link.label}</h3>
                {link.description && <p class="copy">{link.description}</p>}
              </a>
            ))}
          </div>
        </section>
      )
    }

    if (block.blockType === 'clientLogosStrip') {
      const theme = block.theme ?? 'dark'
      const treatment = block.treatment ?? 'monochrome'
      const logos = (block.logos ?? []).filter((l) => resolveLogoUrl(l.logo))
      if (logos.length === 0) return null
      const split = splitHeadlineEm(block.headline)
      return (
        <section
          class="client-logos"
          data-theme={theme}
          data-header-theme={theme}
          data-treatment={treatment}
        >
          <div class="container client-logos__inner">
            {(block.eyebrow || split) && (
              <header class="client-logos__head">
                {block.eyebrow && <span class="eyebrow client-logos__kicker">{block.eyebrow}</span>}
                {split && (
                  <h2 class="display client-logos__title">
                    {split.lead}
                    {split.em && <em>{split.em}</em>}
                    {split.tail}
                  </h2>
                )}
              </header>
            )}
            <ul class="client-logos__row" role="list">
              {logos.map((item: ClientLogoItem) => {
                const url = resolveLogoUrl(item.logo)
                const label = item.name || 'Kunde'
                const cell = (
                  <span class="client-logos__cell">
                    <img src={url!} alt={label} loading="lazy" decoding="async" />
                    <span class="client-logos__name">{label}</span>
                  </span>
                )
                return (
                  <li class="client-logos__item">
                    {item.href ? (
                      <a
                        href={item.href}
                        rel="noopener noreferrer"
                        target={item.href.startsWith('http') ? '_blank' : undefined}
                        aria-label={label}
                      >
                        {cell}
                      </a>
                    ) : (
                      cell
                    )}
                  </li>
                )
              })}
            </ul>
          </div>
        </section>
      )
    }

    if (block.blockType === 'ctaBlock') {
      return (
        <section class="container" style="padding: clamp(54px, 8vw, 120px) 0;">
          <div class="card" style="background: var(--paper); color: var(--paper-ink); min-height: 320px;">
            <p class="eyebrow" style="color: color-mix(in oklch, var(--paper-ink) 58%, transparent);">Anfrage</p>
            <h2 class="display" style="font-size: clamp(42px, 7vw, 116px); margin: 12px 0 24px;">{block.headline}</h2>
            {block.text && <p class="copy" style="color: color-mix(in oklch, var(--paper-ink) 64%, transparent); max-width: 48rem;">{block.text}</p>}
            <a class="button is-accent" style="width: max-content; margin-top: 28px;" href="/kontakt#anfrage">{block.buttonLabel || 'Projekt anfragen'}</a>
            <p class="copy" style="margin-top: 14px; color: color-mix(in oklch, var(--paper-ink) 58%, transparent);">Unverbindlich. Antwort meist innerhalb von 24 Stunden.</p>
          </div>
        </section>
      )
    }

    return null
  })
}

<style>
  /* Client logos strip — a quiet hairline-divided row.
     Same visual logic as .audience__grid and .mr-cities__grid: cells
     joined by 1px gaps over --border, no shadows, no rounded corners.
     "Monochrome" treatment flattens brand colors so the row reads as
     one editorial unit, not a Pinterest sponsor wall. */
  .client-logos {
    padding: clamp(54px, 8vw, 110px) 0;
    background: var(--bg);
    color: var(--fg);
  }
  .client-logos[data-theme='light'] {
    background: var(--paper);
    color: var(--paper-ink);
  }
  .client-logos__inner {
    display: grid;
    gap: clamp(28px, 4vw, 56px);
  }
  .client-logos__head {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(28px, 6vw, 96px);
    align-items: end;
  }
  .client-logos__kicker {
    grid-column: 1;
    align-self: start;
    color: var(--muted);
  }
  .client-logos[data-theme='light'] .client-logos__kicker {
    color: color-mix(in oklch, var(--paper-ink) 58%, transparent);
  }
  .client-logos__title {
    grid-column: 1 / -1;
    margin: 0;
    font-size: clamp(38px, 6vw, 96px);
    line-height: 0.94;
    text-transform: uppercase;
    letter-spacing: -0.025em;
  }
  .client-logos__title em {
    font-style: normal;
    font-weight: 500;
    /* Steel-grey / sage — canonical headline em-color.
       Falls back gracefully when --accent-2 is not yet declared. */
    color: var(--accent-2, #7a8a86);
  }

  .client-logos__row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .client-logos[data-theme='light'] .client-logos__row {
    background: color-mix(in oklch, var(--paper-ink) 13%, transparent);
    border-top-color: color-mix(in oklch, var(--paper-ink) 13%, transparent);
    border-bottom-color: color-mix(in oklch, var(--paper-ink) 13%, transparent);
  }

  .client-logos__item {
    background: var(--bg);
    display: flex;
    min-height: 112px;
  }
  .client-logos[data-theme='light'] .client-logos__item {
    background: var(--paper);
  }

  .client-logos__item > a,
  .client-logos__cell {
    display: grid;
    place-items: center;
    width: 100%;
    padding: clamp(20px, 2.4vw, 32px) clamp(18px, 2vw, 28px);
    color: inherit;
    text-decoration: none;
  }

  .client-logos__item img {
    max-width: 100%;
    max-height: 44px;
    width: auto;
    height: auto;
    object-fit: contain;
    /* Monochrome by default — kills colored logos so the row stays one
       editorial unit. Hover lifts to original-ish for a subtle photographic feel. */
    opacity: 0.78;
    transition: opacity 0.6s var(--ease), filter 0.6s var(--ease);
  }
  .client-logos[data-treatment='monochrome'][data-theme='dark'] .client-logos__item img {
    filter: grayscale(1) brightness(1.6) contrast(1.05);
  }
  .client-logos[data-treatment='monochrome'][data-theme='light'] .client-logos__item img {
    filter: grayscale(1) brightness(0.35) contrast(1.1);
  }
  .client-logos__item:hover img,
  .client-logos__item:focus-within img {
    opacity: 1;
  }
  .client-logos[data-treatment='monochrome'] .client-logos__item:hover img,
  .client-logos[data-treatment='monochrome'] .client-logos__item:focus-within img {
    filter: grayscale(0) brightness(1) contrast(1);
  }

  .client-logos__name {
    /* Visually hidden but reachable for SR — the visual is logo-only. */
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1100px) {
    .client-logos__row { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .client-logos__row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .client-logos__head { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-logos__item img { transition: none; }
  }
</style>
